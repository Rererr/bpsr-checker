// メイン窓（S2: タブ + プレイヤーテーブル）。
// 列の settings 連動・スキル内訳・被ダメドリルダウンは後続の増分で拡充する。

struct Row {
    rank: int,
    name: string,
    class-color: color,
    dmg-text: string,
    dps-text: string,
    pct-text: string,
    pct: float,        // 0..100（割合バー幅。topValue 基準）
    is-local: bool,
}

component TabButton inherits TouchArea {
    in property <string> label;
    in property <bool> active;
    Rectangle {
        background: root.active ? #2d6cdf66 : (root.has-hover ? #ffffff14 : transparent);
        border-radius: 4px;
        HorizontalLayout {
            padding-left: 9px;
            padding-right: 9px;
            Text {
                text: root.label;
                color: root.active ? white : #b8b8c8;
                font-size: 12px;
                vertical-alignment: center;
            }
        }
    }
}

component PlayerRowItem inherits Rectangle {
    in property <Row> entry;
    in property <bool> highlight-local;
    height: 20px;
    // 自分は行を薄く金色に着色（左の色縦線はクラス色ティックのみ＝二重線を解消）
    background: (root.entry.is-local && root.highlight-local) ? #ffd7001f : transparent;

    // 割合バー（クラス色グラデーション）
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.entry.pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, root.entry.class-color.with-alpha(0.22) 0%, transparent 100%);
    }

    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        // 名前セル（クラス色ティック + 名前）
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 5px;
            Rectangle {
                width: 3px;
                background: root.entry.class-color;
                border-radius: 1px;
            }
            Text {
                text: root.entry.name;
                color: white;
                font-size: 12px;
                overflow: elide;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
        }
        Text { text: root.entry.dmg-text; color: #e6e6f0; font-size: 12px; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.dps-text; color: #4fc3f7; font-size: 12px; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.pct-text; color: #cfcfe0; font-size: 11px; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
    }
}

// no-frame 窓の縁/角リサイズ用ハンドル。
component ResizeHandle inherits TouchArea {
    in property <int> dir;
    callback resize(int);
    pointer-event(e) => {
        if (e.kind == PointerEventKind.down) {
            root.resize(root.dir);
        }
    }
}

export component MainWindow inherits Window {
    in property <[Row]> rows;
    in property <string> total-text: "0";
    in property <string> elapsed-text: "0:00";
    in property <bool> highlight-local: true;
    in property <int> tab: 0; // 0=dps 1=heal 2=taken 3=history（Rust が set）
    callback quit();
    callback start-drag();
    callback start-resize(int);
    callback select-tab(int);

    title: @tr("DPSメーター");
    no-frame: true;
    always-on-top: true;
    background: #14141ecc;
    preferred-width: 520px;
    preferred-height: 360px;

    VerticalLayout {
        // ── ヘッダ（タブ + 合計 + ドラッグ + 終了）──
        Rectangle {
            height: 26px;
            background: #1c1c2acc;
            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                spacing: 2px;
                TabButton { label: @tr("DPS"); active: root.tab == 0; clicked => { root.select-tab(0); } }
                TabButton { label: @tr("回復"); active: root.tab == 1; clicked => { root.select-tab(1); } }
                TabButton { label: @tr("被ダメ"); active: root.tab == 2; clicked => { root.select-tab(2); } }
                TabButton { label: @tr("履歴"); active: root.tab == 3; clicked => { root.select-tab(3); } }
                drag := TouchArea {
                    horizontal-stretch: 1;
                    mouse-cursor: move;
                    pointer-event(ev) => {
                        if (ev.kind == PointerEventKind.down) {
                            root.start-drag();
                        }
                    }
                    Text {
                        x: parent.width - self.width - 6px;
                        text: @tr("合計DPS") + " " + root.total-text + "   " + @tr("経過") + " " + root.elapsed-text;
                        color: #c8c8d8;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
                quit-btn := TouchArea {
                    width: 26px;
                    clicked => { root.quit(); }
                    Rectangle {
                        background: quit-btn.has-hover ? #c0392b : transparent;
                        border-radius: 4px;
                        Text { text: "✕"; color: white; font-size: 12px; }
                    }
                }
            }
        }

        // ── 列見出し ──
        Rectangle {
            height: 16px;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;
                Text { text: @tr("プレイヤー"); color: #888; font-size: 10px; horizontal-stretch: 1; vertical-alignment: center; }
                Text {
                    text: root.tab == 1 ? @tr("回復") : (root.tab == 2 ? @tr("被ダメ") : @tr("ダメージ"));
                    color: #888;
                    font-size: 10px;
                    width: 64px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
                Text { text: @tr("DPS"); color: #888; font-size: 10px; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
                Text { text: @tr("%"); color: #888; font-size: 10px; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
            }
        }

        // ── 行（スクロール）──
        Flickable {
            vertical-stretch: 1;
            viewport-height: rowbox.preferred-height;
            rowbox := VerticalLayout {
                for row in root.rows: PlayerRowItem {
                    entry: row;
                    highlight-local: root.highlight-local;
                }
                if root.rows.length == 0: Text {
                    text: @tr("データなし");
                    color: #666;
                    font-size: 12px;
                    height: 40px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    // ── リサイズハンドル（縁/角ドラッグでサイズ変更）。縁6px・角14px で掴みやすく ──
    ResizeHandle { dir: 0; mouse-cursor: ns-resize; resize(d) => { root.start-resize(d); } x: 14px; y: 0; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 1; mouse-cursor: ns-resize; resize(d) => { root.start-resize(d); } x: 14px; y: root.height - 6px; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 2; mouse-cursor: ew-resize; resize(d) => { root.start-resize(d); } x: root.width - 6px; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 3; mouse-cursor: ew-resize; resize(d) => { root.start-resize(d); } x: 0; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 5; mouse-cursor: nwse-resize; resize(d) => { root.start-resize(d); } x: 0; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 4; mouse-cursor: nesw-resize; resize(d) => { root.start-resize(d); } x: root.width - 14px; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 7; mouse-cursor: nesw-resize; resize(d) => { root.start-resize(d); } x: 0; y: root.height - 14px; width: 14px; height: 14px; }
    ResizeHandle { dir: 6; mouse-cursor: nwse-resize; resize(d) => { root.start-resize(d); } x: root.width - 14px; y: root.height - 14px; width: 14px; height: 14px; }
}
