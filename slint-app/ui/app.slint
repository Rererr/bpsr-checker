// メイン窓（S2: タブ + プレイヤーテーブル + スキル内訳ドリルダウン）。
// 条件付き列・被ダメドリルダウンは後続増分。

struct Row {
    rank: int,
    uid-str: string,   // f64 uid を精度落ちさせず Rust へ返すため文字列で持つ
    name: string,
    class-color: color,
    dmg-text: string,
    dps-text: string,
    pct-text: string,
    pct: float,        // 0..100（割合バー幅。topValue 基準）
    is-local: bool,
    // 条件付き列（settings 連動）
    crit-text: string,
    crit-value-text: string,
    lucky-text: string,
    lucky-value-text: string,
    hits-text: string,
    hpm-text: string,
    score-text: string,
    watched: bool,
    spark-commands: string, // この行のDPS推移（空=非表示行）。viewbox 100x16
    food-active: bool,      // 食事バフ使用中
    food-remaining: float,  // 食事の残量割合 0..1（アイコンの色が上から縦に抜ける）
    food-time: string,      // ホバー時の残り時間（例: 45s）
    food-label: string,     // ホバー時の種類ラベル（例: 物攻 +15。空=不明）
    syrup-active: bool,     // シロップ(錬金)バフ使用中
    syrup-remaining: float, // シロップの残量割合 0..1
    syrup-time: string,     // ホバー時の残り時間
    syrup-label: string,    // ホバー時の種類ラベル
}

struct ColumnFlags {
    crit: bool,
    crit-value: bool,
    lucky: bool,
    lucky-value: bool,
    hits: bool,
    hpm: bool,
    score: bool,
}

// 設定パネルのトグル表示状態（Rust が cfg から set）
struct SettingsUi {
    show-crit: bool,
    show-crit-value: bool,
    show-lucky: bool,
    show-lucky-value: bool,
    show-hits: bool,
    show-hpm: bool,
    show-score: bool,
    highlight-local: bool,
    abbreviate-scores: bool,
    privacy-mask: bool,
    self-status: bool,
    stats-overlay: bool,
    buff-overlay: bool,
    imagine-only: bool,
    aot: bool,
    three-min-auto-open: bool,
    compact-split: bool,
    graph-for-local: bool,
    startup-tab: string,
    language: string,            // UI 表示言語（"ja" / "en"）
    accent-theme: string,
    sync-timer: bool,   // イマジンタイマーをメインDPS画面と同期（顔ぶれ・並びを追従）。imagine-only と排他
    sync-order-follow: bool, // 同期ONのときだけ意味を持つ子設定: 並び順までメイン一覧へ追従するか
    show-imagine-tina: bool,
    show-imagine-aluna: bool,
    show-imagine-tarta: bool,
    show-imagine-basilisk: bool,
    show-consumable: bool,
    show-in-taskbar: bool,
    overlay-text-color: string,  // オーバーレイ共通の基準テキスト色（プリセットキー or #rrggbb）
    main-font: string,           // メイン窓フォントファミリ（バフ/デバフ オーバーレイも追随）
    main-font-bold: bool,        // メイン窓フォントの太字（同上）
    stats-overlay-font: string,        // ステータス窓 専用フォントファミリ
    stats-overlay-font-bold: bool,     // ステータス窓 専用フォントの太字
    imagine-overlay-font: string,      // イマジンタイマー 専用フォントファミリ
    imagine-overlay-font-bold: bool,   // イマジンタイマー 専用フォントの太字
    imagine-compact-rows: bool,        // イマジンタイマー 密表示（行を詰める）
    overlay-outline: bool,             // オーバーレイ文字の縁取り（stroke）
    overlay-shadow: bool,              // オーバーレイ文字の影（ドロップシャドウ）
}

// 数値設定の表示用（Rust が cfg から整形して set）。ステッパーで増減する。
struct SettingsNumUi {
    combat-exit: string,
    poll-interval: string,
    history-limit: string,
    ts-samples: string,
    ts-interval: string,
    three-min-dur: string,
    graph-count: string,
    font-size: string,                  // メイン窓フォントサイズ（バフ/デバフ オーバーレイも追随）
    stats-overlay-font-size: string,    // ステータス窓 専用フォントサイズ
    imagine-overlay-font-size: string,  // イマジンタイマー 専用フォントサイズ
}

struct SkillRowUi {
    uid-str: string,   // 被ダメ攻撃元のドリルダウンに使う（スキル行では未使用）
    name: string,
    elem-id: int,      // 属性 0..8（>8=無し）。ElementIcon で描画
    elem-color: color,
    total-text: string,
    dps-text: string,
    pct-text: string,
    pct: float,
}

// 履歴ビューのフラット行（is-header=エンカウンタ見出し / false=プレイヤー行）。
// 展開はネスト配列を避け、Rust 側で展開中のみプレイヤー行を差し込む。
struct HistoryRowUi {
    is-header: bool,
    snap-id: string,
    expanded: bool,
    duration-text: string,
    dps-text: string,
    dmg-text: string,
    count-text: string,
    rank-text: string,
    name: string,
    class-color: color,
    p-dps-text: string,
    p-pct-text: string,
    p-pct: float,
}

// 自キャラUID 候補（現在のプレイヤーから）
struct UidCandidate {
    uid-str: string,
    label: string,    // "名前 #1234"
    selected: bool,
}

// 自キャラ ステータス窓の1行（Rust が整形した value を表示するだけ）。
struct StatEntryUi {
    label: string,
    value: string,
    accent: bool,    // 実測率など強調表示する項目
}

// ステータス表示項目の設定カタログ（表示ON/OFFのトグル一覧用）。
struct StatCatalogItem {
    key: string,
    label: string,
    group-head: string, // グループ先頭の項目のみ見出し文字列（それ以外は空）
    enabled: bool,
}

// 3分計測 結果パネルのプレイヤー行
struct ResultRowUi {
    rank-text: string,
    rank: int,         // 1始まり。TOP3のメダルアクセント判定に使う
    name: string,
    class-color: color,
    dps-text: string,
    dmg-text: string,
    pct-text: string,
    pct: float,        // 0..100（割合バー幅。メインDPS表と同じ雰囲気の背景バー用）
    uid-str: string,   // クリックでスキル内訳の対象に
    selected: bool,
}

// スキル内訳 円グラフの1要素（扇形 or 区切り線の SVGパス）。viewbox 100x100
// is-line=true は灰色の内向き区切り線（塗りなし・外周には届かない）。
struct PieSlice {
    commands: string,
    color: color,
    is-line: bool,
}

// スキル内訳の凡例行（円グラフのスライスと同色）。
struct SkillLegendUi {
    name: string,
    color: color,
    pct-text: string,
}

// 3分計測 結果パネル エリア2 のスキル行（クリックで折れ線の対象スキルに）。
struct ResultSkillRowUi {
    uid-str: string,
    name: string,
    elem-id: int,      // 属性 0..8（>8=無し）。ElementIcon で描画
    elem-color: color,
    dmg-text: string,
    pct-text: string,
    selected: bool,
}

// バトルイマジン名メンテ（設定パネル・全幅セクション）の1行。
// スキル名(main-skill/clone-skills)は Rust が skill_names 経由で解決した表示言語追従の文字列。
// imagine-name は Git DB(ImagineSkillNames.json) の正典名（devモードのみ編集可）、
// display-name はユーザーのローカル表示名上書き（空=未設定）。canonical はグループの識別キー
// （＝現在の imagine-name と同値。上書き/展開状態の参照キーにも使う）。
struct ImagineNameRowUi {
    canonical: string,
    imagine-name: string,
    main-skill: string,
    display-name: string,
    ignored: bool,
    has-clones: bool,
    expanded: bool,
    clone-skills: [string],
}

// アクセントカラーテーマ。設定の accent-theme プリセットに応じて Rust が起動時/変更時に set する。
// accent=文字・枠・選択ハイライト系 / accent-strong=塗りつぶし系（タブ・チェック・スライダー）。
export global Theme {
    in-out property <color> accent: #4fc3f7;
    in-out property <color> accent-strong: #2d6cdf;
}

// 設定パネルのデザイントークン（見出し階層・操作系・カードを一元化し質感を統一）。
// 散在していた #888/#ddd/#cdd/#666/#ffffff10/#ffffff12/#ffffff28/3px 等をここへ集約する。
global SettingsStyle {
    // 見出し階層（3段）: section-title（カード見出し）> sub-label（名前付き小グループ）> group-head（カタログ内の極小見出し）
    out property <color> section-title: #c2c2d6;
    out property <length> section-title-size: 11px;
    out property <color> sub-label: #9a9aae;
    out property <length> sub-label-size: 10px;
    out property <color> group-head: #76768c;
    out property <length> group-head-size: 9px;
    // 行ラベル・補足
    out property <color> row-label: #dcdce4;
    out property <length> row-label-size: 12px;
    out property <color> hint: #6f6f7e;
    out property <length> hint-size: 9px;
    // 操作系（トグル/ステッパー/セグ/入力欄の地・ホバー・角丸・行高）
    out property <color> control-bg: #ffffff14;
    out property <color> control-bg-hover: #ffffff28;
    out property <color> row-hover: #ffffff10;
    out property <length> radius: 3px;
    out property <length> row-height: 26px;
    // セクションカード
    out property <color> card-bg: #ffffff08;
    out property <color> card-border: #ffffff14;
    out property <length> card-radius: 6px;
    out property <length> card-pad: 6px;
}

// 基準テキスト色（プリセットキー→色・hex 解決）は Rust 側 resolve_overlay_text_color に集約。
// 各オーバーレイは解決済みの text-base(color) を Rust から受け取る。

// 設定セクションの見出し（左アクセント細バー＋タイトル）。階層を一目で示す。
component SectionTitle inherits HorizontalLayout {
    in property <string> title;
    spacing: 6px;
    Rectangle {
        width: 3px;
        background: Theme.accent;
        border-radius: 1.5px;
    }
    Text {
        text: root.title;
        color: SettingsStyle.section-title;
        font-size: SettingsStyle.section-title-size;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-stretch: 1;
    }
}

// 設定セクションのカード枠（薄い背景＋枠＋見出し＋本体）。本体は @children を流し込む。
// 各 Section コンポーネントはこれを継承し、見出しは title プロパティ、内容は子要素で渡す。
component SectionCard inherits Rectangle {
    in property <string> title;
    background: SettingsStyle.card-bg;
    border-width: 1px;
    border-color: SettingsStyle.card-border;
    border-radius: SettingsStyle.card-radius;
    VerticalLayout {
        padding: SettingsStyle.card-pad;
        spacing: 2px;
        SectionTitle { title: root.title; }
        @children
    }
}

component TabButton inherits TouchArea {
    in property <string> label;
    in property <bool> active;
    Rectangle {
        background: root.active ? Theme.accent-strong.with-alpha(0.4) : (root.has-hover ? #ffffff14 : transparent);
        animate background { duration: 100ms; easing: ease-out; }
        border-radius: 4px;
        HorizontalLayout {
            padding-left: 9px;
            padding-right: 9px;
            Text {
                text: root.label;
                color: root.active ? white : #b8b8c8;
                font-size: 12px;
                vertical-alignment: center;
            }
        }
    }
}

// 狭幅ヘッダ用アイコン（viewbox 16x16 の SVG パスコマンド）。
// 絵文字/Dingbats はフォント欠落環境があるため Path 描画で持つ。
global HeaderIcons {
    // 停止（縦2本・塗り。小サイズで潰れないよう隙間を広めに取る）
    out property <string> pause: "M 3.5 3 H 6.5 V 13 H 3.5 Z M 9.5 3 H 12.5 V 13 H 9.5 Z";
    // 再開（再生三角・塗り）
    out property <string> play: "M 5 3 L 13 8 L 5 13 Z";
    // 初期化（円弧矢印・線）
    out property <string> reset: "M 13.5 8 A 5.5 5.5 0 1 1 9.42 2.69 M 6.9 3.6 L 9.42 2.69 L 7.7 0.7";
    // 計測（ストップウォッチ・線）
    out property <string> stopwatch: "M 3.5 9.5 A 4.5 4.5 0 1 1 12.5 9.5 A 4.5 4.5 0 1 1 3.5 9.5 M 8 9.5 L 10.3 7.2 M 8 5 V 3.2 M 6.4 2.8 H 9.6";
    // コピー（重ね四角・線）
    out property <string> copy: "M 5.5 5 H 13.5 V 14 H 5.5 Z M 5.5 11 H 2.5 V 2 H 10.5 V 5";
    // コピー済（チェック・線）
    out property <string> check: "M 3 8.5 L 6.5 12 L 13 3.5";
    // 設定（スライダー2本・線。ノブは縦ティックで表現＝丸ノブは小サイズで矢印に潰れるため）
    out property <string> settings: "M 2 5 H 14 M 10 2.8 V 7.2 M 2 11 H 14 M 6 8.8 V 13.2";
    // 最前面ピン（画鋲・塗り。頭バー＋胴＋台座＋針のシルエット）
    out property <string> pin: "M 4.5 1.8 H 11.5 V 3.2 H 4.5 Z M 6 3.2 H 10 L 10.7 7 H 5.3 Z M 3.8 7 H 12.2 V 8.6 H 3.8 Z M 7.45 8.6 H 8.55 V 13.6 H 7.45 Z";
}

// 属性アイコン（viewbox 24 の SVG パス）。漢字 1 字に依存せず全言語共通の絵で属性を示す。
// 絵文字/フォント依存を避けるため Path で自前描画（HeaderIcons と同方針）。
global ElementIcons {
    out property <string> phys: "M12 1.5 L13.4 3.2 L13.4 13 L10.6 13 L10.6 3.2 Z M8 13 L16 13 L16 15.2 L8 15.2 Z M10.8 15.2 L13.2 15.2 L13.2 19.5 L10.8 19.5 Z M10 19.5 L14 19.5 L14 21.5 L10 21.5 Z";       // 物理: 剣
    out property <string> fire: "M12 2 C 14 6.5 17 8.5 16 13 A 4 4 0 1 1 8 13 C 7.8 10.5 9.5 9.5 10 11.5 C 10.2 7.5 10.5 4.8 12 2 Z";                                                              // 炎: 炎
    out property <string> ice: "M12 2.5 V21.5 M4 7.25 L20 16.75 M20 7.25 L4 16.75 M9.8 4.7 L12 2.5 L14.2 4.7 M9.8 19.3 L12 21.5 L14.2 19.3";                                                     // 氷: 雪片
    out property <string> thunder: "M13.5 2 L6 13 L10.5 13 L9 22 L18 9 L13 9 Z";                                                                                                                 // 雷: 稲妻
    out property <string> wood: "M12 3 C 6 8 6 16 12 21 C 18 16 18 8 12 3 Z M12 5 V19.5";                                                                                                        // 森: 葉（輪郭＋葉脈・stroke）
    out property <string> wind: "M3 8 H13.5 A 2.6 2.6 0 1 0 11 5.4 M3 12.5 H17 A 2.6 2.6 0 1 1 14.5 15.1 M3 17 H10";                                                                             // 風: 風紋
    out property <string> rock: "M2 20.5 L8 9 L12 15.5 L15 10 L22 20.5 Z";                                                                                                                       // 岩: 山
    out property <string> light: "M8.4 12 A 3.6 3.6 0 1 1 15.6 12 A 3.6 3.6 0 1 1 8.4 12 M12 1.8 V4.4 M12 19.6 V22.2 M1.8 12 H4.4 M19.6 12 H22.2 M4.9 4.9 L6.7 6.7 M17.3 17.3 L19.1 19.1 M19.1 4.9 L17.3 6.7 M6.7 17.3 L4.9 19.1"; // 光: 太陽
    out property <string> dark: "M16.8 3.5 A 8.7 8.7 0 1 0 16.8 20.5 A 6.6 6.6 0 1 1 16.8 3.5 Z";                                                                                                // 闇: 三日月
}

component ElementGlyphFill inherits Path {
    in property <color> tint;
    width: 100%;
    height: 100%;
    viewbox-width: 24;
    viewbox-height: 24;
    fill: root.tint;
}

component ElementGlyphStroke inherits Path {
    in property <color> tint;
    width: 100%;
    height: 100%;
    viewbox-width: 24;
    viewbox-height: 24;
    stroke: root.tint;
    stroke-width: 1.8px;
    fill: transparent;
}

// 属性 0..8 を Path アイコンで描画（>8 は空＝従来の "-" 相当）。tint は属性色。
component ElementIcon inherits Rectangle {
    in property <int> id;
    in property <color> tint;
    in property <length> box: 14px;
    width: root.box;
    height: root.box;
    if root.id == 0: ElementGlyphFill { commands: ElementIcons.phys; tint: root.tint; }
    if root.id == 1: ElementGlyphFill { commands: ElementIcons.fire; tint: root.tint; }
    if root.id == 2: ElementGlyphStroke { commands: ElementIcons.ice; tint: root.tint; }
    if root.id == 3: ElementGlyphFill { commands: ElementIcons.thunder; tint: root.tint; }
    if root.id == 4: ElementGlyphStroke { commands: ElementIcons.wood; tint: root.tint; }
    if root.id == 5: ElementGlyphStroke { commands: ElementIcons.wind; tint: root.tint; }
    if root.id == 6: ElementGlyphFill { commands: ElementIcons.rock; tint: root.tint; }
    if root.id == 7: ElementGlyphStroke { commands: ElementIcons.light; tint: root.tint; }
    if root.id == 8: ElementGlyphFill { commands: ElementIcons.dark; tint: root.tint; }
}

// ヘッダの機能ボタン。狭幅時（show-icon）はテキストの代わりに Path アイコンを表示する。
component HeaderButton inherits TouchArea {
    in property <string> label;
    in property <string> icon-commands; // HeaderIcons の viewbox 16x16 パス
    in property <bool> show-icon;
    in property <bool> active;
    in property <bool> icon-fill: false; // true=塗り、false=線
    in property <color> active-bg: #8a5d12aa;
    in property <color> active-fg: #ffd54f;
    property <color> fg: root.active ? root.active-fg : #cdd;
    Rectangle {
        background: root.active ? root.active-bg : (root.has-hover ? #ffffff20 : transparent);
        animate background { duration: 100ms; easing: ease-out; }
        border-radius: 4px;
        if root.show-icon: Path {
            width: 13px;
            height: 13px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            viewbox-width: 16;
            viewbox-height: 16;
            commands: root.icon-commands;
            stroke: root.icon-fill ? transparent : root.fg;
            stroke-width: root.icon-fill ? 0px : 1.6px;
            fill: root.icon-fill ? root.fg : transparent;
        }
        if !root.show-icon: Text {
            text: root.label;
            color: root.fg;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// 設定パネルのセグメントボタン（起動タブ選択など）。
// fill=true で固定50px幅を解除し、行内で均等に伸縮（狭い列でもはみ出さない）。
component SegButton inherits TouchArea {
    in property <string> label;
    in property <bool> active;
    in property <bool> fill: false;
    height: 22px;
    min-width: root.fill ? 44px : 50px;
    max-width: root.fill ? 100000px : 50px;
    horizontal-stretch: root.fill ? 1 : 0;
    Rectangle {
        background: root.active ? Theme.accent-strong : (root.has-hover ? SettingsStyle.control-bg-hover : SettingsStyle.control-bg);
        animate background { duration: 100ms; easing: ease-out; }
        border-radius: SettingsStyle.radius;
        Text { text: root.label; color: root.active ? white : #bbb; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
    }
}

// 食事/シロップ バフのタイマーアイコン。アイコン自体の色が残量に応じて上から
// 縦に抜けていく（縦型プログレスバー・使用中=色付き / 未使用=グレー半透明）。
component ConsumableBadge inherits Rectangle {
    in property <bool> active;
    in property <float> remaining;  // 残量割合 0..1（1=満タン, 0=切れ）
    in property <string> icon;      // SVGパス commands（viewbox 24）
    in property <color> tint;       // 使用中の色
    in property <string> tip-time;  // ホバー: 残り時間（例 45s）
    in property <string> tip-label; // ホバー: 種類ラベル（例 物攻 +15。空=非表示）
    in property <float> font-scale: 1.0;
    callback clicked();
    property <float> elapsed: 1.0 - root.remaining;  // 経過割合（上から色が消える境界）
    // アイコン径＝メインのフォントサイズ（font_size = 12px*font_scale）に一致
    width: 12px * root.font-scale;
    height: self.width;
    Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 24;
        viewbox-height: 24;
        commands: root.icon;
        // 上[0..経過]=グレー半透明、下[経過..1]=色。残量が減ると色が上から下へ抜ける。
        fill: root.active
            ? @linear-gradient(180deg, #8a8f9980 0%, #8a8f9980 root.elapsed * 100%, root.tint root.elapsed * 100%, root.tint 100%)
            : #8a8f9980;
    }
    // ホバーで残り時間＋種類をアイコンの下に表示。PopupWindow=最前面・行にクリップ
    // されないため最上段でも見切れない。ポップはアイコンの下に出すので hover を奪わない。
    ta := TouchArea {
        // アイコン(約12px)はホバー判定が狭く、少しのカーソルずれで tip が消えて
        // ちらつく。行高さいっぱい＋左右に余白を取った判定に広げて安定させる。
        // 行クリックは下層の rowta が拾えなくなるため clicked を転送して維持する。
        width: root.width + 10px;
        height: 20px * root.font-scale;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        changed has-hover => {
            if (self.has-hover && root.active) {
                tip.show();
            } else {
                tip.close();
            }
        }
        clicked => { root.clicked(); }
    }
    tip := PopupWindow {
        x: 0;
        y: root.height + 3px;
        Rectangle {
            width: tipcol.preferred-width;
            height: tipcol.preferred-height;
            background: #11131af2;
            border-radius: 4px;
            border-width: 1px;
            border-color: #ffffff26;
            tipcol := VerticalLayout {
                padding-left: 7px;
                padding-right: 7px;
                padding-top: 4px;
                padding-bottom: 4px;
                spacing: 1px;
                Text {
                    text: @tr("残り {}", root.tip-time);
                    color: #e6e6f0;
                    font-size: 11px * root.font-scale;
                }
                if root.tip-label != "": Text {
                    text: root.tip-label;
                    color: root.tint;
                    font-size: 10px * root.font-scale;
                }
            }
        }
    }
}

component PlayerRowItem inherits Rectangle {
    in property <Row> entry;
    in property <bool> highlight-local;
    in property <ColumnFlags> cols;
    in property <float> font-scale: 1.0;
    in property <bool> show-graph-col;
    in property <bool> show-consumable: true;
    in property <bool> sync-timer; // イマジンタイマー同期ON/OFF（ウォッチボタンのツールチップ文言切替に使う）
    callback activate(string);
    callback toggle-watch(string);
    height: 20px * root.font-scale;
    background: rowta.has-hover ? #ffffff12 : transparent;
    animate background { duration: 100ms; easing: ease-out; }

    // 行クリック（背面）。ウォッチピン等の TouchArea が前面で個別に捕捉する。
    rowta := TouchArea {
        clicked => { root.activate(root.entry.uid-str); }
    }

    // 割合バー（クラス色グラデーション）
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.entry.pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, root.entry.class-color.with-alpha(0.22) 0%, transparent 100%);
    }

    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 5px;
            Rectangle {
                width: 3px;
                background: root.entry.class-color;
                border-radius: 1px;
            }
            Text {
                text: root.entry.name;
                color: white;
                font-size: 12px * root.font-scale;
                overflow: elide;
                vertical-alignment: center;
                horizontal-stretch: 1;
                min-width: 90px * root.font-scale;
            }
            // 食事/シロップ バフのタイマーアイコン（残量に応じて色が上から縦に抜ける・ホバーで詳細）
            if root.show-consumable: VerticalLayout { alignment: center; ConsumableBadge {
                active: root.entry.food-active;
                remaining: root.entry.food-remaining;
                tint: #66bb6a;
                tip-time: root.entry.food-time;
                tip-label: root.entry.food-label;
                font-scale: root.font-scale;
                icon: "M8.1 13.34l2.83-2.83L3.91 3.5c-1.56 1.56-1.56 4.09 0 5.66l4.19 4.18zm6.78-1.81c1.53.71 3.68.21 5.27-1.38 1.91-1.91 2.28-4.65.81-6.12-1.46-1.46-4.2-1.1-6.12.81-1.59 1.59-2.09 3.74-1.38 5.27L3.7 19.87l1.41 1.41L12 14.41l6.88 6.88 1.41-1.41L13.41 13l1.47-1.47z";
                clicked => { root.activate(root.entry.uid-str); }
            } }
            if root.show-consumable: VerticalLayout { alignment: center; ConsumableBadge {
                active: root.entry.syrup-active;
                remaining: root.entry.syrup-remaining;
                tint: #b07cff;
                tip-time: root.entry.syrup-time;
                tip-label: root.entry.syrup-label;
                font-scale: root.font-scale;
                icon: "M19.8 18.4L14 10.67V6.5l1.35-1.69c.26-.33.03-.81-.39-.81H9.04c-.42 0-.65.48-.39.81L10 6.5v4.17L4.2 18.4c-.49.66-.02 1.6.8 1.6h14c.82 0 1.29-.94.8-1.6z";
                clicked => { root.activate(root.entry.uid-str); }
            } }
        }
        if root.show-graph-col: Rectangle {
            width: 60px;
            // 対象行のみ折れ線を描く（非対象は空セルで列を揃える）
            Path {
                x: 2px;
                width: 56px;
                height: 14px;
                viewbox-x: 0;
                viewbox-y: 0;
                viewbox-width: 100;
                viewbox-height: 16;
                commands: root.entry.spark-commands;
                stroke: root.entry.class-color;
                stroke-width: 1.2px;
                fill: transparent;
            }
        }
        Text { text: root.entry.dmg-text; color: #e6e6f0; font-size: 12px * root.font-scale; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.dps-text; color: Theme.accent; font-size: 12px * root.font-scale; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.pct-text; color: #cfcfe0; font-size: 11px * root.font-scale; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.crit: Text { text: root.entry.crit-text; color: #f39c12; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.crit-value: Text { text: root.entry.crit-value-text; color: #f39c12; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.lucky: Text { text: root.entry.lucky-text; color: #2ecc71; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.lucky-value: Text { text: root.entry.lucky-value-text; color: #2ecc71; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.hits: Text { text: root.entry.hits-text; color: #cfcfe0; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.hpm: Text { text: root.entry.hpm-text; color: #cfcfe0; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.score: Text { text: root.entry.score-text; color: #99aa99; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        watch := TouchArea {
            width: 14px;
            clicked => { root.toggle-watch(root.entry.uid-str); }
            changed has-hover => {
                if (self.has-hover) {
                    watch-tip.show();
                } else {
                    watch-tip.close();
                }
            }
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 9px;
                height: 9px;
                border-radius: 4.5px;
                border-width: 1px;
                border-color: root.entry.watched ? Theme.accent : (watch.has-hover ? #888888 : #ffffff00);
                background: root.entry.watched ? Theme.accent : transparent;
                animate background, border-color { duration: 100ms; easing: ease-out; }
            }
            // ホバーで操作内容を説明（同期ON/OFFで意味が変わるため文言を切替）。
            watch-tip := PopupWindow {
                x: 0;
                y: watch.height + 3px;
                Rectangle {
                    width: watch-tip-text.preferred-width + 14px;
                    height: watch-tip-text.preferred-height + 8px;
                    background: #11131af2;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: #ffffff26;
                    watch-tip-text := Text {
                        x: 7px;
                        y: 4px;
                        text: root.sync-timer
                            ? @tr("タイマーから隠す/表示")
                            : @tr("ウォッチに追加/削除");
                        color: #e6e6f0;
                        font-size: 11px * root.font-scale;
                    }
                }
            }
        }
    }

    // 自キャラ マーカー: クラス色バー左の左余白に〉を描画（行塗りつぶしの代替）。
    // フォント依存を避けるため Path で描く。font-scale に追従。
    if (root.entry.is-local && root.highlight-local): Path {
        x: 1px;
        y: (parent.height - self.height) / 2;
        width: 5px * root.font-scale;
        height: 9px * root.font-scale;
        viewbox-width: 5;
        viewbox-height: 9;
        commands: "M 1 1 L 4 4.5 L 1 8";
        stroke: #ffd700;
        stroke-width: 1.4px;
        fill: transparent;
    }
}

// 軽量分割表示の行（名前＋ダメージ＋DPSのみ。グラフ/ピン無し）
component CompactRowItem inherits Rectangle {
    in property <Row> entry;
    in property <bool> highlight-local;
    in property <float> font-scale: 1.0;
    callback activate(string);
    height: 18px;
    background: cta.has-hover ? #ffffff12 : transparent;
    animate background { duration: 100ms; easing: ease-out; }
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.entry.pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, root.entry.class-color.with-alpha(0.18) 0%, transparent 100%);
    }
    cta := TouchArea {
        clicked => { root.activate(root.entry.uid-str); }
    }
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 5px;
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            Rectangle { width: 2px; background: root.entry.class-color; border-radius: 1px; }
            Text { text: root.entry.name; color: white; font-size: 11px * root.font-scale; overflow: elide; horizontal-stretch: 1; vertical-alignment: center; }
        }
        Text { text: root.entry.dmg-text; color: #e6e6f0; font-size: 11px * root.font-scale; width: 56px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.dps-text; color: Theme.accent; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
    }

    // 自キャラ マーカー（RowItem と同様。クラス色バー左の左余白に〉）。
    if (root.entry.is-local && root.highlight-local): Path {
        x: 0.5px;
        y: (parent.height - self.height) / 2;
        width: 4.5px * root.font-scale;
        height: 8px * root.font-scale;
        viewbox-width: 5;
        viewbox-height: 9;
        commands: "M 1 1 L 4 4.5 L 1 8";
        stroke: #ffd700;
        stroke-width: 1.4px;
        fill: transparent;
    }
}

component SkillRowItem inherits Rectangle {
    in property <SkillRowUi> entry;
    in property <bool> clickable;
    in property <float> font-scale: 1.0;
    callback activate(string);
    height: 20px;
    background: (root.clickable && ta.has-hover) ? #ffffff12 : transparent;
    animate background { duration: 100ms; easing: ease-out; }

    // プレイヤー一覧と同じ雰囲気の割合バー。elem-color は element=0(物理・被ダメ攻撃元一覧)で
    // 淡いグレーになり背景にほぼ埋もれるため、アクセント色で統一して視認性を確保する
    // （要素ごとの色分けは左のElementIconが担うのでバー自体は識別色を持たせなくてよい）。
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.entry.pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, Theme.accent.with-alpha(0.20) 0%, transparent 100%);
    }
    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            VerticalLayout { alignment: center; ElementIcon { id: root.entry.elem-id; tint: root.entry.elem-color; box: 14px * root.font-scale; } }
            Text { text: root.entry.name; color: white; font-size: 12px * root.font-scale; overflow: elide; vertical-alignment: center; horizontal-stretch: 1; }
        }
        Text { text: root.entry.total-text; color: #e6e6f0; font-size: 12px * root.font-scale; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.dps-text; color: Theme.accent; font-size: 12px * root.font-scale; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.pct-text; color: #cfcfe0; font-size: 11px * root.font-scale; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
    }
    ta := TouchArea {
        enabled: root.clickable;
        mouse-cursor: root.clickable ? pointer : default;
        clicked => { root.activate(root.entry.uid-str); }
    }
}

// 履歴の行（見出し or プレイヤー）。見出しはクリックで展開トグル。
component HistoryRowItem inherits Rectangle {
    in property <HistoryRowUi> e;
    in property <float> font-scale: 1.0;
    callback toggle(string);
    height: root.e.is-header ? 24px : 18px;
    background: (root.e.is-header && hta.has-hover) ? #ffffff14 : (root.e.is-header ? #ffffff08 : transparent);
    animate background { duration: 100ms; easing: ease-out; }

    // プレイヤー行の割合バー
    if !root.e.is-header: Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.e.p-pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, root.e.class-color.with-alpha(0.18) 0%, transparent 100%);
    }
    // 見出しのみクリック可（プレイヤー行では enabled:false で無反応）
    hta := TouchArea {
        enabled: root.e.is-header;
        mouse-cursor: root.e.is-header ? pointer : default;
        clicked => { root.toggle(root.e.snap-id); }
    }
    HorizontalLayout {
        padding-left: root.e.is-header ? 8px : 18px;
        padding-right: 8px;
        spacing: 8px;
        // ── 見出し ──
        if root.e.is-header: Text { text: root.e.duration-text; color: #888; font-size: 10px * root.font-scale; width: 40px; vertical-alignment: center; }
        if root.e.is-header: Text { text: root.e.dps-text + " DPS"; color: Theme.accent; font-size: 11px * root.font-scale; width: 90px; vertical-alignment: center; }
        if root.e.is-header: Text { text: root.e.dmg-text; color: #aaa; font-size: 10px * root.font-scale; width: 60px; vertical-alignment: center; }
        if root.e.is-header: Text { text: root.e.count-text + @tr("人"); color: #666; font-size: 10px * root.font-scale; horizontal-stretch: 1; vertical-alignment: center; }
        if root.e.is-header: Text { text: root.e.expanded ? "▲" : "▼"; color: #555; font-size: 9px * root.font-scale; vertical-alignment: center; }
        // ── プレイヤー行 ──
        if !root.e.is-header: Text { text: root.e.rank-text; color: #555; font-size: 10px * root.font-scale; width: 18px; vertical-alignment: center; }
        if !root.e.is-header: Text { text: root.e.name; color: root.e.class-color; font-size: 11px * root.font-scale; overflow: elide; horizontal-stretch: 1; vertical-alignment: center; }
        if !root.e.is-header: Text { text: root.e.p-dps-text; color: Theme.accent; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if !root.e.is-header: Text { text: root.e.p-pct-text; color: #aaa; font-size: 10px * root.font-scale; width: 40px; horizontal-alignment: right; vertical-alignment: center; }
    }
}

// 3分計測 結果パネルの行（クリックでスキル内訳の対象に）
component ResultRow inherits Rectangle {
    in property <ResultRowUi> e;
    callback activate(string);
    // TOP3 は控えめなメダルカラー（金/銀/銅）。4位以下は従来通り。
    property <color> medal-color: root.e.rank == 1 ? #e8c35a : (root.e.rank == 2 ? #c0c8d4 : (root.e.rank == 3 ? #c9a06e : transparent));
    height: 18px;
    background: root.e.selected ? Theme.accent.with-alpha(0.18) : (rta.has-hover ? #ffffff18 : #ffffff0a);
    animate background, border-color { duration: 100ms; easing: ease-out; }
    border-width: 1px;
    border-color: root.e.selected ? Theme.accent.with-alpha(0.667) : #ffffff00;
    border-radius: 2px;
    rta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.activate(root.e.uid-str); }
    }
    // 割合バー（メインDPS表と同じ雰囲気の半透明グラデーション）
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.e.pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, root.e.class-color.with-alpha(0.22) 0%, transparent 100%);
    }
    // TOP3 の左アクセント（細いメダルカラーの縦線）
    if root.e.rank <= 3: Rectangle {
        x: 0;
        y: 0;
        width: 2px;
        height: 100%;
        background: root.medal-color;
    }
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 8px;
        Text { text: root.e.rank-text; color: root.e.rank <= 3 ? root.medal-color : #666; width: 18px; font-size: 10px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.e.name; color: root.e.class-color; font-size: 11px; horizontal-stretch: 1; overflow: elide; vertical-alignment: center; }
        Text { text: root.e.dps-text; color: Theme.accent; font-size: 10px; width: 56px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.e.dmg-text; color: #aaa; font-size: 10px; width: 60px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.e.pct-text; color: #777; font-size: 10px; width: 40px; horizontal-alignment: right; vertical-alignment: center; }
    }
}

// 3分計測 結果パネル エリア2 のスキル行（クリックで折れ線の対象スキルに）
component ResultSkillRow inherits Rectangle {
    in property <ResultSkillRowUi> e;
    callback activate(string);
    height: 18px;
    background: root.e.selected ? Theme.accent.with-alpha(0.18) : (rsta.has-hover ? #ffffff18 : #ffffff0a);
    animate background, border-color { duration: 100ms; easing: ease-out; }
    border-width: 1px;
    border-color: root.e.selected ? Theme.accent.with-alpha(0.667) : #ffffff00;
    border-radius: 2px;
    rsta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.activate(root.e.uid-str); }
    }
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 6px;
        VerticalLayout { alignment: center; width: 14px; ElementIcon { id: root.e.elem-id; tint: root.e.elem-color; box: 13px; } }
        Text { text: root.e.name; color: white; font-size: 11px; horizontal-stretch: 1; overflow: elide; vertical-alignment: center; }
        Text { text: root.e.dmg-text; color: #e6e6f0; font-size: 10px; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.e.pct-text; color: #777; font-size: 10px; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
    }
}

// 3分計測 結果パネル: 自己ベスト更新時の「新記録！」バッジ。
// Slint に scale 変形が無いため、font-size/padding を anim(0..1) から導出して
// 「小さい状態→自然サイズ」に見えるポップ演出＋フェードで代替する（出現時に一度だけ）。
component NewRecordBadge inherits Rectangle {
    property <bool> popped: false;
    property <float> anim: root.popped ? 1.0 : 0.0;
    animate anim { duration: 250ms; easing: ease-out; }
    init => { root.popped = true; }
    opacity: root.anim;
    background: #e8c35a2b;
    border-width: 1px;
    border-color: #e8c35a;
    border-radius: 4px;
    HorizontalLayout {
        padding-left: 4px + (1.0 - root.anim) * 4px;
        padding-right: 4px + (1.0 - root.anim) * 4px;
        padding-top: 2px;
        padding-bottom: 2px;
        Text {
            text: @tr("新記録！");
            color: #e8c35a;
            font-size: 9px + 2px * root.anim;
            vertical-alignment: center;
        }
    }
}

// 折れ線グラフ＋左Y軸目安(上=最大/中=半分/下=0)＋時間X軸(区切り本数は横幅で可変)＋グリッド線。
component SparkGraph inherits VerticalLayout {
    in property <bool> visible-graph;
    // パスコマンド（M/L）。座標は viewbox=プロット実寸(px) に一致させた「ピクセル座標」。
    // Slint の Path は viewbox を縦横比保持でスケールするため、viewbox を要素実寸に合わせ、
    // パスも実寸座標で渡すことで等倍描画（X全幅・Y軸グリッド整合）にする。実寸が変わると
    // パスを作り直す必要があるため resized で通知する。
    in property <string> commands;
    in property <color> line-color;
    in property <string> axis-top;
    in property <string> axis-mid;
    in property <string> empty-text;
    in property <float> duration-ms;                 // X軸の総時間（ms）
    // プロット実寸(px)が変わったら通知（呼び出し側がこの寸法でパスを再生成する）。
    callback resized(float /* width-px */, float /* height-px */);
    // X軸の区切り本数（横幅で可変。約80pxごとに1区切り、2〜7本）。
    property <int> x-ticks: Math.max(2, Math.min(7, Math.floor(plot.width / 80px)));
    property <float> vbw: plot.width / 1px;
    property <float> vbh: plot.height / 1px;
    spacing: 2px;

    // 主行: 左Y軸 ＋ グラフ
    HorizontalLayout {
        vertical-stretch: 1;
        spacing: 4px;
        VerticalLayout {
            width: 42px;
            Text { text: root.axis-top; color: #777; font-size: 8px; horizontal-alignment: right; }
            Rectangle { vertical-stretch: 1; }
            Text { text: root.axis-mid; color: #777; font-size: 8px; horizontal-alignment: right; }
            Rectangle { vertical-stretch: 1; }
            Text { text: "0"; color: #777; font-size: 8px; horizontal-alignment: right; }
        }
        plot := Rectangle {
            horizontal-stretch: 1;
            clip: true;
            changed width => { root.resized(self.width / 1px, self.height / 1px); }
            changed height => { root.resized(self.width / 1px, self.height / 1px); }
            // 横グリッド（上/中/下）
            Rectangle { y: 0; width: 100%; height: 1px; background: #ffffff14; }
            Rectangle { y: parent.height / 2; width: 100%; height: 1px; background: #ffffff10; }
            Rectangle { y: parent.height - 1px; width: 100%; height: 1px; background: #ffffff14; }
            // 縦グリッド（時間区切り・本数は横幅で可変）
            for i in root.x-ticks: Rectangle {
                property <float> f: root.x-ticks > 1 ? (i * 1.0) / (root.x-ticks - 1) : 0;
                x: plot.width * self.f;
                y: 0;
                width: 1px;
                height: 100%;
                background: #ffffff0c;
            }
            if root.visible-graph: Path {
                width: 100%;
                height: 100%;
                viewbox-x: 0;
                viewbox-y: 0;
                viewbox-width: root.vbw;
                viewbox-height: root.vbh;
                commands: root.commands;
                stroke: root.line-color;
                stroke-width: 1px;
                fill: transparent;
            }
            if !root.visible-graph: Text { text: root.empty-text; color: #555; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
        }
    }
    // X軸: 時間ラベル（M:SS）。区切り位置に合わせて配置。
    HorizontalLayout {
        height: 11px;
        spacing: 4px;
        Rectangle { width: 42px; }   // Y軸列ぶんのスペーサ
        xaxis := Rectangle {
            horizontal-stretch: 1;
            for i in root.x-ticks: Text {
                property <float> f: root.x-ticks > 1 ? (i * 1.0) / (root.x-ticks - 1) : 0;
                property <int> sec: Math.round(root.duration-ms / 1000 * self.f);
                property <int> mins: Math.floor(self.sec / 60);
                property <int> rem: self.sec - self.mins * 60;
                property <string> rem-str: self.rem < 10 ? "0\{self.rem}" : "\{self.rem}";
                x: Math.max(0px, Math.min(xaxis.width - self.width, xaxis.width * self.f - self.width / 2));
                color: #777;
                font-size: 8px;
                text: "\{self.mins}:\{self.rem-str}";
            }
        }
    }
}

// 自キャラUID 候補チップ
component CandidateChip inherits TouchArea {
    in property <UidCandidate> c;
    callback pick(string);
    height: 20px;
    clicked => { root.pick(root.c.uid-str); }
    Rectangle {
        background: root.c.selected ? Theme.accent.with-alpha(0.2) : (root.has-hover ? #ffffff20 : #ffffff10);
        animate background, border-color { duration: 100ms; easing: ease-out; }
        border-width: 1px;
        border-color: root.c.selected ? Theme.accent : #ffffff26;
        border-radius: 3px;
        HorizontalLayout {
            padding-left: 6px;
            padding-right: 6px;
            Text { text: root.c.label; color: root.c.selected ? Theme.accent : #bbb; font-size: 10px; vertical-alignment: center; }
        }
    }
}

// HSV カラーピッカー（彩度/明度の正方形フィールド＋右の縦 色相スライダー）。状態は持たず、表示は
// h/s/v(各 0..1)入力から描き、操作時は pick(h,s,v) を即コールバック（不透明度スライダーと同じ round-trip）。
// 色相 h は 0..1 で持ち、hsv() へ渡すときに ×360（度）する。
component HsvPicker inherits HorizontalLayout {
    in property <float> h;
    in property <float> s;
    in property <float> v;
    callback pick(float, float, float);
    callback dragging-changed(bool);
    // SV/色相いずれかをドラッグ中か（押下中=true）。親 Flickable のスクロール奪取抑止に使う。
    property <bool> dragging: sv-ta.pressed || hue-ta.pressed;
    changed dragging => { root.dragging-changed(self.dragging); }
    spacing: 6px;
    // 彩度(x→右で高) / 明度(y→上で高) のフィールド。列幅いっぱいに伸ばす（右余白を出さない）。
    // 背景＝純色相、白横グラデで彩度、黒縦グラデで明度。
    Rectangle {
        horizontal-stretch: 1;
        height: 96px;
        border-radius: 4px;
        border-width: 1px;
        border-color: #ffffff20;
        clip: true;
        background: hsv(root.h * 360, 1, 1);
        Rectangle { width: 100%; height: 100%; background: @linear-gradient(90deg, #ffffff 0%, #ffffff00 100%); }
        Rectangle { width: 100%; height: 100%; background: @linear-gradient(180deg, #00000000 0%, #000000 100%); }
        // 選択カーソル（暗縁＋白リングで任意背景に視認可）
        Rectangle {
            x: root.s * parent.width - self.width / 2;
            y: (1.0 - root.v) * parent.height - self.height / 2;
            width: 14px;
            height: 14px;
            border-radius: 7px;
            background: transparent;
            border-width: 3px;
            border-color: #00000066;
            Rectangle {
                x: 2px;
                y: 2px;
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: transparent;
                border-width: 2px;
                border-color: #ffffff;
            }
        }
        sv-ta := TouchArea {
            moved => { root.pick(root.h, (self.mouse-x / self.width).clamp(0.0, 1.0), (1.0 - self.mouse-y / self.height).clamp(0.0, 1.0)); }
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) {
                    root.pick(root.h, (self.mouse-x / self.width).clamp(0.0, 1.0), (1.0 - self.mouse-y / self.height).clamp(0.0, 1.0));
                }
            }
        }
    }
    // 縦 色相スライダー（上=0 → 下=1。border-radius で角丸・clip 無しでマーカーを欠けさせない）
    Rectangle {
        width: 16px;
        height: 96px;
        border-radius: 8px;
        background: @linear-gradient(180deg, #ff0000 0%, #ffff00 16.66%, #00ff00 33.33%, #00ffff 50%, #0000ff 66.66%, #ff00ff 83.33%, #ff0000 100%);
        // 横マーカー（バーをまたぐ白線＋暗縁）
        Rectangle {
            x: -2px;
            y: root.h * (parent.height - self.height);
            width: parent.width + 4px;
            height: 4px;
            border-radius: 2px;
            background: #ffffff;
            border-width: 1px;
            border-color: #00000088;
        }
        hue-ta := TouchArea {
            moved => { root.pick((self.mouse-y / self.height).clamp(0.0, 1.0), root.s, root.v); }
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) {
                    root.pick((self.mouse-y / self.height).clamp(0.0, 1.0), root.s, root.v);
                }
            }
        }
    }
}

// 設定パネルのトグル行（カスタムチェックボックス）
component ToggleRow inherits TouchArea {
    in property <string> label;
    in property <bool> checked;
    // 横パディング（既定 10px。2列表示など幅の狭い文脈ではラベル領域を稼ぐため小さくできる）。
    in property <length> pad-x: 10px;
    callback toggled();
    height: SettingsStyle.row-height;
    // enabled:false（依存設定で無効化されている等）のとき視覚的にグレーアウト。
    opacity: root.enabled ? 1.0 : 0.4;
    // 支援技術向け: チェックボックスとしてラベル・状態を伝える。
    accessible-role: checkbox;
    accessible-label: root.label;
    accessible-checkable: true;
    accessible-checked: root.checked;
    accessible-action-default => { root.toggled(); }
    clicked => { root.toggled(); }
    Rectangle {
        background: root.has-hover ? SettingsStyle.row-hover : transparent;
        animate background { duration: 100ms; easing: ease-out; }
        HorizontalLayout {
            padding-left: root.pad-x;
            padding-right: root.pad-x;
            spacing: 8px;
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 16px;
                    height: 16px;
                    border-width: 1px;
                    border-color: #777;
                    border-radius: SettingsStyle.radius;
                    background: root.checked ? Theme.accent-strong : transparent;
                    animate background { duration: 100ms; easing: ease-out; }
                    // チェックマークはフォント依存(✓はDingbatsで欠落環境あり)を避け Path 描画
                    if root.checked: Path {
                        width: 16px;
                        height: 16px;
                        viewbox-x: 0;
                        viewbox-y: 0;
                        viewbox-width: 16;
                        viewbox-height: 16;
                        commands: "M 3.5 8.5 L 6.5 11.5 L 12.5 4.5";
                        stroke: white;
                        stroke-width: 1.6px;
                        fill: transparent;
                    }
                }
            }
            Text { text: root.label; color: SettingsStyle.row-label; font-size: SettingsStyle.row-label-size; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
        }
    }
}

// 不透明度スライダー行
component OpacityRow inherits Rectangle {
    in property <float> value;
    callback changed(float);
    height: 30px;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;
        Text { text: @tr("不透明度"); color: SettingsStyle.row-label; font-size: SettingsStyle.row-label-size; vertical-alignment: center; width: 80px; }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            track := Rectangle {
                height: 6px;
                background: #3a3a48;
                border-radius: 3px;
                Rectangle {
                    x: 0;
                    width: parent.width * root.value;
                    height: 100%;
                    background: Theme.accent-strong;
                    border-radius: 3px;
                }
                // つまみ（現在値の視認と把持性向上。トラックより大きく中央に重ねる）
                Rectangle {
                    width: 14px;
                    height: 14px;
                    border-radius: 7px;
                    x: (parent.width - self.width) * root.value;
                    y: (parent.height - self.height) / 2;
                    background: #eaeaf2;
                    border-width: 1px;
                    border-color: #00000055;
                }
                // クリック領域は行全体(30px)へ縦に拡張し当てやすくする（トラック自体は細い 6px のまま）。
                ta := TouchArea {
                    y: (parent.height - self.height) / 2;
                    height: 30px;
                    moved => { root.changed((self.mouse-x / self.width).clamp(0.0, 1.0)); }
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) {
                            root.changed((self.mouse-x / self.width).clamp(0.0, 1.0));
                        }
                    }
                }
            }
        }
    }
}

// 数値設定の増減行（−/＋ ステッパー。表示はリアクティブ Text で双方向バインド競合を回避）
component StepperRow inherits Rectangle {
    in property <string> label;
    in property <string> value-text;
    callback dec();
    callback inc();
    height: SettingsStyle.row-height;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        Text { text: root.label; color: SettingsStyle.row-label; font-size: SettingsStyle.row-label-size; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
        dec-btn := TouchArea {
            width: 22px;
            // 長押しリピート: 押下中は400ms後から120ms間隔で連続実行。単発クリックは
            // repeat-started が立たないため clicked 側の1回のみで処理される(二重加算なし)。
            property <bool> repeat-started: false;
            clicked => { if (!dec-btn.repeat-started) { root.dec(); } }
            changed pressed => { if (self.pressed) { dec-btn.repeat-started = false; } }
            dec-repeat := Timer {
                interval: dec-btn.repeat-started ? 120ms : 400ms;
                running: dec-btn.pressed;
                triggered => { dec-btn.repeat-started = true; root.dec(); }
            }
            Rectangle {
                background: dec-btn.has-hover ? SettingsStyle.control-bg-hover : SettingsStyle.control-bg;
                animate background { duration: 100ms; easing: ease-out; }
                border-radius: SettingsStyle.radius;
                Text { text: "-"; color: white; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
        Text { text: root.value-text; color: #cdd; font-size: SettingsStyle.row-label-size; width: 44px; horizontal-alignment: center; vertical-alignment: center; }
        inc-btn := TouchArea {
            width: 22px;
            property <bool> repeat-started: false;
            clicked => { if (!inc-btn.repeat-started) { root.inc(); } }
            changed pressed => { if (self.pressed) { inc-btn.repeat-started = false; } }
            inc-repeat := Timer {
                interval: inc-btn.repeat-started ? 120ms : 400ms;
                running: inc-btn.pressed;
                triggered => { inc-btn.repeat-started = true; root.inc(); }
            }
            Rectangle {
                background: inc-btn.has-hover ? SettingsStyle.control-bg-hover : SettingsStyle.control-bg;
                animate background { duration: 100ms; easing: ease-out; }
                border-radius: SettingsStyle.radius;
                Text { text: "+"; color: white; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
}

// テンプレート編集（ラベル＋複数行テキスト入力＋リセット＋プレビュー）。
// value は Rust 側が「パネル開時／リセット時のみ」push する。編集中(edited)は
// cfg と preview のみ更新し value を再設定しない＝入力中のクロバーを防ぐ。
component TemplateField inherits VerticalLayout {
    in property <string> label;
    in property <string> value;
    in property <string> preview;
    in property <string> hint;
    callback changed(string);
    callback reset();
    spacing: 2px;
    padding-left: 10px;
    padding-right: 10px;
    Text { text: root.label; color: SettingsStyle.sub-label; font-size: SettingsStyle.sub-label-size; }
    HorizontalLayout {
        spacing: 4px;
        Rectangle {
            horizontal-stretch: 1;
            height: 34px;
            background: SettingsStyle.control-bg;
            border-width: 1px;
            border-color: ti.has-focus ? Theme.accent : #ffffff26;
            border-radius: SettingsStyle.radius;
            ti := TextInput {
                x: 5px;
                width: parent.width - 10px;
                height: 100%;
                vertical-alignment: center;
                wrap: word-wrap;
                single-line: false;
                color: #ddd;
                font-size: 11px;
                text: root.value;
                edited => { root.changed(self.text); }
            }
        }
        reset-btn := TouchArea {
            width: 44px;
            clicked => { root.reset(); }
            Rectangle {
                background: reset-btn.has-hover ? SettingsStyle.control-bg-hover : SettingsStyle.control-bg;
                animate background { duration: 100ms; easing: ease-out; }
                border-radius: SettingsStyle.radius;
                Text { text: @tr("リセット"); color: #cdd; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
    if root.hint != "": Text { text: root.hint; color: SettingsStyle.hint; font-size: SettingsStyle.hint-size; wrap: word-wrap; }
    Text { text: root.preview; color: #cfcfe0; font-size: 10px; wrap: word-wrap; }
}

// ── 設定パネルのセクション群（レスポンシブ多列レイアウトの単位）──
// 各セクションは VerticalLayout を継承し、必要な構造体/コールバックのみを公開する。
// MainWindow 側で最大3カラムへ振り分け、同じ定義を列ごとに条件配置する。

// キャラクター（自キャラUID入力・解決名・候補チップ・ヒント）
component CharacterSection inherits SectionCard {
    in property <string> uid-value;
    in property <string> uid-name;
    in property <[UidCandidate]> candidates;
    callback set-uid(string); // 空文字=クリア
    title: @tr("キャラクター");
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        height: 28px;
        Text { text: @tr("自キャラUID"); color: SettingsStyle.row-label; font-size: SettingsStyle.row-label-size; vertical-alignment: center; width: 76px; }
        Rectangle {
            horizontal-stretch: 1;
            background: SettingsStyle.control-bg;
            border-width: 1px;
            border-color: uidti.has-focus ? Theme.accent : #ffffff26;
            border-radius: SettingsStyle.radius;
            uidti := TextInput {
                x: 5px;
                width: parent.width - 10px;
                height: 100%;
                vertical-alignment: center;
                color: #ddd;
                font-size: 12px;
                input-type: number;
                text: root.uid-value;
                // Enter で確定（毎キーで set すると集計リセットされるため）
                accepted => { root.set-uid(self.text); }
            }
        }
        uidclear := TouchArea {
            width: 44px;
            clicked => { root.set-uid(""); }
            Rectangle {
                background: uidclear.has-hover ? SettingsStyle.control-bg-hover : SettingsStyle.control-bg;
                animate background { duration: 100ms; easing: ease-out; }
                border-radius: SettingsStyle.radius;
                Text { text: @tr("クリア"); color: #cdd; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        Rectangle { width: 76px; }
        Text { text: root.uid-name; color: #aaa; font-size: 11px; vertical-alignment: center; overflow: elide; horizontal-stretch: 1; }
    }
    if root.candidates.length > 0: HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        height: 24px;
        Text { text: @tr("候補"); color: #777; font-size: 10px; vertical-alignment: center; width: 76px; }
        Flickable {
            horizontal-stretch: 1;
            viewport-width: candbox.preferred-width;
            candbox := HorizontalLayout {
                spacing: 4px;
                for cand in root.candidates: CandidateChip { c: cand; pick(u) => { root.set-uid(u); } }
            }
        }
    }
    Text { text: @tr("自動判定が外れた時に手動で自分を指定（Enterで確定）"); color: SettingsStyle.hint; font-size: SettingsStyle.hint-size; wrap: word-wrap; }
}

// 表示列（一覧に出す列のトグル）
component DisplayColsSection inherits SectionCard {
    in property <SettingsUi> cfg;
    callback set-bool(string, bool);
    title: @tr("表示列");
    ToggleRow { label: @tr("会心率"); checked: root.cfg.show-crit; toggled => { root.set-bool("show-crit", !root.cfg.show-crit); } }
    ToggleRow { label: @tr("会心ダメ率"); checked: root.cfg.show-crit-value; toggled => { root.set-bool("show-crit-value", !root.cfg.show-crit-value); } }
    ToggleRow { label: @tr("幸運率"); checked: root.cfg.show-lucky; toggled => { root.set-bool("show-lucky", !root.cfg.show-lucky); } }
    ToggleRow { label: @tr("幸運ダメ率"); checked: root.cfg.show-lucky-value; toggled => { root.set-bool("show-lucky-value", !root.cfg.show-lucky-value); } }
    ToggleRow { label: @tr("ヒット数"); checked: root.cfg.show-hits; toggled => { root.set-bool("show-hits", !root.cfg.show-hits); } }
    ToggleRow { label: @tr("毎分ヒット数"); checked: root.cfg.show-hpm; toggled => { root.set-bool("show-hpm", !root.cfg.show-hpm); } }
    ToggleRow { label: @tr("戦力"); checked: root.cfg.show-score; toggled => { root.set-bool("show-score", !root.cfg.show-score); } }
    ToggleRow { label: @tr("食事/シロップ"); checked: root.cfg.show-consumable; toggled => { root.set-bool("show-consumable", !root.cfg.show-consumable); } }
}

// フォント外観グループ（サイズ＋ファミリ＋太字）。メイン窓・各オーバーレイ設定で共用。
// 設定キーは呼び出し側が generic コールバック→自分のキーへマップする（窓ごとに独立）。
component FontControls inherits VerticalLayout {
    in property <string> size-text;  // フォントサイズ ステッパー表示値
    in property <string> font;       // 現在のフォントファミリ
    in property <bool> bold;
    callback bump-size(int);
    callback set-font(string);
    callback toggle-bold();
    spacing: 2px;
    StepperRow { label: @tr("フォントサイズ"); value-text: root.size-text; dec => { root.bump-size(-1); } inc => { root.bump-size(1); } }
    // フォント（和文対応のシステムフォントをプリセット選択）。
    // 5プリセットを 3列×2段のグリッドに均等伸縮で並べ、どの列幅でもはみ出さない。
    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 3px;
        Text { text: @tr("フォント"); color: SettingsStyle.row-label; font-size: SettingsStyle.row-label-size; }
        GridLayout {
            spacing: 6px;
            Row {
                SegButton { fill: true; label: @tr("ゴシック"); active: root.font == "Yu Gothic UI"; clicked => { root.set-font("Yu Gothic UI"); } }
                SegButton { fill: true; label: @tr("メイリオ"); active: root.font == "Meiryo"; clicked => { root.set-font("Meiryo"); } }
                SegButton { fill: true; label: @tr("UD"); active: root.font == "BIZ UDPGothic"; clicked => { root.set-font("BIZ UDPGothic"); } }
            }
            Row {
                SegButton { fill: true; label: @tr("明朝"); active: root.font == "Yu Mincho"; clicked => { root.set-font("Yu Mincho"); } }
                SegButton { fill: true; label: @tr("等幅"); active: root.font == "MS Gothic"; clicked => { root.set-font("MS Gothic"); } }
            }
        }
    }
    ToggleRow { label: @tr("太字"); checked: root.bold; toggled => { root.toggle-bold(); } }
}

// 表示（強調・省略・マスク・フォントサイズ・起動タブ）
component DisplaySection inherits SectionCard {
    in property <SettingsUi> cfg;
    in property <SettingsNumUi> nums;
    in property <float> accent-h;          // アクセント色ピッカーの色相(0..1)
    in property <float> accent-s;          // 同 彩度(0..1)
    in property <float> accent-v;          // 同 明度(0..1)
    callback set-bool(string, bool);
    callback bump-num(string, int);
    callback set-str(string, string);
    callback pick-accent(float, float, float); // アクセント色ピッカー操作(h,s,v)
    callback picker-dragging-changed(bool);    // ピッカー押下中→Flickableスクロール抑止
    title: @tr("表示");
    ToggleRow { label: @tr("自分を強調"); checked: root.cfg.highlight-local; toggled => { root.set-bool("highlight-local", !root.cfg.highlight-local); } }
    ToggleRow { label: @tr("スコア省略(K/M)"); checked: root.cfg.abbreviate-scores; toggled => { root.set-bool("abbreviate-scores", !root.cfg.abbreviate-scores); } }
    ToggleRow { label: @tr("名前マスク"); checked: root.cfg.privacy-mask; toggled => { root.set-bool("privacy-mask", !root.cfg.privacy-mask); } }
    ToggleRow { label: @tr("軽量分割表示"); checked: root.cfg.compact-split; toggled => { root.set-bool("compact-split", !root.cfg.compact-split); } }
    ToggleRow { label: @tr("タスクバーに常駐"); checked: root.cfg.show-in-taskbar; toggled => { root.set-bool("show-in-taskbar", !root.cfg.show-in-taskbar); } }
    // メイン窓の文字サイズ・フォント（バフ/デバフ オーバーレイもこれに追随する）。
    FontControls {
        size-text: root.nums.font-size;
        font: root.cfg.main-font;
        bold: root.cfg.main-font-bold;
        bump-size(d) => { root.bump-num("font-size", d); }
        set-font(f) => { root.set-str("main-font", f); }
        toggle-bold => { root.set-bool("main-font-bold", !root.cfg.main-font-bold); }
    }
    // 起動時のタブ: ラベルを上・セグボタンを下に縦積み（狭幅列でもラベルが潰れない）
    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 3px;
        Text { text: @tr("起動時のタブ"); color: SettingsStyle.row-label; font-size: SettingsStyle.row-label-size; }
        HorizontalLayout {
            spacing: 6px;
            SegButton { label: @tr("DPS"); active: root.cfg.startup-tab == "dps"; clicked => { root.set-str("startup-tab", "dps"); } }
            SegButton { label: @tr("回復"); active: root.cfg.startup-tab == "heal"; clicked => { root.set-str("startup-tab", "heal"); } }
            SegButton { label: @tr("履歴"); active: root.cfg.startup-tab == "history"; clicked => { root.set-str("startup-tab", "history"); } }
            // 余白を吸収し、固定幅セグボタンによる行の max-width(150px) 制限を解除する。
            // これがないと DisplaySection→中央列が ~150px で頭打ちになり伸縮しない。
            Rectangle { horizontal-stretch: 1; }
        }
    }
    // 言語: 選択は保存され、反映は次回起動時（Slint 1.16 は @tr リテラルを定数畳み込みするため
    // ランタイムでは既存 UI を再翻訳できない）。ボタン名は各言語の自称表記なので翻訳しない。
    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 3px;
        Text { text: @tr("言語"); color: SettingsStyle.row-label; font-size: SettingsStyle.row-label-size; }
        HorizontalLayout {
            spacing: 6px;
            SegButton { label: "日本語"; active: root.cfg.language == "ja"; clicked => { root.set-str("language", "ja"); } }
            SegButton { label: "English"; active: root.cfg.language == "en"; clicked => { root.set-str("language", "en"); } }
            // 中文（簡体字）は翻訳・名前辞書が未完成のため一旦非表示（zh.po 等は温存）。
            // 完成したら下行を復帰: SegButton { label: "中文"; active: root.cfg.language == "zh"; clicked => { root.set-str("language", "zh"); } }
            Rectangle { horizontal-stretch: 1; }
        }
        Text {
            text: @tr("再起動後に反映されます");
            color: SettingsStyle.hint;
            font-size: SettingsStyle.hint-size;
            wrap: word-wrap;
        }
    }
    // アクセントカラー: HSV ピッカーで任意色を選択（クリックで即適用・全ウィンドウ再起動不要）
    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 3px;
        Text { text: @tr("アクセントカラー"); color: SettingsStyle.row-label; font-size: SettingsStyle.row-label-size; }
        HsvPicker {
            h: root.accent-h;
            s: root.accent-s;
            v: root.accent-v;
            pick(h, s, v) => { root.pick-accent(h, s, v); }
            dragging-changed(d) => { root.picker-dragging-changed(d); }
        }
    }
}

// オーバーレイ（バフ/デバフ窓・最前面）。不透明度は全幅化のため setbox 側へ分離。
component OverlaySection inherits SectionCard {
    in property <SettingsUi> cfg;
    in property <SettingsNumUi> nums;
    in property <float> overlay-opacity;
    in property <float> text-h;            // 文字色ピッカーの色相(0..1)
    in property <float> text-s;            // 文字色ピッカーの彩度(0..1)
    in property <float> text-v;            // 文字色ピッカーの明度(0..1)
    callback set-bool(string, bool);
    callback set-overlay-opacity(float);
    callback bump-num(string, int);
    callback set-str(string, string);
    callback pick-text(float, float, float); // 文字色ピッカー操作(h,s,v)
    callback picker-dragging-changed(bool);  // ピッカー押下中→Flickableスクロール抑止
    title: @tr("オーバーレイ");
    ToggleRow { label: @tr("自キャラ バフ/デバフ"); checked: root.cfg.self-status; toggled => { root.set-bool("self-status-overlay", !root.cfg.self-status); } }
    ToggleRow { label: @tr("常に最前面"); checked: root.cfg.aot; toggled => { root.set-bool("aot", !root.cfg.aot); } }
    // ── 外観（不透明度・文字色は3窓共通。文字サイズ・フォントは窓ごとに独立：
    //    バフ/デバフ=メイン窓に追随／ステータス・イマジンは各セクションで個別設定）──
    Text { text: @tr("外観"); color: SettingsStyle.sub-label; font-size: SettingsStyle.sub-label-size; }
    OpacityRow { value: root.overlay-opacity; changed(v) => { root.set-overlay-opacity(v); } }
    // 完全透明（不透明度0）時の警告。クリック透過になり当該オーバーレイ自体は操作不可になる。
    if root.overlay-opacity <= 0.001: Rectangle {
        background: #ffb45422;
        border-width: 1px;
        border-color: #ffb45466;
        border-radius: 4px;
        HorizontalLayout {
            padding: 6px;
            Text {
                text: @tr("完全透明中はクリック透過になり、オーバーレイの移動・最小化・閉じるができません。設定パネルで不透明度を上げると操作に戻れます。");
                color: #ffcf8a;
                font-size: 10px;
                wrap: word-wrap;
                horizontal-stretch: 1;
            }
        }
    }
    // 文字装飾（縁取り／影）。低不透明度・透明 HUD で文字を背景から浮かせる。個別に ON/OFF 可。
    ToggleRow { label: @tr("縁取り"); checked: root.cfg.overlay-outline; toggled => { root.set-bool("overlay-outline", !root.cfg.overlay-outline); } }
    ToggleRow { label: @tr("影"); checked: root.cfg.overlay-shadow; toggled => { root.set-bool("overlay-shadow", !root.cfg.overlay-shadow); } }
    // ※ フォントサイズ・フォント・太字はバフ/デバフ＝メイン窓設定に追随（「表示」セクション）。
    //    ステータス／イマジンタイマーは各セクションで個別に設定する。
    // 文字色（白系ラベル/値のみ再着色・意味色は維持）。HSV ピッカーで任意色を選択。
    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 3px;
        Text { text: @tr("文字色"); color: SettingsStyle.row-label; font-size: SettingsStyle.row-label-size; }
        HsvPicker {
            h: root.text-h;
            s: root.text-s;
            v: root.text-v;
            pick(h, s, v) => { root.pick-text(h, s, v); }
            dragging-changed(d) => { root.picker-dragging-changed(d); }
        }
    }
}

// イマジンデバフタイマー（表示ON/OFF＋専用モード＋表示するイマジン列＋専用フォント）
component ImagineTimerSection inherits SectionCard {
    in property <SettingsUi> cfg;
    in property <SettingsNumUi> nums;
    callback set-bool(string, bool);
    callback bump-num(string, int);
    callback set-str(string, string);
    callback clear-watchlist();
    title: @tr("イマジンタイマー");
    ToggleRow { label: @tr("イマジンデバフタイマー"); checked: root.cfg.buff-overlay; toggled => { root.set-bool("buff-overlay", !root.cfg.buff-overlay); } }
    ToggleRow { label: @tr("イマジン専用モード"); checked: root.cfg.imagine-only; toggled => { root.set-bool("imagine-only", !root.cfg.imagine-only); } }
    // メインDPS画面とタイマーの名簿を同期。ON=顔ぶれ・並びを自動追従しピンは隠す/表示、OFF=手動ピン運用。
    // 専用モードは集計を省く軽量モードで導出元(メインDPS一覧)が空になるため、互いに排他（片方ON時は他方を無効化）。
    ToggleRow {
        label: @tr("メインDPSと同期");
        checked: root.cfg.sync-timer;
        enabled: !root.cfg.imagine-only;
        toggled => { root.set-bool("sync-timer-with-main", !root.cfg.sync-timer); }
    }
    Text {
        text: root.cfg.imagine-only
            ? @tr("専用モードでは集計を省くため同期不可。バフ検知した全員を自動表示します")
            : (root.cfg.sync-timer
                ? @tr("メインの顔ぶれ・並びに自動追従。ピンで個別に隠す/表示")
                : @tr("手動でピンしたプレイヤーのみ表示"));
        color: SettingsStyle.sub-label;
        font-size: SettingsStyle.sub-label-size;
        wrap: word-wrap;
    }
    // 同期の子設定（ツリー表示）: 並び順までメイン一覧へ追従するか。
    // 同期OFFまたは専用モードONのときは意味を持たないため無効化。
    ToggleRow {
        pad-x: 24px;
        label: @tr("並び順の追従");
        checked: root.cfg.sync-order-follow;
        enabled: root.cfg.sync-timer && !root.cfg.imagine-only;
        toggled => { root.set-bool("sync-order-follow", !root.cfg.sync-order-follow); }
    }
    // ウォッチクリアは手動運用(同期OFF・専用OFF)のときだけ意味を持つ導線。
    // 過去の幽霊エントリ（離脱済プレイヤー等）を一括で掃除する。
    if !root.cfg.sync-timer && !root.cfg.imagine-only: clear-wl-btn := TouchArea {
        height: 22px;
        accessible-role: button;
        accessible-label: @tr("ウォッチをクリア");
        accessible-action-default => { root.clear-watchlist(); }
        clicked => { root.clear-watchlist(); }
        Rectangle {
            background: clear-wl-btn.has-hover ? #ffffff20 : #ffffff10;
            animate background { duration: 100ms; easing: ease-out; }
            border-radius: 3px;
            Text { text: @tr("ウォッチをクリア"); color: #cdd; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
        }
    }
    // 名簿の表示レイアウト（密表示）。同期/手動どちらの運用でも見た目に影響するため、
    // 同期セクションの直後に置き「名簿の出し方」がひとまとまりに見えるようグルーピング。
    // タイマー本体(buff-overlay)が OFF のときは無関係なので畳んで初見の圧を下げる。
    if root.cfg.buff-overlay: VerticalLayout {
        spacing: 1px;
        Text { text: @tr("レイアウト"); color: SettingsStyle.sub-label; font-size: SettingsStyle.sub-label-size; }
        ToggleRow { pad-x: 4px; label: @tr("密表示（行を詰める）"); checked: root.cfg.imagine-compact-rows; toggled => { root.set-bool("imagine-compact-rows", !root.cfg.imagine-compact-rows); } }
    }
    // タイマーに表示するイマジン列＋専用フォント（パーティ構成に合わせて不要列を消す）。
    // タイマー本体(buff-overlay)が OFF のときは無関係なので畳んで初見の圧を下げる。
    if root.cfg.buff-overlay: VerticalLayout {
        spacing: 1px;
        Text { text: @tr("タイマー表示イマジン"); color: SettingsStyle.sub-label; font-size: SettingsStyle.sub-label-size; }
        // ステータスと同様に2列化（左=ティナ/アルーナ・右=タータ/バジリスク）。列間に上下90%の中央寄せ区切り線。
        HorizontalLayout {
            spacing: 8px;
            VerticalLayout {
                horizontal-stretch: 1;
                min-width: 0px;
                spacing: 1px;
                alignment: start;
                ToggleRow { pad-x: 4px; label: @tr("ティナ"); checked: root.cfg.show-imagine-tina; toggled => { root.set-bool("imagine-col-tina", !root.cfg.show-imagine-tina); } }
                ToggleRow { pad-x: 4px; label: @tr("アルーナ"); checked: root.cfg.show-imagine-aluna; toggled => { root.set-bool("imagine-col-aluna", !root.cfg.show-imagine-aluna); } }
            }
            // 列間の薄い区切り線（上下いっぱいではなく高さ90%を中央寄せ＝上下に接地しない）。
            Rectangle {
                width: 1px;
                Rectangle { width: 1px; height: parent.height * 0.9; background: #ffffff2e; }
            }
            VerticalLayout {
                horizontal-stretch: 1;
                min-width: 0px;
                spacing: 1px;
                alignment: start;
                ToggleRow { pad-x: 4px; label: @tr("タータ"); checked: root.cfg.show-imagine-tarta; toggled => { root.set-bool("imagine-col-tarta", !root.cfg.show-imagine-tarta); } }
                ToggleRow { pad-x: 4px; label: @tr("バジリスク"); checked: root.cfg.show-imagine-basilisk; toggled => { root.set-bool("imagine-col-basilisk", !root.cfg.show-imagine-basilisk); } }
            }
        }
        // タイマー専用の文字サイズ・フォント（メイン窓とは独立）。
        Text { text: @tr("文字"); color: SettingsStyle.sub-label; font-size: SettingsStyle.sub-label-size; }
        FontControls {
            size-text: root.nums.imagine-overlay-font-size;
            font: root.cfg.imagine-overlay-font;
            bold: root.cfg.imagine-overlay-font-bold;
            bump-size(d) => { root.bump-num("imagine-overlay-font-size", d); }
            set-font(f) => { root.set-str("imagine-overlay-font", f); }
            toggle-bold => { root.set-bool("imagine-overlay-font-bold", !root.cfg.imagine-overlay-font-bold); }
        }
    }
}

// 自キャラ ステータス窓（表示ON/OFF＋専用フォント＋表示する項目のカスタマイズ）
component StatsSection inherits SectionCard {
    in property <SettingsUi> cfg;
    in property <SettingsNumUi> nums;
    // 項目カタログは Rust 側でグループ境界を跨がず左右2列へ分割済み（見出しを各列で保持）。
    in property <[StatCatalogItem]> catalog-left;
    in property <[StatCatalogItem]> catalog-right;
    callback set-bool(string, bool);
    callback bump-num(string, int);
    callback set-str(string, string);
    title: @tr("ステータス");
    ToggleRow { label: @tr("自キャラ ステータス"); checked: root.cfg.stats-overlay; toggled => { root.set-bool("stats-overlay", !root.cfg.stats-overlay); } }
    // 表示する項目（ゲーム内パネル単位でグループ表示。実測率とステータス値は別項目）。
    // ステータスが OFF のときはカタログ(~23項目)を畳んで初見の圧と列の縦長を抑える。
    if root.cfg.stats-overlay: VerticalLayout {
        spacing: 1px;
        // ステータス窓 専用の文字サイズ・フォント（メイン窓とは独立）。
        Text { text: @tr("文字"); color: SettingsStyle.sub-label; font-size: SettingsStyle.sub-label-size; }
        FontControls {
            size-text: root.nums.stats-overlay-font-size;
            font: root.cfg.stats-overlay-font;
            bold: root.cfg.stats-overlay-font-bold;
            bump-size(d) => { root.bump-num("stats-overlay-font-size", d); }
            set-font(f) => { root.set-str("stats-overlay-font", f); }
            toggle-bold => { root.set-bool("stats-overlay-font-bold", !root.cfg.stats-overlay-font-bold); }
        }
        Text { text: @tr("表示する項目"); color: SettingsStyle.sub-label; font-size: SettingsStyle.sub-label-size; }
        // ~23項目を1クリックで一括切替（個別トグルの手間を省く）。
        HorizontalLayout {
            spacing: 6px;
            SegButton { fill: true; label: @tr("すべてオン"); clicked => { root.set-bool("stats-all-on", true); } }
            SegButton { fill: true; label: @tr("すべてオフ"); clicked => { root.set-bool("stats-all-off", true); } }
        }
        // 項目を2列に分割（左=catalog-left / 右=catalog-right）。列間に薄い区切り線を入れて視認性を上げる。
        HorizontalLayout {
            spacing: 8px;
            VerticalLayout {
                horizontal-stretch: 1;
                min-width: 0px;
                spacing: 1px;
                alignment: start;
                for item in root.catalog-left: VerticalLayout {
                    spacing: 1px;
                    if item.group-head != "": Text { text: item.group-head; color: SettingsStyle.group-head; font-size: SettingsStyle.group-head-size; }
                    ToggleRow {
                        pad-x: 4px; // 狭い半幅列ではラベル省略を抑えるため左右パディングを詰める
                        label: item.label;
                        checked: item.enabled;
                        toggled => { root.set-bool("stat.\{item.key}", !item.enabled); }
                    }
                }
            }
            // 列間の薄い区切り線（上下いっぱいではなく高さ90%を中央寄せ＝上下に接地しない）。
            Rectangle {
                width: 1px;
                Rectangle { width: 1px; height: parent.height * 0.9; background: #ffffff2e; }
            }
            VerticalLayout {
                horizontal-stretch: 1;
                min-width: 0px;
                spacing: 1px;
                alignment: start;
                for item in root.catalog-right: VerticalLayout {
                    spacing: 1px;
                    if item.group-head != "": Text { text: item.group-head; color: SettingsStyle.group-head; font-size: SettingsStyle.group-head-size; }
                    ToggleRow {
                        pad-x: 4px; // 狭い半幅列ではラベル省略を抑えるため左右パディングを詰める
                        label: item.label;
                        checked: item.enabled;
                        toggled => { root.set-bool("stat.\{item.key}", !item.enabled); }
                    }
                }
            }
        }
    }
}

// 戦闘（終了判定・更新間隔・3分計測）
component CombatSection inherits SectionCard {
    in property <SettingsUi> cfg;
    in property <SettingsNumUi> nums;
    callback set-bool(string, bool);
    callback bump-num(string, int);
    title: @tr("戦闘");
    StepperRow { label: @tr("戦闘終了(秒)"); value-text: root.nums.combat-exit; dec => { root.bump-num("combat-exit", -1); } inc => { root.bump-num("combat-exit", 1); } }
    StepperRow { label: @tr("更新間隔(ms)"); value-text: root.nums.poll-interval; dec => { root.bump-num("poll-interval", -1); } inc => { root.bump-num("poll-interval", 1); } }
    StepperRow { label: @tr("計測時間(秒)"); value-text: root.nums.three-min-dur; dec => { root.bump-num("three-min-dur", -1); } inc => { root.bump-num("three-min-dur", 1); } }
    ToggleRow { label: @tr("計測を自動で開く"); checked: root.cfg.three-min-auto-open; toggled => { root.set-bool("three-min-auto-open", !root.cfg.three-min-auto-open); } }
}

// 履歴・グラフ
component HistorySection inherits SectionCard {
    in property <SettingsUi> cfg;
    in property <SettingsNumUi> nums;
    callback set-bool(string, bool);
    callback bump-num(string, int);
    title: @tr("履歴・グラフ");
    StepperRow { label: @tr("履歴保持数"); value-text: root.nums.history-limit; dec => { root.bump-num("history-limit", -1); } inc => { root.bump-num("history-limit", 1); } }
    StepperRow { label: @tr("グラフ標本数"); value-text: root.nums.ts-samples; dec => { root.bump-num("ts-samples", -1); } inc => { root.bump-num("ts-samples", 1); } }
    StepperRow { label: @tr("グラフ間隔(ms)"); value-text: root.nums.ts-interval; dec => { root.bump-num("ts-interval", -1); } inc => { root.bump-num("ts-interval", 1); } }
    StepperRow { label: @tr("グラフ表示人数"); value-text: root.nums.graph-count; dec => { root.bump-num("graph-count", -1); } inc => { root.bump-num("graph-count", 1); } }
    ToggleRow { label: @tr("自分のグラフを表示"); checked: root.cfg.graph-for-local; toggled => { root.set-bool("graph-for-local", !root.cfg.graph-for-local); } }
}

// イマジン名メンテ窓のテーブル列幅（固定2列ぶん）。可変2列(スキル名/表示名)の幅は
// ImagineNamesWindow.col-flex-w（root.width から算出・全行/ヘッダー共通）を参照する。
// horizontal-stretch による自動配分は行ごとの文字列長で preferred-width が変わり縦線がズレる
// ため使わない（v1.18.0 で実機報告・修正）。
global ImagineTableCols {
    out property <length> imagine-name-col: 110px;
    out property <length> action-col: 50px; // SegButton の既定幅(50px、fill未指定)と一致させる
}

// イマジン名メンテ窓のテーブル縦罫線（列区切り）。
component ImagineColDivider inherits Rectangle {
    width: 1px;
    background: SettingsStyle.card-border;
}

// バトルイマジン名メンテの起動セクション（設定パネル・常に全幅）。
// 本体は別ウィンドウ（ImagineNamesWindow）へ移設済み。ここは説明文＋起動ボタンのみを置く。
component ImagineNamesOpenSection inherits SectionCard {
    callback open-window();
    title: @tr("イマジン名");
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 2px;
        padding-bottom: 2px;
        spacing: 10px;
        Text {
            text: @tr("バトルイマジンの表示名を編集する専用ウィンドウを開きます。");
            color: SettingsStyle.hint;
            font-size: SettingsStyle.hint-size;
            wrap: word-wrap;
            horizontal-stretch: 1;
            min-width: 0px;
            vertical-alignment: center;
        }
        open-btn := TouchArea {
            width: 128px;
            height: 26px;
            clicked => { root.open-window(); }
            Rectangle {
                background: open-btn.has-hover ? SettingsStyle.control-bg-hover : SettingsStyle.control-bg;
                animate background { duration: 100ms; easing: ease-out; }
                border-radius: SettingsStyle.radius;
                Text { text: @tr("別ウィンドウで開く"); color: #cdd; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
}

// バトルイマジン名メンテ（別ウィンドウ・通常の OS タイトルバー付き）。MainWindow やバフ/
// ステータス系オーバーレイと違い no-frame にせず always-on-top にもしない（タスクバーにも
// 通常どおり表示される・OS が最小化/リサイズ/×閉じを扱う）。×閉じは Slint の既定挙動
// （CloseRequestResponse::HideWindow）でウィンドウが隠れるだけ＝プロセスは終了しない。
//
// スキル名列＝ゲームのスキル名（メイン＋分身をアコーディオンで束ねる。編集不可）。
// イマジン名列＝Git DB(ImagineSkillNames.json)の正典名（開発者モード限定で編集可）。
// 表示名列＝ユーザーのローカル上書き（空ならイマジン名にフォールバック。IGNOREで非表示）。
//
// 入力中クロバー回避: TemplateField と同じ方針で、イマジン名/表示名 TextInput の `text:` は
// 各行モデルの当該フィールドへバインドするが、Rust 側は「編集の都度」再送しない
// （set-display/set-name コールバックは永続化のみ行い rebuild しない）。展開/IGNORE/リセット/
// フィルタ等の非タイプ操作のみモデルを再構築する。イマジン名(devのみ)は accepted(Enter確定)の
// まま（editedにすると1キー毎の再ソート＋in-place同期で別イマジンを誤リネームし得るため）。
export component ImagineNamesWindow inherits Window {
    in property <[ImagineNameRowUi]> imagine-rows;
    in property <bool> imagine-dev-mode;
    in property <string> imagine-push-status;
    in property <string> imagine-filter-value;
    callback imagine-toggle-expand(string);
    callback imagine-set-display(string, string);
    callback imagine-toggle-ignore(string);
    callback imagine-reset(string);
    callback imagine-set-name(string, string);
    callback imagine-push-db();
    callback imagine-set-filter(string);

    title: @tr("イマジン名のメンテナンス");
    default-font-family: "Yu Gothic UI";
    background: #14141e;
    preferred-width: 620px;
    preferred-height: 520px;
    min-width: 420px;
    min-height: 280px;

    // スキル名/表示名列の幅（Window 自身の width から算出）。ヘッダーと全行がこの1つの値を
    // 参照することで、テキスト長や devモード列有無に関わらず縦の列境界を完全に一致させる
    // （horizontal-stretch による自動配分は行ごとの内容量で min-width/preferred が変わり縦線が
    // ズレるため使わない）。root.width への直接バインディングは自身の layoutinfo と循環する
    // ため（MainWindow の narrow-header/col-level と同じ理由）、changed width で値として
    // 代入してループを断つ。
    property <length> outer-pad: 10px; // 下の最外周 VerticalLayout の padding と同じ値
    property <length> row-pad: 10px;   // 行/ヘッダーの左右パディング（下の HorizontalLayout と同じ値）
    property <length> col-gap: 8px;    // 列間の余白（下の HorizontalLayout の spacing と同じ値）
    property <length> col-flex-w: 150px;
    changed width => {
        // 行(ヘッダーも同型)は5セル(スキル名/イマジン名/表示名/非表示/リセット)+区切り線4本の
        // 計9要素を spacing で並べるため、間隙は 5+4-1=8 箇所ぶん生じる（区切り線1本につき
        // 前後2箇所ずつ）。ここを 4 箇所と誤算すると列が広がりすぎて右端がはみ出す
        // （v1.18.0 リリース後の実機報告で発覚。罫線自体は列幅一致で通貫していたが、
        // はみ出しにより最右列が窓の外へ出て見えていた）。
        root.col-flex-w = max(40px, (root.width - 2 * root.outer-pad - 2 * root.row-pad
            - ImagineTableCols.imagine-name-col
            - 2 * ImagineTableCols.action-col
            - 8 * root.col-gap) / 2);
    }

    VerticalLayout {
        padding: 10px;
        spacing: 8px;
        // 絞り込み＋（開発者モードのみ）GitHubへ反映
        HorizontalLayout {
            spacing: 6px;
            Rectangle {
                horizontal-stretch: 1;
                min-width: 0px;
                height: 26px;
                background: SettingsStyle.control-bg;
                border-width: 1px;
                border-color: filter-ti.has-focus ? Theme.accent : #ffffff26;
                border-radius: SettingsStyle.radius;
                if filter-ti.text == "": Text {
                    x: 6px;
                    text: @tr("絞り込み（名前で検索）");
                    color: SettingsStyle.hint;
                    font-size: 11px;
                    vertical-alignment: center;
                }
                filter-ti := TextInput {
                    x: 5px;
                    width: parent.width - 10px;
                    height: 100%;
                    vertical-alignment: center;
                    single-line: true;
                    color: #ddd;
                    font-size: 11px;
                    text: root.imagine-filter-value;
                    edited => { root.imagine-set-filter(self.text); }
                }
            }
            if root.imagine-dev-mode: push-btn := TouchArea {
                width: 96px;
                clicked => { root.imagine-push-db(); }
                Rectangle {
                    background: push-btn.has-hover ? SettingsStyle.control-bg-hover : SettingsStyle.control-bg;
                    animate background { duration: 100ms; easing: ease-out; }
                    border-radius: SettingsStyle.radius;
                    Text { text: @tr("GitHubへ反映"); color: #cdd; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
        if root.imagine-dev-mode && root.imagine-push-status != "": Text {
            text: root.imagine-push-status;
            color: SettingsStyle.hint;
            font-size: SettingsStyle.hint-size;
            wrap: word-wrap;
        }
        // テーブル本体（罫線付きヘッダー＋列を揃えた行。ヘッダーは固定・行のみスクロール）
        Rectangle {
            vertical-stretch: 1;
            clip: true;
            background: SettingsStyle.card-bg;
            border-width: 1px;
            border-color: SettingsStyle.card-border;
            border-radius: SettingsStyle.card-radius;
            VerticalLayout {
                // 列見出し
                Rectangle {
                    height: 28px;
                    background: #1c1c2a;
                    HorizontalLayout {
                        padding-left: root.row-pad;
                        padding-right: root.row-pad;
                        spacing: root.col-gap;
                        Text { text: @tr("スキル名"); color: SettingsStyle.sub-label; font-size: 11px; font-weight: 600; width: root.col-flex-w; vertical-alignment: center; }
                        ImagineColDivider {}
                        Text { text: @tr("イマジン名"); color: SettingsStyle.sub-label; font-size: 11px; font-weight: 600; width: ImagineTableCols.imagine-name-col; vertical-alignment: center; }
                        ImagineColDivider {}
                        Text { text: @tr("表示名"); color: SettingsStyle.sub-label; font-size: 11px; font-weight: 600; width: root.col-flex-w; vertical-alignment: center; }
                        ImagineColDivider {}
                        Text { text: @tr("非表示"); color: SettingsStyle.sub-label; font-size: 11px; font-weight: 600; width: ImagineTableCols.action-col; horizontal-alignment: center; vertical-alignment: center; }
                        ImagineColDivider {}
                        Text { text: @tr("リセット"); color: SettingsStyle.sub-label; font-size: 11px; font-weight: 600; width: ImagineTableCols.action-col; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
                Rectangle { height: 1px; background: SettingsStyle.card-border; }
                // 行本体（スクロール可能。ヘッダーは上の Rectangle に固定済み）
                Rectangle {
                    vertical-stretch: 1;
                    clip: true;
                    if root.imagine-rows.length == 0: Text {
                        x: 10px;
                        y: 8px;
                        text: @tr("該当するイマジンがありません");
                        color: SettingsStyle.hint;
                        font-size: SettingsStyle.hint-size;
                    }
                    rows-flick := Flickable {
                        width: 100%;
                        height: 100%;
                        viewport-height: rowsbox.preferred-height;
                        viewport-width: self.width;
                        rowsbox := VerticalLayout {
                            min-width: 0px;
                            preferred-width: 0px;
                            max-width: 100000px;
                            for row in root.imagine-rows: VerticalLayout {
                                spacing: 0px;
                                Rectangle {
                                    height: SettingsStyle.row-height;
                                    background: row-ta.has-hover ? SettingsStyle.row-hover : transparent;
                                    animate background { duration: 100ms; easing: ease-out; }
                                    opacity: row.ignored ? 0.45 : 1.0;
                                    // 行全体のホバー表示のみ（クリックは各セルの TouchArea/TextInput が個別に捕捉する）。
                                    row-ta := TouchArea {}
                                    HorizontalLayout {
                                        padding-left: root.row-pad;
                                        padding-right: root.row-pad;
                                        spacing: root.col-gap;
                                        expand-ta := TouchArea {
                                            width: root.col-flex-w;
                                            enabled: row.has-clones;
                                            clicked => { root.imagine-toggle-expand(row.canonical); }
                                            HorizontalLayout {
                                                spacing: 4px;
                                                if row.has-clones: Path {
                                                    width: 8px;
                                                    height: 8px;
                                                    viewbox-width: 10;
                                                    viewbox-height: 10;
                                                    commands: row.expanded ? "M 1 3 L 5 7 L 9 3" : "M 3 1 L 7 5 L 3 9";
                                                    stroke: #999;
                                                    stroke-width: 1.6px;
                                                    fill: transparent;
                                                }
                                                Text {
                                                    text: row.main-skill;
                                                    color: SettingsStyle.row-label;
                                                    font-size: SettingsStyle.row-label-size;
                                                    vertical-alignment: center;
                                                    overflow: elide;
                                                    horizontal-stretch: 1;
                                                    min-width: 0px;
                                                }
                                            }
                                        }
                                        ImagineColDivider {}
                                        // イマジン名（開発者モードのみ編集可。通常は読み取り専用テキスト）
                                        Rectangle {
                                            width: ImagineTableCols.imagine-name-col;
                                            height: 22px;
                                            if root.imagine-dev-mode: name-ti := TextInput {
                                                width: 100%;
                                                height: 100%;
                                                vertical-alignment: center;
                                                single-line: true;
                                                color: #ddd;
                                                font-size: 11px;
                                                text: row.imagine-name;
                                                // Enter確定のみ（editedにすると1キー毎にcanonicalが変わり再ソート→
                                                // in-place同期でフォーカス行に別イマジンのデータが入り、次のキーで
                                                // 無関係イマジンを誤リネームし得るため。UID入力欄(選択UID確定)と同型）。
                                                accepted => { root.imagine-set-name(row.canonical, self.text); }
                                            }
                                            if !root.imagine-dev-mode: Text {
                                                text: row.imagine-name;
                                                color: SettingsStyle.row-label;
                                                font-size: SettingsStyle.row-label-size;
                                                vertical-alignment: center;
                                                overflow: elide;
                                            }
                                        }
                                        ImagineColDivider {}
                                        // 表示名（ユーザー上書き。空欄はイマジン名をプレースホルダ表示）
                                        Rectangle {
                                            width: root.col-flex-w;
                                            height: 22px;
                                            if disp-ti.text == "": Text {
                                                text: row.canonical;
                                                color: SettingsStyle.hint;
                                                font-size: 11px;
                                                vertical-alignment: center;
                                            }
                                            disp-ti := TextInput {
                                                width: 100%;
                                                height: 100%;
                                                vertical-alignment: center;
                                                single-line: true;
                                                color: #ddd;
                                                font-size: 11px;
                                                text: row.display-name;
                                                edited => { root.imagine-set-display(row.canonical, self.text); }
                                            }
                                        }
                                        ImagineColDivider {}
                                        SegButton { label: @tr("非表示"); active: row.ignored; clicked => { root.imagine-toggle-ignore(row.canonical); } }
                                        ImagineColDivider {}
                                        SegButton { label: @tr("リセット"); clicked => { root.imagine-reset(row.canonical); } }
                                    }
                                }
                                if row.expanded: VerticalLayout {
                                    padding-left: 24px;
                                    padding-right: 10px;
                                    spacing: 1px;
                                    for c in row.clone-skills: Text {
                                        text: c;
                                        color: SettingsStyle.hint;
                                        font-size: SettingsStyle.hint-size;
                                        overflow: elide;
                                    }
                                }
                                Rectangle { height: 1px; background: SettingsStyle.card-border; }
                            }
                        }
                    }
                }
            }
        }
    }
}

// no-frame 窓の縁/角リサイズ用ハンドル。
component ResizeHandle inherits TouchArea {
    in property <int> dir;
    callback resize(int);
    pointer-event(e) => {
        if (e.kind == PointerEventKind.down) {
            root.resize(root.dir);
        }
    }
}

// no-frame 窓の縁/角リサイズ枠（8ハンドル）。中央は透過し下層へイベントを通す。
// 透明 Rectangle 自体はイベントを捕捉しないため、縁/角のみ反応する。
component ResizeEdges inherits Rectangle {
    callback resize(int);
    ResizeHandle { dir: 0; mouse-cursor: ns-resize; resize(d) => { root.resize(d); } x: 14px; y: 0; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 1; mouse-cursor: ns-resize; resize(d) => { root.resize(d); } x: 14px; y: root.height - 6px; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 2; mouse-cursor: ew-resize; resize(d) => { root.resize(d); } x: root.width - 6px; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 3; mouse-cursor: ew-resize; resize(d) => { root.resize(d); } x: 0; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 5; mouse-cursor: nwse-resize; resize(d) => { root.resize(d); } x: 0; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 4; mouse-cursor: nesw-resize; resize(d) => { root.resize(d); } x: root.width - 14px; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 7; mouse-cursor: nesw-resize; resize(d) => { root.resize(d); } x: 0; y: root.height - 14px; width: 14px; height: 14px; }
    ResizeHandle { dir: 6; mouse-cursor: nwse-resize; resize(d) => { root.resize(d); } x: root.width - 14px; y: root.height - 14px; width: 14px; height: 14px; }
}

export component MainWindow inherits Window {
    in property <[Row]> rows;
    in property <[Row]> compact-left;   // 軽量分割 左カラム（前半）
    in property <[Row]> compact-right;  // 軽量分割 右カラム（後半）
    in property <[SkillRowUi]> skill-rows;
    in property <[HistoryRowUi]> history-rows;
    in property <string> total-text: "0";
    in property <string> elapsed-text: "0:00";
    in property <string> inspected-name;
    in property <bool> highlight-local: true;
    in property <bool> aot: true; // 常に最前面（設定連動）
    in property <ColumnFlags> cols;
    in property <int> tab: 0;  // 0=dps 1=heal 2=taken 3=history（Rust が set）
    in property <int> view: 0; // 0=一覧 1=スキル内訳/攻撃元（Rust が set）
    in property <bool> skills-clickable; // 被ダメ攻撃元一覧のとき true（行クリックで技別へ）
    in property <bool> settings-open;
    in property <SettingsUi> cfg-ui;
    in property <SettingsNumUi> nums;
    in property <string> name-template-value;
    in property <string> copy-template-value;
    in property <string> name-preview;
    in property <string> copy-preview;
    in property <string> selected-uid-value;  // 自キャラUID入力欄（開時/確定時に push）
    in property <string> selected-uid-name;    // 解決名/状態表示
    in property <[UidCandidate]> uid-candidates;
    in property <[StatCatalogItem]> stat-catalog-left; // ステータス表示項目トグル一覧（左列・グループ境界で分割）
    in property <[StatCatalogItem]> stat-catalog-right; // 同・右列
    in property <float> win-opacity: 0.85;
    in property <float> overlay-opacity: 0.82; // オーバーレイ3窓共通の背景不透明度（メインとは独立）
    in property <float> overlay-text-h: 0;     // 文字色HSVピッカーの色相(0..1。Rustが現在色から算出)
    in property <float> overlay-text-s: 0;     // 同 彩度(0..1)
    in property <float> overlay-text-v: 1.0;   // 同 明度(0..1)
    in property <float> accent-h: 0;           // アクセント色HSVピッカーの色相(0..1。Rustが現在色から算出)
    in property <float> accent-s: 0;           // 同 彩度(0..1)
    in property <float> accent-v: 1.0;         // 同 明度(0..1)
    in property <float> font-scale: 1.0; // 本体テーブル＋ヘッダの文字倍率（font_size/12）
    in property <string> main-font: "Yu Gothic UI"; // 本体フォントファミリ（バフ/デバフ オーバーレイも追随）
    in property <bool> main-font-bold;              // 本体フォントの太字（同上）
    in property <bool> copied; // コピー直後の一時フィードバック
    in property <bool> show-graph-col;    // 一覧にDPS推移列を出すか（graph設定＋被ダメ以外）
    in property <bool> show-consumable: true; // 名前列に食事/シロップバッジを出すか
    in property <bool> paused;            // 集計の一時停止状態
    in property <int> measure-kind;       // 3分計測 0=通常 1=待機(pending) 2=計測中(active)
    in property <string> measure-text;    // 計測中のカウントダウン "M:SS"
    in property <bool> result-open;       // 3分計測 結果パネル表示
    in property <string> result-dps;
    in property <string> result-dmg;
    in property <string> result-duration;
    in property <string> result-char-spark;         // エリア1: 選択キャラの区間DPS折れ線（実寸px座標）
    in property <bool> result-char-spark-visible;
    callback result-char-spark-resized(float, float); // プロット実寸(px)変化→Rustが再生成
    in property <[ResultRowUi]> result-rows;        // エリア1: キャラ一覧（最大5）
    in property <[ResultSkillRowUi]> result-skill-rows; // エリア2: スキル内訳
    in property <string> result-skill-spark;        // エリア2: 選択スキルの区間DPS折れ線（実寸px座標）
    in property <bool> result-skill-spark-visible;
    callback result-skill-spark-resized(float, float); // プロット実寸(px)変化→Rustが再生成
    in property <[PieSlice]> result-pie;            // エリア3: TOP10+その他 円グラフ
    in property <[SkillLegendUi]> result-legend;
    in property <string> result-pie-title;
    in property <string> result-char-name;          // エリア1 折れ線ラベル: 選択キャラ名
    in property <string> result-skill-name;         // エリア4 折れ線ラベル: 選択スキル名
    in property <string> result-char-axis-top;      // エリア1 Y軸: 最大DPS
    in property <string> result-char-axis-mid;      // エリア1 Y軸: 最大DPSの半分
    in property <string> result-skill-axis-top;     // エリア4 Y軸: 最大DPS
    in property <string> result-skill-axis-mid;     // エリア4 Y軸: 最大DPSの半分
    in property <float> result-duration-ms;         // 折れ線 X軸 時間ラベル用（計測全体の長さ）
    in property <int> capture-state;  // 0=起動中 1=待機(ゲーム通信なし) 2=受信中 3=開始失敗
    in property <string> app-version;        // 設定パネル最下部の表示（バージョンのみ）
    in property <string> result-watermark;   // 結果モーダルの透かし（バージョン・日時・計測時間。画像コピーに写り込む）
    in property <bool> result-img-copied;    // 画像コピー直後の一時フィードバック
    in property <bool> result-is-new-record;    // 自キャラの自己ベスト更新（計測確定時のみ判定）
    in property <string> result-best-dps-text;  // 自己ベストDPSの表示用整形済み文字列（自キャラ不在/記録無しは空）
    callback quit();
    callback minimize();
    callback start-drag();
    callback start-resize(int);
    callback select-tab(int);
    callback open-drill(string);
    callback drill-row(string);
    callback toggle-watch(string);
    callback back();
    callback toggle-settings();
    callback set-bool(string, bool);
    callback set-opacity(float);
    callback set-overlay-opacity(float);
    callback pick-overlay-text(float, float, float); // 文字色HSVピッカー操作(h,s,v)
    callback pick-accent(float, float, float);       // アクセント色HSVピッカー操作(h,s,v)
    callback bump-num(string, int);
    callback set-str(string, string);
    callback reset-str(string);
    callback set-selected-uid(string); // 空文字=クリア
    callback copy-list();
    callback toggle-history(string);
    callback clear-history();
    callback clear-watchlist(); // 手動運用(同期OFF)のウォッチ一括クリア（watched・excluded 両方）
    callback toggle-measure();
    callback toggle-pause();
    callback reset-encounter();
    callback close-result();
    callback copy-result();
    callback copy-result-image();
    callback restart-measure();
    callback select-result-player(string);
    callback select-result-skill(string);
    callback imagine-open-window();                   // 「別ウィンドウで開く」ボタン→ ImagineNamesWindow を show()

    // ヘッダの固定幅合計（タブ＋ボタン）が収まらない幅ではアイコン/短縮ラベル表示に切り替える。
    // root.width への直接バインディングはヘッダ文字列経由で layoutinfo と循環するため、
    // changed コールバックで値として代入してループを断つ。
    property <bool> narrow-header: false;
    // 一覧の列を幅に応じて段階的に間引くレベル(6=全列表示可能 .. 0=最小)。同じ理由で
    // root.width への直接バインディングは避け、changed width で値として代入する。
    property <int> col-level: 6;
    changed width => {
        root.narrow-header = root.width < 600px;
        root.col-level = root.width >= 600px ? 6
            : (root.width >= 560px ? 5
            : (root.width >= 500px ? 4
            : (root.width >= 440px ? 3
            : (root.width >= 380px ? 2
            : (root.width >= 320px ? 1 : 0)))));
    }
    // 設定でONの列でも幅が足りなければ隠す（優先して隠す順: 幸運ダメ率→幸運率→会心ダメ率→
    // ヒット数→毎分ヒット→推移スパークライン）。ダメージ/DPS/%・会心率・戦力は幅による強制
    // 非表示の対象外（設定トグルのみで制御）。ヘッダ行と PlayerRowItem の両方がこれを参照する。
    property <ColumnFlags> effective-cols: {
        crit: root.cols.crit,
        crit-value: root.cols.crit-value && root.col-level >= 4,
        lucky: root.cols.lucky && root.col-level >= 5,
        lucky-value: root.cols.lucky-value && root.col-level >= 6,
        hits: root.cols.hits && root.col-level >= 3,
        hpm: root.cols.hpm && root.col-level >= 2,
        score: root.cols.score,
    };
    property <bool> effective-show-graph-col: root.show-graph-col && root.col-level >= 1;
    // 設定パネルの列数（窓幅でレスポンシブに 1/2/3）。短ラベルが多いので幅があれば3列まで。
    property <int> set-cols: root.width >= 660px ? 3 : (root.width >= 440px ? 2 : 1);
    // HSVピッカーをドラッグ中か。true の間は設定パネル Flickable の interactive を切り、
    // ポインタ移動でスクロールへグラブが奪われるのを防ぐ（ピッカー操作とスクロールの連動解消）。
    property <bool> picker-dragging: false;
    // セクション index(0=キャラ,1=表示列,2=表示,3=オーバーレイ,4=戦闘,5=履歴,6=ステータス,7=イマジンタイマー) の所属カラムを返す。
    // イマジンタイマー(7)とステータス(6)は同じ列へ積む（7=上, 6=下）。ステータスは表示項目を
    // 2列化して縦を抑えるため、両者を専用カラムに置いても列の高さ差が出にくい。
    pure function scol(i: int) -> int {
        if (root.set-cols <= 1) {
            return 0;
        }
        if (root.set-cols == 2) {
            // 列0: キャラ/表示列/表示/オーバーレイ、 列1: 戦闘/履歴/イマジンタイマー/ステータス
            return i <= 3 ? 0 : 1;
        }
        // 3列: 列2=イマジンタイマー＋ステータス、 列1=表示/オーバーレイ、 列0=キャラ/表示列/戦闘/履歴
        if (i == 6 || i == 7) {
            return 2;
        }
        if (i == 2 || i == 3) {
            return 1;
        }
        return 0;
    }

    title: @tr("DPSメーター");
    // femtovg は ClearType 非対応のため既定は可読性重視の和文フォント。設定で変更可（バフ/デバフ オーバーレイも追随）。
    default-font-family: root.main-font;
    default-font-weight: root.main-font-bold ? 700 : 400;
    no-frame: true;
    always-on-top: root.aot;
    // 不透明度: 背景の透け具合を調整（文字・バーは可読性のため不透明のまま）
    background: #14141e.with-alpha(root.win-opacity);
    preferred-width: 520px;
    preferred-height: 360px;

    VerticalLayout {
        // ── ヘッダ（タブ + 合計 + ドラッグ + 終了）──
        Rectangle {
            height: 26px;
            background: #1c1c2acc;
            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                spacing: 2px;
                // 回復/被ダメ/履歴は元々2〜3文字と短いため、狭幅でも英語へ差し替えず常に日本語で統一する
                // （狭幅時のみ英語になり日本語UIに英単語が混ざっていた問題の解消）。
                TabButton { label: @tr("DPS"); active: root.tab == 0; clicked => { root.select-tab(0); } }
                TabButton { label: @tr("回復"); active: root.tab == 1; clicked => { root.select-tab(1); } }
                TabButton { label: @tr("被ダメ"); active: root.tab == 2; clicked => { root.select-tab(2); } }
                TabButton { label: @tr("履歴"); active: root.tab == 3; clicked => { root.select-tab(3); } }
                drag := TouchArea {
                    horizontal-stretch: 1;
                    mouse-cursor: move;
                    pointer-event(ev) => {
                        if (ev.kind == PointerEventKind.down) {
                            root.start-drag();
                        }
                    }
                    Text {
                        x: parent.width - self.width - 6px;
                        // 狭幅時はラベルを省き値のみ。それでも収まらない幅では隠して
                        // タブへのはみ出し重なりを防ぐ（ドラッグ領域は stretch で潰れ得る）
                        text: root.narrow-header
                            ? root.total-text + "  " + root.elapsed-text
                            : (root.tab == 1 ? @tr("合計HPS") : (root.tab == 2 ? @tr("合計被DPS") : @tr("合計DPS"))) + " " + root.total-text + "   " + @tr("経過") + " " + root.elapsed-text;
                        visible: self.width + 12px <= parent.width;
                        color: #c8c8d8;
                        font-size: 11px * root.font-scale;
                        vertical-alignment: center;
                    }
                }
                // 観測ステータスドット（緑=ゲーム通信受信中 / 青=待機 / 赤=開始失敗 / 灰=起動中）
                Rectangle {
                    width: 12px;
                    Rectangle {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 7px;
                        height: 7px;
                        border-radius: 3.5px;
                        background: root.capture-state == 2 ? #4caf50
                                  : (root.capture-state == 3 ? #e05252
                                  : (root.capture-state == 1 ? #5a8fd8 : #777777));
                    }
                }
                pause-btn := HeaderButton {
                    width: root.narrow-header ? 26px : 40px;
                    label: root.paused ? @tr("再開") : @tr("停止");
                    icon-commands: root.paused ? HeaderIcons.play : HeaderIcons.pause;
                    icon-fill: true;
                    show-icon: root.narrow-header;
                    active: root.paused;
                    clicked => { root.toggle-pause(); }
                }
                reset-btn := HeaderButton {
                    width: root.narrow-header ? 26px : 44px;
                    label: @tr("初期化");
                    icon-commands: HeaderIcons.reset;
                    show-icon: root.narrow-header;
                    clicked => { root.reset-encounter(); }
                }
                // 計測中（kind=2）はカウントダウン M:SS を狭幅でもテキスト表示する
                measure-btn := HeaderButton {
                    width: root.narrow-header
                        ? (root.measure-kind == 2 ? 36px : 26px)
                        : (root.measure-kind == 0 ? 44px : 58px);
                    label: root.measure-kind == 0
                        ? @tr("計測")
                        : (root.measure-kind == 1 ? @tr("待機") : root.measure-text);
                    icon-commands: HeaderIcons.stopwatch;
                    show-icon: root.narrow-header && root.measure-kind != 2;
                    active: root.measure-kind != 0;
                    clicked => { root.toggle-measure(); }
                }
                copy-btn := HeaderButton {
                    width: root.narrow-header ? 26px : 44px;
                    label: root.copied ? @tr("済") : @tr("コピー");
                    icon-commands: root.copied ? HeaderIcons.check : HeaderIcons.copy;
                    show-icon: root.narrow-header;
                    active: root.copied;
                    active-bg: #2e7d32;
                    active-fg: #cdd;
                    clicked => { root.copy-list(); }
                }
                settings-btn := HeaderButton {
                    width: root.narrow-header ? 26px : 36px;
                    label: @tr("設定");
                    icon-commands: HeaderIcons.settings;
                    show-icon: root.narrow-header;
                    active: root.settings-open;
                    active-bg: #ffffff20;
                    active-fg: #cdd;
                    clicked => { root.toggle-settings(); }
                }
                pin-btn := HeaderButton {
                    width: root.narrow-header ? 26px : 36px;
                    label: @tr("前面");
                    icon-commands: HeaderIcons.pin;
                    icon-fill: true;
                    show-icon: root.narrow-header;
                    active: root.aot;
                    // 最前面はデフォルトON＝常時表示状態。警告色の黄ではなく
                    // アクセント色で控えめに示す（設定ボタンと同様の抑えたトーン）。
                    active-bg: #ffffff20;
                    active-fg: Theme.accent;
                    clicked => { root.set-bool("aot", !root.aot); }
                }
                min-btn := TouchArea {
                    width: 26px;
                    clicked => { root.minimize(); }
                    Rectangle {
                        background: min-btn.has-hover ? #ffffff20 : transparent;
                        animate background { duration: 100ms; easing: ease-out; }
                        border-radius: 4px;
                        Text { text: "−"; color: white; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
                quit-btn := TouchArea {
                    width: 26px;
                    clicked => { root.quit(); }
                    Rectangle {
                        background: quit-btn.has-hover ? #c0392b : transparent;
                        animate background { duration: 100ms; easing: ease-out; }
                        border-radius: 4px;
                        Text { text: "×"; color: white; font-size: 12px; }
                    }
                }
            }
        }

        // ── 一覧ビュー（履歴タブ以外・通常列）──
        // 設定/ドリルダウン/履歴から戻った時や初回表示は if が作り直されるため init で毎回フェードイン
        // する。同一インスタンスのままタブだけ切り替わる場合(DPS/回復/被ダメ間)は init が再発火せず
        // 再フェードできないが、opacity を強制的に往復させると中断アニメの重ね掛けで意図しないパルス
        // (0まで落ちきらず点滅して見える)になるだけなので、その場合はフェードなし(即時切替)のまま見送る。
        if !root.settings-open && root.view == 0 && root.tab != 3 && !root.cfg-ui.compact-split: VerticalLayout {
            vertical-stretch: 1;
            property <bool> entered: false;
            opacity: self.entered ? 1.0 : 0.0;
            animate opacity { duration: 140ms; easing: ease-out; }
            init => { self.entered = true; }
            Rectangle {
                height: 16px;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 6px;
                    Text { text: @tr("プレイヤー"); color: #888; font-size: 10px * root.font-scale; horizontal-stretch: 1; min-width: 90px * root.font-scale; vertical-alignment: center; }
                    if root.effective-show-graph-col: Text { text: @tr("推移"); color: #888; font-size: 9px * root.font-scale; width: 60px; horizontal-alignment: center; vertical-alignment: center; }
                    Text {
                        text: root.tab == 1 ? @tr("回復") : (root.tab == 2 ? @tr("被ダメ") : @tr("ダメージ"));
                        color: #888;
                        font-size: 10px * root.font-scale;
                        width: 64px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.tab == 1 ? @tr("HPS") : (root.tab == 2 ? @tr("被DPS") : @tr("DPS"));
                        color: #888;
                        font-size: 10px * root.font-scale;
                        width: 58px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                    Text { text: @tr("%"); color: #888; font-size: 10px * root.font-scale; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.effective-cols.crit: Text { text: @tr("会心率"); color: #888; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.effective-cols.crit-value: Text { text: @tr("会心ダメ率"); color: #888; font-size: 9px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.effective-cols.lucky: Text { text: @tr("幸運率"); color: #888; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.effective-cols.lucky-value: Text { text: @tr("幸運ダメ率"); color: #888; font-size: 9px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.effective-cols.hits: Text { text: @tr("ヒット数"); color: #888; font-size: 9px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.effective-cols.hpm: Text { text: @tr("毎分ヒット数"); color: #888; font-size: 9px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.effective-cols.score: Text { text: @tr("戦力"); color: #888; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    // データ行末尾のウォッチピン(14px)に合わせた見出し用スペーサー（列ズレ防止）
                    Rectangle { width: 14px; }
                }
            }
            Flickable {
                vertical-stretch: 1;
                max-height: 100000px;
                viewport-height: rowbox.preferred-height;
                rowbox := VerticalLayout {
                    for row in root.rows: PlayerRowItem {
                        entry: row;
                        highlight-local: root.highlight-local;
                        cols: root.effective-cols;
                        font-scale: root.font-scale;
                        show-graph-col: root.effective-show-graph-col;
                        show-consumable: root.show-consumable;
                        sync-timer: root.cfg-ui.sync-timer;
                        activate(u) => { root.open-drill(u); }
                        toggle-watch(u) => { root.toggle-watch(u); }
                    }
                    // 空状態: 観測ステータスに応じた案内（初回ユーザーの「動いているのか」を解消）
                    if root.rows.length == 0: VerticalLayout {
                        padding-top: 18px;
                        spacing: 5px;
                        Text {
                            text: root.capture-state == 3 ? @tr("パケット観測の開始に失敗しました")
                                : (root.capture-state == 2 ? @tr("ゲーム通信を検出中") : @tr("ゲーム通信を待機中"));
                            color: root.capture-state == 3 ? #e05252 : #999;
                            font-size: 12px;
                            horizontal-alignment: center;
                        }
                        if root.capture-state != 3: Text {
                            text: @tr("戦闘を開始すると自動的に表示されます");
                            color: #777;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                        if root.capture-state != 3 && root.capture-state != 2: Text {
                            text: @tr("検出されない場合はゾーン移動か再ログインで検出が始まります");
                            color: #666;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                        if root.capture-state != 3 && root.capture-state != 2: Text {
                            text: @tr("VPN / ExitLag / NoPing 等の使用中は検出できないことがあります");
                            color: #666;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                        if root.capture-state == 3: Text {
                            text: @tr("管理者権限で起動しているか確認してください");
                            color: #888;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                        if root.capture-state == 3: Text {
                            text: @tr("WinDivert.dll / WinDivert64.sys が exe と同じフォルダにあるか確認してください");
                            color: #888;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }

        // ── 軽量分割表示（2カラム・履歴タブ以外）──
        // 一覧ビューと同じ理由で init のみによる初回フェードイン(タブ切替自体は即時のまま見送り)。
        if !root.settings-open && root.view == 0 && root.tab != 3 && root.cfg-ui.compact-split: Flickable {
            vertical-stretch: 1;
            max-height: 100000px;
            property <bool> entered: false;
            opacity: self.entered ? 1.0 : 0.0;
            animate opacity { duration: 140ms; easing: ease-out; }
            init => { self.entered = true; }
            viewport-height: csbox.preferred-height;
            csbox := HorizontalLayout {
                spacing: 4px;
                // 左カラム（前半）
                VerticalLayout {
                    horizontal-stretch: 1;
                    Rectangle {
                        height: 16px;
                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 6px;
                            spacing: 5px;
                            Text { text: @tr("プレイヤー"); color: #888; font-size: 10px * root.font-scale; horizontal-stretch: 1; vertical-alignment: center; }
                            Text { text: root.tab == 1 ? @tr("回復") : (root.tab == 2 ? @tr("被ダメ") : @tr("ダメージ")); color: #888; font-size: 10px * root.font-scale; width: 56px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: root.tab == 1 ? @tr("HPS") : (root.tab == 2 ? @tr("被DPS") : @tr("DPS")); color: #888; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                        }
                    }
                    for row in root.compact-left: CompactRowItem {
                        entry: row;
                        highlight-local: root.highlight-local;
                        font-scale: root.font-scale;
                        activate(u) => { root.open-drill(u); }
                    }
                }
                // 右カラム（後半）
                VerticalLayout {
                    horizontal-stretch: 1;
                    Rectangle {
                        height: 16px;
                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 6px;
                            spacing: 5px;
                            Text { text: @tr("プレイヤー"); color: #888; font-size: 10px * root.font-scale; horizontal-stretch: 1; vertical-alignment: center; }
                            Text { text: root.tab == 1 ? @tr("回復") : (root.tab == 2 ? @tr("被ダメ") : @tr("ダメージ")); color: #888; font-size: 10px * root.font-scale; width: 56px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: root.tab == 1 ? @tr("HPS") : (root.tab == 2 ? @tr("被DPS") : @tr("DPS")); color: #888; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                        }
                    }
                    for row in root.compact-right: CompactRowItem {
                        entry: row;
                        highlight-local: root.highlight-local;
                        font-scale: root.font-scale;
                        activate(u) => { root.open-drill(u); }
                    }
                    if root.rows.length == 0: Text { text: @tr("データなし"); color: #666; font-size: 12px; height: 40px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }

        // ── 履歴ビュー ──
        // tab==3 の間だけ存在する専用インスタンス（他タブへ抜けると破棄される）なので、
        // 履歴タブに入るたび init が再発火し自然にフェードインする。
        if !root.settings-open && root.view == 0 && root.tab == 3: VerticalLayout {
            vertical-stretch: 1;
            property <bool> entered: false;
            opacity: self.entered ? 1.0 : 0.0;
            animate opacity { duration: 140ms; easing: ease-out; }
            init => { self.entered = true; }
            Rectangle {
                height: 20px;
                background: #20202e;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 6px;
                    spacing: 6px;
                    Text { text: @tr("履歴"); color: #888; font-size: 10px * root.font-scale; horizontal-stretch: 1; vertical-alignment: center; }
                    clear-btn := TouchArea {
                        width: 70px;
                        clicked => { root.clear-history(); }
                        Rectangle {
                            background: clear-btn.has-hover ? #ffffff20 : #ffffff10;
                            animate background { duration: 100ms; easing: ease-out; }
                            border-radius: 3px;
                            Text { text: @tr("履歴クリア"); color: #cdd; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
            }
            Flickable {
                vertical-stretch: 1;
                max-height: 100000px;
                viewport-height: histbox.preferred-height;
                histbox := VerticalLayout {
                    for h in root.history-rows: HistoryRowItem {
                        e: h;
                        font-scale: root.font-scale;
                        toggle(id) => { root.toggle-history(id); }
                    }
                    if root.history-rows.length == 0: VerticalLayout {
                        padding-top: 18px;
                        spacing: 5px;
                        Text {
                            text: @tr("履歴なし");
                            color: #666;
                            font-size: 12px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: @tr("戦闘が終了すると自動的にここへ記録されます");
                            color: #ffffff60;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }

        // ── スキル内訳ビュー ──
        // 初回オープン(view 0→1)は if が作り直されるため init で毎回フェードイン。被ダメ攻撃元→技別
        // のような同一view内の深掘り遷移は、opacityの往復がパルスになるだけで綺麗なフェードにならない
        // ため見送り（即時切替のまま）。
        if !root.settings-open && root.view == 1: VerticalLayout {
            vertical-stretch: 1;
            property <bool> entered: false;
            opacity: self.entered ? 1.0 : 0.0;
            animate opacity { duration: 140ms; easing: ease-out; }
            init => { self.entered = true; }
            Rectangle {
                height: 20px;
                background: #20202e;
                HorizontalLayout {
                    padding-left: 4px;
                    padding-right: 8px;
                    spacing: 6px;
                    back-btn := TouchArea {
                        width: 56px;
                        clicked => { root.back(); }
                        Rectangle {
                            background: back-btn.has-hover ? #ffffff20 : transparent;
                            animate background { duration: 100ms; easing: ease-out; }
                            border-radius: 4px;
                            Text { text: "← " + @tr("戻る"); color: #cdd; font-size: 11px; }
                        }
                    }
                    Text { text: root.inspected-name; color: #e6e6f0; font-size: 12px * root.font-scale; horizontal-stretch: 1; overflow: elide; vertical-alignment: center; }
                }
            }
            Rectangle {
                height: 16px;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 6px;
                    Text { text: @tr("スキル"); color: #888; font-size: 10px * root.font-scale; horizontal-stretch: 1; vertical-alignment: center; }
                    Text { text: @tr("ダメージ"); color: #888; font-size: 10px * root.font-scale; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: @tr("DPS"); color: #888; font-size: 10px * root.font-scale; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: @tr("%"); color: #888; font-size: 10px * root.font-scale; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
                }
            }
            Flickable {
                vertical-stretch: 1;
                max-height: 100000px;
                viewport-height: skillbox.preferred-height;
                skillbox := VerticalLayout {
                    for s in root.skill-rows: SkillRowItem {
                        entry: s;
                        clickable: root.skills-clickable;
                        font-scale: root.font-scale;
                        activate(u) => { root.drill-row(u); }
                    }
                    if root.skill-rows.length == 0: Text {
                        text: @tr("データなし");
                        color: #666;
                        font-size: 12px;
                        height: 40px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── 設定パネル ──
        // 開閉のたび if が再評価されインスタンスが作り直されるため、init だけで毎回フェードインする。
        if root.settings-open: VerticalLayout {
            vertical-stretch: 1;
            property <bool> entered: false;
            opacity: self.entered ? 1.0 : 0.0;
            animate opacity { duration: 140ms; easing: ease-out; }
            init => { self.entered = true; }
            Rectangle {
                height: 20px;
                background: #20202e;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 6px;
                    Text { text: @tr("設定"); color: #e6e6f0; font-size: 12px; horizontal-stretch: 1; vertical-alignment: center; }
                    close-btn := TouchArea {
                        width: 24px;
                        clicked => { root.toggle-settings(); }
                        Rectangle {
                            background: close-btn.has-hover ? #c0392b : transparent;
                            animate background { duration: 100ms; easing: ease-out; }
                            border-radius: 4px;
                            Text { text: "×"; color: white; font-size: 11px; }
                        }
                    }
                }
            }
            // Flickable 単体だとスクロールバーが無く、下に続くコンテンツの存在に気付けない。
            // Rectangle でラップし、スクロール可能な残量があるときだけ下端にグラデーション＋
            // 下向きシェブロンを重ねて示す（状態依存の静的表示・アニメ無し）。
            Rectangle {
                vertical-stretch: 1;
                clip: true;
                settings-flick := Flickable {
                    width: 100%;
                    height: 100%;
                    // ピッカー ドラッグ中はスクロールを無効化（ドラッグのグラブ奪取を防ぐ）。
                    interactive: !root.picker-dragging;
                    viewport-height: setbox.preferred-height;
                    // 横は Flickable 幅に固定（横スクロール無効＝内側の列レイアウトが窓幅へ
                    // 逆流しないようにし、set-cols(root.width依存) との binding loop を断つ）
                    viewport-width: self.width;
                    setbox := VerticalLayout {
                    padding: 4px;
                    spacing: 8px;
                    // 横の layoutinfo を定数化し、列数(set-cols)→窓幅→set-cols の binding loop を断つ。
                    // 実幅は親 Flickable の viewport-width(=自幅)で決まるので各値は表示に影響しない。
                    min-width: 0px;
                    preferred-width: 0px;
                    max-width: 100000px;
                    // ── 設定セクションのレスポンシブ多列グリッド（窓幅で 1/2/3 列）──
                    // 8セクションを scol(i) で各カラムへ振り分け。同じ定義を列ごとに条件配置する。
                    HorizontalLayout {
                        spacing: 8px;
                        // ── 列0 ──
                        VerticalLayout {
                            horizontal-stretch: 1;
                            // preferred 幅を内容非依存(0)にして全カラムを完全な等幅にする。
                            // （内容の preferred 差で stretch 配分が偏り、表示列が狭くなるのを防ぐ）
                            min-width: 0px;
                            preferred-width: 0px;
                            alignment: start; // 上詰め（カラム間の高さ差で見出し直下に隙間が出るのを防ぐ）
                            spacing: 8px; // カード間の縦余白（セクション境界）
                            if root.scol(0) == 0: CharacterSection { uid-value: root.selected-uid-value; uid-name: root.selected-uid-name; candidates: root.uid-candidates; set-uid(u) => { root.set-selected-uid(u); } }
                            if root.scol(1) == 0: DisplayColsSection { cfg: root.cfg-ui; set-bool(k, v) => { root.set-bool(k, v); } }
                            if root.scol(2) == 0: DisplaySection { cfg: root.cfg-ui; nums: root.nums; accent-h: root.accent-h; accent-s: root.accent-s; accent-v: root.accent-v; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } pick-accent(h, s, v) => { root.pick-accent(h, s, v); } picker-dragging-changed(d) => { root.picker-dragging = d; } }
                            if root.scol(3) == 0: OverlaySection { cfg: root.cfg-ui; nums: root.nums; overlay-opacity: root.overlay-opacity; text-h: root.overlay-text-h; text-s: root.overlay-text-s; text-v: root.overlay-text-v; set-bool(k, v) => { root.set-bool(k, v); } set-overlay-opacity(v) => { root.set-overlay-opacity(v); } pick-text(h, s, v) => { root.pick-overlay-text(h, s, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } picker-dragging-changed(d) => { root.picker-dragging = d; } }
                            if root.scol(4) == 0: CombatSection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                            if root.scol(5) == 0: HistorySection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                            if root.scol(7) == 0: ImagineTimerSection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } clear-watchlist => { root.clear-watchlist(); } }
                            if root.scol(6) == 0: StatsSection { cfg: root.cfg-ui; nums: root.nums; catalog-left: root.stat-catalog-left; catalog-right: root.stat-catalog-right; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } }
                        }
                        // ── 列1（2列以上のとき）──
                        if root.set-cols >= 2: VerticalLayout {
                            horizontal-stretch: 1;
                            min-width: 0px;
                            preferred-width: 0px;
                            alignment: start;
                            spacing: 8px; // カード間の縦余白（セクション境界）
                            if root.scol(0) == 1: CharacterSection { uid-value: root.selected-uid-value; uid-name: root.selected-uid-name; candidates: root.uid-candidates; set-uid(u) => { root.set-selected-uid(u); } }
                            if root.scol(1) == 1: DisplayColsSection { cfg: root.cfg-ui; set-bool(k, v) => { root.set-bool(k, v); } }
                            if root.scol(2) == 1: DisplaySection { cfg: root.cfg-ui; nums: root.nums; accent-h: root.accent-h; accent-s: root.accent-s; accent-v: root.accent-v; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } pick-accent(h, s, v) => { root.pick-accent(h, s, v); } picker-dragging-changed(d) => { root.picker-dragging = d; } }
                            if root.scol(3) == 1: OverlaySection { cfg: root.cfg-ui; nums: root.nums; overlay-opacity: root.overlay-opacity; text-h: root.overlay-text-h; text-s: root.overlay-text-s; text-v: root.overlay-text-v; set-bool(k, v) => { root.set-bool(k, v); } set-overlay-opacity(v) => { root.set-overlay-opacity(v); } pick-text(h, s, v) => { root.pick-overlay-text(h, s, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } picker-dragging-changed(d) => { root.picker-dragging = d; } }
                            if root.scol(4) == 1: CombatSection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                            if root.scol(5) == 1: HistorySection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                            if root.scol(7) == 1: ImagineTimerSection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } clear-watchlist => { root.clear-watchlist(); } }
                            if root.scol(6) == 1: StatsSection { cfg: root.cfg-ui; nums: root.nums; catalog-left: root.stat-catalog-left; catalog-right: root.stat-catalog-right; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } }
                        }
                        // ── 列2（3列のとき）──
                        if root.set-cols >= 3: VerticalLayout {
                            horizontal-stretch: 1;
                            min-width: 0px;
                            preferred-width: 0px;
                            alignment: start;
                            spacing: 8px; // カード間の縦余白（セクション境界）
                            if root.scol(0) == 2: CharacterSection { uid-value: root.selected-uid-value; uid-name: root.selected-uid-name; candidates: root.uid-candidates; set-uid(u) => { root.set-selected-uid(u); } }
                            if root.scol(1) == 2: DisplayColsSection { cfg: root.cfg-ui; set-bool(k, v) => { root.set-bool(k, v); } }
                            if root.scol(2) == 2: DisplaySection { cfg: root.cfg-ui; nums: root.nums; accent-h: root.accent-h; accent-s: root.accent-s; accent-v: root.accent-v; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } pick-accent(h, s, v) => { root.pick-accent(h, s, v); } picker-dragging-changed(d) => { root.picker-dragging = d; } }
                            if root.scol(3) == 2: OverlaySection { cfg: root.cfg-ui; nums: root.nums; overlay-opacity: root.overlay-opacity; text-h: root.overlay-text-h; text-s: root.overlay-text-s; text-v: root.overlay-text-v; set-bool(k, v) => { root.set-bool(k, v); } set-overlay-opacity(v) => { root.set-overlay-opacity(v); } pick-text(h, s, v) => { root.pick-overlay-text(h, s, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } picker-dragging-changed(d) => { root.picker-dragging = d; } }
                            if root.scol(4) == 2: CombatSection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                            if root.scol(5) == 2: HistorySection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                            if root.scol(7) == 2: ImagineTimerSection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } clear-watchlist => { root.clear-watchlist(); } }
                            if root.scol(6) == 2: StatsSection { cfg: root.cfg-ui; nums: root.nums; catalog-left: root.stat-catalog-left; catalog-right: root.stat-catalog-right; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } }
                        }
                    }
                    // ── 不透明度（常に全幅。2列以上のときは複数列ぶんの横幅で操作しやすく）──
                    SectionCard {
                        title: @tr("ウィンドウ");
                        OpacityRow { value: root.win-opacity; changed(v) => { root.set-opacity(v); } }
                    }
                    // ── テンプレート（常に全幅）──
                    SectionCard {
                        title: @tr("テンプレート");
                        TemplateField {
                            label: @tr("名前列テンプレ");
                            value: root.name-template-value;
                            preview: root.name-preview;
                            hint: "{name} {class} {spec} {score} {seasonLv} {seasonStr} {imagine}";
                            changed(t) => { root.set-str("name-template", t); }
                            reset => { root.reset-str("name-template"); }
                        }
                        TemplateField {
                            label: @tr("コピーテンプレ");
                            value: root.copy-template-value;
                            preview: root.copy-preview;
                            hint: "{rank} {name} {class} {spec} {dmg} {dps} {pct} {crit} {critV} {lucky} {luckyV} {hits} {hpm} {score} {seasonLv} {seasonStr}";
                            changed(t) => { root.set-str("copy-template", t); }
                            reset => { root.reset-str("copy-template"); }
                        }
                    }
                    // ── バトルイマジン名メンテ（本体は別ウィンドウ。ここは起動ボタンのみ・常に全幅）──
                    ImagineNamesOpenSection {
                        open-window => { root.imagine-open-window(); }
                    }
                    // ── バージョン情報（設定パネル最下部）──
                    Text {
                        text: root.app-version;
                        color: SettingsStyle.sub-label;
                        font-size: SettingsStyle.sub-label-size;
                        horizontal-alignment: center;
                    }
                }
                }
                // 下端グラデーション＋シェブロン（まだ下にスクロール可能なコンテンツがある間だけ表示）。
                // Flickable の viewport-y は 0 以下（下スクロールで負に増える）。
                // 「表示済みの一番下」が総コンテンツ高に届いていなければスクロール余地ありと判定する。
                if (-settings-flick.viewport-y + settings-flick.height) < (settings-flick.viewport-height - 0.5px): Rectangle {
                    x: 0;
                    y: parent.height - self.height;
                    width: parent.width;
                    height: 24px;
                    background: @linear-gradient(180deg, #14141e00 0%, #14141ee6 100%);
                    Path {
                        x: (parent.width - self.width) / 2;
                        y: parent.height - self.height - 4px;
                        width: 10px;
                        height: 6px;
                        viewbox-width: 10;
                        viewbox-height: 6;
                        commands: "M 0.5 0.5 L 5 5 L 9.5 0.5";
                        stroke: #ffffffaa;
                        stroke-width: 1.4px;
                        fill: transparent;
                    }
                }
            }
        }
    }

    // ── リサイズハンドル（縁/角ドラッグでサイズ変更）。縁6px・角14px ──
    ResizeHandle { dir: 0; mouse-cursor: ns-resize; resize(d) => { root.start-resize(d); } x: 14px; y: 0; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 1; mouse-cursor: ns-resize; resize(d) => { root.start-resize(d); } x: 14px; y: root.height - 6px; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 2; mouse-cursor: ew-resize; resize(d) => { root.start-resize(d); } x: root.width - 6px; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 3; mouse-cursor: ew-resize; resize(d) => { root.start-resize(d); } x: 0; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 5; mouse-cursor: nwse-resize; resize(d) => { root.start-resize(d); } x: 0; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 4; mouse-cursor: nesw-resize; resize(d) => { root.start-resize(d); } x: root.width - 14px; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 7; mouse-cursor: nesw-resize; resize(d) => { root.start-resize(d); } x: 0; y: root.height - 14px; width: 14px; height: 14px; }
    ResizeHandle { dir: 6; mouse-cursor: nwse-resize; resize(d) => { root.start-resize(d); } x: root.width - 14px; y: root.height - 14px; width: 14px; height: 14px; }

    // ── 3分計測 結果モーダル（最上層・背景クリックで閉じる）──
    if root.result-open: Rectangle {
        width: 100%;
        height: 100%;
        background: #000000cc;
        backdrop := TouchArea { clicked => { root.close-result(); } }
        result-card := Rectangle {
            x: 12px;
            // 開いた瞬間の入場演出（フェード＋わずかな上方スライド）。init で1度だけ
            // entered を立てて animate に任せる＝恒常アニメではなく一過性のみ。
            property <bool> entered: false;
            y: self.entered ? 12px : 2px;
            width: parent.width - 24px;
            height: parent.height - 24px;
            opacity: self.entered ? 1.0 : 0.0;
            animate y, opacity { duration: 160ms; easing: ease-out; }
            init => { self.entered = true; }
            background: #14141ef7;
            border-width: 1px;
            border-color: #ffffff26;
            border-radius: 8px;
            // カード内クリックを吸収し背景の close へ落とさない
            TouchArea {}
            VerticalLayout {
                padding: 12px;
                spacing: 8px;
                // ヘッダー行（常に固定表示）
                HorizontalLayout {
                    Text { text: @tr("計測結果"); color: Theme.accent; font-size: 13px; horizontal-stretch: 1; vertical-alignment: center; }
                    rclose := TouchArea {
                        width: 24px;
                        clicked => { root.close-result(); }
                        Rectangle {
                            background: rclose.has-hover ? #c0392b : transparent;
                            animate background { duration: 100ms; easing: ease-out; }
                            border-radius: 4px;
                            Text { text: "×"; color: white; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
                // サマリ（総合DPS/総ダメ/計測時間/自己ベスト）はヘッダー直下（常に固定表示）
                HorizontalLayout {
                    spacing: 22px;
                    VerticalLayout {
                        spacing: 1px;
                        Text { text: "DPS"; color: #888; font-size: 10px; }
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            Text { text: root.result-dps; color: Theme.accent; font-size: 14px; vertical-alignment: center; }
                            if root.result-is-new-record: NewRecordBadge {}
                        }
                    }
                    VerticalLayout { spacing: 1px; Text { text: @tr("総ダメ"); color: #888; font-size: 10px; } Text { text: root.result-dmg; color: #e6e6f0; font-size: 14px; } }
                    VerticalLayout { spacing: 1px; Text { text: @tr("計測時間"); color: #888; font-size: 10px; } Text { text: root.result-duration; color: #e6e6f0; font-size: 14px; } }
                    if root.result-best-dps-text != "": VerticalLayout {
                        spacing: 1px;
                        Text { text: @tr("自己ベスト"); color: #888; font-size: 10px; }
                        Text { text: root.result-best-dps-text; color: #999; font-size: 12px; }
                    }
                }
                // ── スクロール領域: エリア1〜4。低いウィンドウでは縦スクロール、十分な高さでは
                // 今まで通り 30/50/20 の比率で伸縮する（Flickable 自体の最小高さは0のため、
                // ヘッダー/サマリ/アクション行を押し出さない＝それらは常に画面内に残る）。
                res-scroll := Flickable {
                    vertical-stretch: 1;
                    max-height: 100000px;
                    viewport-height: res-content.height;
                    res-content := VerticalLayout {
                        height: Math.max(res-scroll.height, res-content.preferred-height);
                        spacing: 8px;
                        // ── エリア1（フル幅）: 選択キャラ折れ線ラベル ＋ キャラ一覧（最大5・3行超は縦スクロール）＋ 累積合計ダメージ折れ線 ──
                        VerticalLayout {
                            vertical-stretch: 30;
                            spacing: 4px;
                            // キャラ一覧（高さ≒3行ぶん。超過は縦スクロール）
                            Rectangle {
                                height: 58px;
                                Flickable {
                                    width: 100%;
                                    height: 100%;
                                    viewport-height: charbox.preferred-height;
                                    charbox := VerticalLayout {
                                        spacing: 2px;
                                        for r in root.result-rows: ResultRow { e: r; activate(u) => { root.select-result-player(u); } }
                                        if root.result-rows.length == 0: Text { text: @tr("ダメージなし"); color: #555; font-size: 11px; height: 30px; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                            }
                            // 選択キャラの区間DPS折れ線ラベル
                            Text {
                                text: root.result-char-name == "" ? @tr("DPS推移") : @tr("DPS推移") + " — " + root.result-char-name;
                                color: #888;
                                font-size: 10px;
                                overflow: elide;
                            }
                            // 選択キャラの区間DPS折れ線（残り高さいっぱい・左にY軸目安）
                            SparkGraph {
                                vertical-stretch: 1;
                                visible-graph: root.result-char-spark-visible;
                                commands: root.result-char-spark;
                                resized(w, h) => { root.result-char-spark-resized(w, h); }
                                line-color: Theme.accent;
                                axis-top: root.result-char-axis-top;
                                axis-mid: root.result-char-axis-mid;
                                duration-ms: root.result-duration-ms;
                                empty-text: "";
                            }
                        }
                        // ── 中段: エリア2(65%)＝スキル内訳 ｜ エリア3(35%)＝円グラフ ──
                        HorizontalLayout {
                            vertical-stretch: 50;
                            spacing: 8px;
                            // エリア2（65%）: スキル内訳（残り高さいっぱい・超過は縦スクロール）
                            VerticalLayout {
                                horizontal-stretch: 0.65;
                                spacing: 4px;
                                Text { text: root.result-pie-title; color: #cdd; font-size: 10px; overflow: elide; }
                                Rectangle {
                                    vertical-stretch: 1;
                                    Flickable {
                                        width: 100%;
                                        height: 100%;
                                        viewport-height: resskillbox.preferred-height;
                                        resskillbox := VerticalLayout {
                                            spacing: 2px;
                                            for s in root.result-skill-rows: ResultSkillRow { e: s; activate(u) => { root.select-result-skill(u); } }
                                            if root.result-skill-rows.length == 0: Text { text: @tr("スキルなし"); color: #555; font-size: 11px; height: 30px; horizontal-alignment: center; vertical-alignment: center; }
                                        }
                                    }
                                }
                            }
                            // エリア3（35%）: TOP10＋その他 の円グラフ＋凡例
                            VerticalLayout {
                                horizontal-stretch: 0.35;
                                spacing: 4px;
                                // 円グラフ（領域内に収まる正方形。区切り線は灰色で外周に届かない）。
                                // 凡例より高さ配分を多めにして円を大きく見せる（円:凡例 = 2:1）。
                                pie-col := Rectangle {
                                    vertical-stretch: 2;
                                    property <length> sz: self.width < self.height ? self.width : self.height;
                                    Rectangle {
                                        width: pie-col.sz;
                                        height: pie-col.sz;
                                        x: (pie-col.width - pie-col.sz) / 2;
                                        y: (pie-col.height - pie-col.sz) / 2;
                                        for slice in root.result-pie: Path {
                                            width: 100%;
                                            height: 100%;
                                            viewbox-x: 0;
                                            viewbox-y: 0;
                                            viewbox-width: 100;
                                            viewbox-height: 100;
                                            commands: slice.commands;
                                            fill: slice.is-line ? transparent : slice.color;
                                            stroke: slice.is-line ? #8a8a8acc : transparent;
                                            stroke-width: slice.is-line ? 1px : 0px;
                                        }
                                    }
                                }
                                // 凡例（スキル名＋同色＋割合）
                                Flickable {
                                    vertical-stretch: 1;
                                    max-height: 100000px;
                                    viewport-height: legbox.preferred-height;
                                    legbox := VerticalLayout {
                                        spacing: 1px;
                                        for lg in root.result-legend: HorizontalLayout {
                                            spacing: 4px;
                                            height: 14px;
                                            VerticalLayout { alignment: center; Rectangle { width: 8px; height: 8px; background: lg.color; border-radius: 2px; } }
                                            Text { text: lg.name; color: #bbb; font-size: 9px; overflow: elide; horizontal-stretch: 1; vertical-alignment: center; }
                                            Text { text: lg.pct-text; color: #888; font-size: 9px; vertical-alignment: center; }
                                        }
                                    }
                                }
                            }
                        }
                        // ── エリア4（フル幅）: 選択スキル折れ線ラベル ＋ 区間DPS折れ線 ──
                        VerticalLayout {
                            vertical-stretch: 20;
                            spacing: 4px;
                            Text {
                                text: root.result-skill-name == "" ? @tr("スキルDPS推移") : @tr("スキルDPS推移") + " — " + root.result-skill-name;
                                color: #888;
                                font-size: 10px;
                                overflow: elide;
                            }
                            SparkGraph {
                                vertical-stretch: 1;
                                visible-graph: root.result-skill-spark-visible;
                                commands: root.result-skill-spark;
                                resized(w, h) => { root.result-skill-spark-resized(w, h); }
                                line-color: #66bb6a;
                                axis-top: root.result-skill-axis-top;
                                axis-mid: root.result-skill-axis-mid;
                                duration-ms: root.result-duration-ms;
                                empty-text: @tr("スキルを選択");
                            }
                        }
                    }
                }
                // アクション行（常に固定表示）
                HorizontalLayout {
                    spacing: 8px;
                    // 透かし（画像コピーに写り込む小さなクレジット）。stretch で余白を吸収しボタンを右寄せ
                    Text {
                        text: root.result-watermark;
                        color: #555;
                        font-size: 9px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    copy-img-r := TouchArea {
                        width: 76px;
                        height: 24px;
                        clicked => { root.copy-result-image(); }
                        Rectangle { background: root.result-img-copied ? #2e7d32 : (copy-img-r.has-hover ? #ffffff20 : #ffffff10); animate background { duration: 100ms; easing: ease-out; } border-radius: 4px; Text { text: root.result-img-copied ? @tr("済") : @tr("画像コピー"); color: #ccc; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; } }
                    }
                    copy-r := TouchArea {
                        width: 64px;
                        height: 24px;
                        clicked => { root.copy-result(); }
                        Rectangle { background: copy-r.has-hover ? #ffffff20 : #ffffff10; animate background { duration: 100ms; easing: ease-out; } border-radius: 4px; Text { text: @tr("コピー"); color: #ccc; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; } }
                    }
                    restart-r := TouchArea {
                        width: 64px;
                        height: 24px;
                        clicked => { root.restart-measure(); }
                        Rectangle { background: restart-r.has-hover ? #ffffff20 : #ffffff10; animate background { duration: 100ms; easing: ease-out; } border-radius: 4px; Text { text: @tr("再計測"); color: #ccc; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; } }
                    }
                    closebtn-r := TouchArea {
                        width: 64px;
                        height: 24px;
                        clicked => { root.close-result(); }
                        Rectangle { background: closebtn-r.has-hover ? Theme.accent.with-alpha(0.2) : Theme.accent.with-alpha(0.133); animate background { duration: 100ms; easing: ease-out; } border-width: 1px; border-color: Theme.accent.with-alpha(0.45); border-radius: 4px; Text { text: @tr("閉じる"); color: Theme.accent; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; } }
                    }
                }
            }
        }
    }
}

// ─── 自キャラ バフ/デバフ オーバーレイ ───────────────────────────────
struct StatusEntryUi {
    name: string,
    remaining-text: string,
    bar-ratio: float,
    bar-color: color,
    layer-text: string,
    is-low: bool,
    border-color: color,
}

// no-frame オーバーレイ右上の閉じるボタン。クリックで設定トグルOFFと連動して窓を隠す。
// Dingbats を避け Latin-1「×」を使用（CLAUDE.md）。最後の子＝最上層に置き縁リサイズより優先。
component OverlayCloseButton inherits TouchArea {
    callback close();
    width: 16px;
    height: 14px;
    mouse-cursor: pointer;
    clicked => { root.close(); }
    Rectangle {
        background: root.has-hover ? #c0392b : #ffffff14;
        animate background { duration: 100ms; easing: ease-out; }
        border-radius: 3px;
        Text { text: "×"; color: white; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
    }
}

// オーバーレイの最小化ボタン（タスクバー常駐モード時のみ表示・OS最小化でタスクバーへ）
component OverlayMinButton inherits TouchArea {
    callback minimize();
    width: 16px;
    height: 14px;
    mouse-cursor: pointer;
    clicked => { root.minimize(); }
    Rectangle {
        background: root.has-hover ? #ffffff33 : #ffffff14;
        animate background { duration: 100ms; easing: ease-out; }
        border-radius: 3px;
        Text { text: "−"; color: white; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
    }
}

// HUD テキストの装飾フラグ（縁取り/影を個別に切替）。設定の「縁取り」「影」チェックに対応。
struct HudFx {
    outline: bool,  // 縁取り（stroke）を描くか
    shadow: bool,   // ドロップシャドウを描くか
}

// オーバーレイ用テキスト: 縁取り(stroke)＋ドロップシャドウで背景非依存の視認性を確保する。
// 透明/半透明オーバーレイの文字はゲーム画面（明→暗→極彩色と変動）に直接乗るため、単色では必ず
// どこかのシーンで埋もれる。fx 有効時は暗い輪郭＋影で「色に依らず」浮かせる。Text を 2 枚重ねる
// （影＝下にずらした暗いコピー / 本体＝stroke 付き）。レイアウト挙動は素の Text と等価になるよう
// preferred/min を本体テキストへ委譲する。font-family/weight は Window の default を継承。
component HudText inherits Rectangle {
    in property <string> text;
    in property <brush> text-color: white;             // 文字色（Rectangle.color 非推奨と衝突するため別名）
    in property <length> font-size;
    in property <TextHorizontalAlignment> horizontal-alignment: left;
    in property <TextVerticalAlignment> vertical-alignment: center;
    in property <TextOverflow> overflow: clip;
    in property <HudFx> fx: { outline: true, shadow: true }; // 縁取り/影を個別に切替（既定とも ON）
    in property <brush> outline-color: #000000b3;      // 縁取り色（暗・やや薄め。濃すぎると重く見えるため）
    in property <brush> shadow-color: #00000099;       // 影色（暗・半透明）
    // 縁取り幅は font-size 追従（大きい文字でも比率一定）。影は 1px 固定で十分。
    property <length> sw: root.font-size * 0.10;

    preferred-width: main.preferred-width;
    preferred-height: main.preferred-height;
    min-height: main.min-height;

    // 影（右下 1px の暗いコピー・本体の下に描画）
    Text {
        x: root.fx.shadow ? 1px : 0px;
        y: root.fx.shadow ? 1px : 0px;
        width: root.width;
        height: root.height;
        text: root.text;
        color: root.fx.shadow ? root.shadow-color : transparent;
        font-size: root.font-size;
        horizontal-alignment: root.horizontal-alignment;
        vertical-alignment: root.vertical-alignment;
        overflow: root.overflow;
    }
    main := Text {
        width: root.width;
        height: root.height;
        text: root.text;
        color: root.text-color;
        font-size: root.font-size;
        horizontal-alignment: root.horizontal-alignment;
        vertical-alignment: root.vertical-alignment;
        overflow: root.overflow;
        stroke: root.fx.outline ? root.outline-color : transparent;
        stroke-width: root.fx.outline ? root.sw : 0px;
        stroke-style: outside;
    }
}

component StatusRow inherits Rectangle {
    in property <StatusEntryUi> e;
    in property <float> font-scale: 1.0;
    in property <color> text-base: #ffffff;
    in property <bool> hud-mode; // 完全透明(HUD)時は枠/背景チップ/バー溝を消し、文字と色付きバーのみ残す
    in property <HudFx> fx;       // 縁取り＋影（低不透明度時に視認性確保）
    // 行高・各列幅は font-scale に追従（大きいフォントで行内テキストの行高が固定行高を超え、
    // elide 指定のラベルが縦に収まらず丸ごと消えるのを防ぐ）。
    height: 16px * root.font-scale;
    border-width: root.hud-mode ? 0px : 1px;
    border-color: root.e.border-color;
    border-radius: 3px;
    background: root.hud-mode ? transparent : #00000059;
    HorizontalLayout {
        padding-left: 5px;
        padding-right: 5px;
        spacing: 5px;
        HudText { text: root.e.name; text-color: root.text-base.with-alpha(0.85); font-size: 9px * root.font-scale; overflow: elide; horizontal-stretch: 1; min-width: 56px * root.font-scale; vertical-alignment: center; fx: root.fx; }
        VerticalLayout {
            alignment: center;
            width: 64px * root.font-scale;
            Rectangle {
                height: 4px;
                background: root.hud-mode ? transparent : #ffffff1f;
                border-radius: 2px;
                Rectangle { x: 0; width: parent.width * root.e.bar-ratio; height: 100%; background: root.e.bar-color; border-radius: 2px; }
            }
        }
        HudText { text: root.e.layer-text; text-color: root.text-base.with-alpha(0.45); font-size: 8px * root.font-scale; width: 22px * root.font-scale; vertical-alignment: center; fx: root.fx; }
        HudText { text: root.e.remaining-text; text-color: root.e.is-low ? #ff7043 : root.text-base.with-alpha(0.90); font-size: 9px * root.font-scale; width: 36px * root.font-scale; horizontal-alignment: right; vertical-alignment: center; fx: root.fx; }
    }
}

export component SelfStatusOverlay inherits Window {
    in property <[StatusEntryUi]> buffs;
    in property <[StatusEntryUi]> debuffs;
    in property <bool> waiting;
    // 文字の縁取り/影（設定の「縁取り」「影」チェックから Rust が設定。低不透明度・透明 HUD で文字を浮かせる）。
    in property <bool> overlay-outline: true;
    in property <bool> overlay-shadow: false;
    property <HudFx> fx: { outline: root.overlay-outline, shadow: root.overlay-shadow };
    in property <float> font-scale: 1.0; // メインの font_size に連動
    in property <bool> show-minimize; // タスクバー常駐モード時のみ最小化ボタンを出す
    in property <float> overlay-opacity: 0.82;        // 背景不透明度（メインとは独立）
    in property <string> overlay-font: "Yu Gothic UI"; // フォントファミリ
    in property <bool> overlay-font-bold;              // 太字（既定オフ）
    in property <color> text-base: #ffffff;            // 基準テキスト色（Rust が解決して設定。白系ラベル/値のみ再着色）
    callback start-drag();
    callback start-resize(int);
    callback close-window();
    callback minimize();

    title: @tr("自キャラ バフ/デバフ表示");
    default-font-family: root.overlay-font;
    default-font-weight: root.overlay-font-bold ? 700 : 400;
    no-frame: true;
    always-on-top: true;
    // 完全透明時は `transparent`(#00000000) を使う。femtovg 透明窓は背景色の RGB を alpha=0 でも
    // 加算で漏らすため、#0a0a12.with-alpha(0) だと窓全体に +#0a0a12 の被膜が残る（RGB=0 なら漏れ 0）。
    background: root.overlay-opacity <= 0.001 ? transparent : #0a0a12.with-alpha(root.overlay-opacity);
    preferred-width: 220px;
    preferred-height: 180px;

    // 全面ドラッグ（外周フレーム相当）
    drag := TouchArea {
        mouse-cursor: move;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down) {
                root.start-drag();
            }
        }
    }
    VerticalLayout {
        padding-left: 8px;
        padding-right: 8px;
        padding-bottom: 8px;
        // 上部はヘッダー帯ぶんの余白を確保（完全透明時はヘッダーごと消すので詰める）
        padding-top: root.overlay-opacity > 0.001 ? 20px : 0px;
        spacing: 3px;
        alignment: start; // 上詰め（既定stretchだと余白分配で下寄り/間延びする）
        if root.waiting: HudText { text: @tr("自キャラ判定中..."); text-color: root.text-base.with-alpha(0.30); font-size: 10px * root.font-scale; horizontal-alignment: center; fx: root.fx; }
        if !root.waiting && root.buffs.length == 0 && root.debuffs.length == 0: HudText { text: @tr("バフ/デバフなし"); text-color: root.text-base.with-alpha(0.30); font-size: 10px * root.font-scale; horizontal-alignment: center; fx: root.fx; }
        if !root.waiting && root.buffs.length > 0: HudText { text: @tr("バフ"); text-color: root.text-base.with-alpha(0.40); font-size: 9px * root.font-scale; fx: root.fx; }
        for b in root.buffs: StatusRow { e: b; font-scale: root.font-scale; text-base: root.text-base; hud-mode: root.overlay-opacity <= 0.001; fx: root.fx; }
        if !root.waiting && root.debuffs.length > 0: HudText { text: @tr("デバフ"); text-color: root.text-base.with-alpha(0.40); font-size: 9px * root.font-scale; fx: root.fx; }
        for d in root.debuffs: StatusRow { e: d; font-scale: root.font-scale; text-base: root.text-base; hud-mode: root.overlay-opacity <= 0.001; fx: root.fx; }
    }
    // 縁ドラッグでリサイズ（最前面・最後の子＝最上層で縁イベントを捕捉）
    ResizeEdges { width: 100%; height: 100%; resize(d) => { root.start-resize(d); } }
    // ヘッダーの操作ボタン（ResizeEdges より後＝最上層で右上角クリックを優先）。
    // 上部のヘッダー帯（padding-top）に収まり、完全透明時はヘッダーごと非描画にする。
    if root.overlay-opacity > 0.001 && root.show-minimize: OverlayMinButton { x: root.width - 2 * self.width - 6px; y: 2px; minimize => { root.minimize(); } }
    if root.overlay-opacity > 0.001: OverlayCloseButton { x: root.width - self.width - 2px; y: 2px; close => { root.close-window(); } }
}

// ─── 自キャラ ステータス オーバーレイ（攻撃力/会心/HP 等のリアルタイム表示）──────
component StatValueRow inherits Rectangle {
    in property <StatEntryUi> e;
    in property <float> font-scale: 1.0;
    in property <color> text-base: #ffffff;
    in property <HudFx> fx;       // 縁取り＋影（低不透明度時に視認性確保）
    // 行高は font-scale に追従（固定 17px だと大きいフォントで行が縦に収まらず、
    // elide 指定のラベルが丸ごと消える）。
    height: 17px * root.font-scale;
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 8px;
        HudText { text: root.e.label; text-color: root.text-base.with-alpha(0.90); font-size: 10px * root.font-scale; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; fx: root.fx; }
        HudText { text: root.e.value; text-color: root.e.accent ? Theme.accent : root.text-base.with-alpha(0.90); font-size: 10px * root.font-scale; vertical-alignment: center; horizontal-alignment: right; fx: root.fx; }
    }
}

export component StatsOverlay inherits Window {
    in property <[StatEntryUi]> stats;
    in property <bool> waiting;
    // 文字の縁取り/影（設定の「縁取り」「影」チェックから Rust が設定。低不透明度・透明 HUD で文字を浮かせる）。
    in property <bool> overlay-outline: true;
    in property <bool> overlay-shadow: false;
    property <HudFx> fx: { outline: root.overlay-outline, shadow: root.overlay-shadow };
    in property <float> font-scale: 1.0; // メインの font_size に連動
    in property <bool> show-minimize;    // タスクバー常駐モード時のみ最小化ボタンを出す
    in property <float> overlay-opacity: 0.82;        // 背景不透明度（メインとは独立）
    in property <string> overlay-font: "Yu Gothic UI"; // フォントファミリ
    in property <bool> overlay-font-bold;              // 太字（既定オフ）
    in property <color> text-base: #ffffff;            // 基準テキスト色（Rust が解決して設定。白系ラベル/値のみ再着色）
    callback start-drag();
    callback start-resize(int);
    callback close-window();
    callback minimize();

    title: @tr("自キャラ ステータス");
    default-font-family: root.overlay-font;
    default-font-weight: root.overlay-font-bold ? 700 : 400;
    no-frame: true;
    always-on-top: true;
    // 完全透明時は `transparent`(#00000000) を使う。femtovg 透明窓は背景色の RGB を alpha=0 でも
    // 加算で漏らすため、#0a0a12.with-alpha(0) だと窓全体に +#0a0a12 の被膜が残る（RGB=0 なら漏れ 0）。
    background: root.overlay-opacity <= 0.001 ? transparent : #0a0a12.with-alpha(root.overlay-opacity);
    preferred-width: 200px;
    preferred-height: 220px;

    // 全面ドラッグ（外周フレーム相当）
    drag := TouchArea {
        mouse-cursor: move;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down) {
                root.start-drag();
            }
        }
    }
    VerticalLayout {
        padding-left: 8px;
        padding-right: 8px;
        padding-bottom: 8px;
        // 上部はヘッダー帯ぶんの余白を確保（完全透明時はヘッダーごと消すので詰める）
        padding-top: root.overlay-opacity > 0.001 ? 20px : 0px;
        spacing: 2px;
        alignment: start; // 上詰め
        if root.waiting: HudText { text: @tr("自キャラ判定中..."); text-color: root.text-base.with-alpha(0.30); font-size: 10px * root.font-scale; horizontal-alignment: center; fx: root.fx; }
        if !root.waiting && root.stats.length == 0: HudText { text: @tr("表示項目なし"); text-color: root.text-base.with-alpha(0.30); font-size: 10px * root.font-scale; horizontal-alignment: center; fx: root.fx; }
        for s in root.stats: StatValueRow { e: s; font-scale: root.font-scale; text-base: root.text-base; fx: root.fx; }
    }
    // 縁ドラッグでリサイズ（最前面・最後の子＝最上層で縁イベントを捕捉）
    ResizeEdges { width: 100%; height: 100%; resize(d) => { root.start-resize(d); } }
    // ヘッダーの操作ボタン（ResizeEdges より後＝最上層で右上角クリックを優先）。
    // 上部のヘッダー帯（padding-top）に収まり、完全透明時はヘッダーごと非描画にする。
    if root.overlay-opacity > 0.001 && root.show-minimize: OverlayMinButton { x: root.width - 2 * self.width - 6px; y: 2px; minimize => { root.minimize(); } }
    if root.overlay-opacity > 0.001: OverlayCloseButton { x: root.width - self.width - 2px; y: 2px; close => { root.close-window(); } }
}

// ─── バフタイマー オーバーレイ（イマジンデバフの円形タイマー）────────────
struct BuffCell {
    active: bool,
    arc-commands: string,
    color: color,
    text: string,
    text-color: color,
}

struct BuffPlayerRow {
    name: string,
    tina: BuffCell,
    aluna: BuffCell,
    tarta: BuffCell,
    basilisk: BuffCell,
}

component CircularCell inherits Rectangle {
    in property <BuffCell> cell;
    in property <float> font-scale: 1.0;
    in property <HudFx> fx;             // 縁取り＋影（低不透明度時に視認性確保）
    in property <float> size-mul: 1.0; // 密表示で円を縮める係数（行高に合わせる）
    // 円とストロークも font-scale に追従（大きいフォントで数字が円からはみ出さないように）。
    width: 28px * root.font-scale * root.size-mul;
    height: 28px * root.font-scale * root.size-mul;
    opacity: root.cell.active ? 1.0 : 0.25;
    Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 28;
        viewbox-height: 28;
        commands: "M 14 1.5 A 12.5 12.5 0 1 1 13.99 1.5";
        // 完全透明(HUD)時も溝リングは残す（タイマーの目盛りとして見せる）。白12%は背景漏れ無関係。
        stroke: #ffffff1f;
        stroke-width: 3px * root.font-scale * root.size-mul;
        fill: transparent;
    }
    Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 28;
        viewbox-height: 28;
        commands: root.cell.arc-commands;
        stroke: root.cell.color;
        stroke-width: 3px * root.font-scale * root.size-mul;
        fill: transparent;
    }
    HudText {
        text: root.cell.text;
        text-color: root.cell.text-color;
        font-size: 9px * root.font-scale * root.size-mul;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
        fx: root.fx;
    }
}

component BuffPlayerRowItem inherits Rectangle {
    in property <BuffPlayerRow> p;
    in property <float> font-scale: 1.0;
    in property <color> text-base: #ffffff;
    in property <HudFx> fx;             // 縁取り＋影（低不透明度時に視認性確保）
    in property <bool> show-tina: true;
    in property <bool> show-aluna: true;
    in property <bool> show-tarta: true;
    in property <bool> show-basilisk: true;
    in property <bool> compact;          // 密表示（行高・円を縮める）
    // 円は 28px*scale*cell-mul。compact 時は行高を円に合わせて詰める。
    property <float> cell-mul: root.compact ? 0.78 : 1.0;
    height: (root.compact ? 24px : 30px) * root.font-scale;
    HorizontalLayout {
        spacing: 4px;
        // 名前列は伸縮（min-width は font-scale 追従）。窓を広げると余白でなく名前列が広がり、
        // 大きいフォントでも名前が見切れにくい。ヘッダの名前スペーサーと同設定で列を揃える。
        HudText { text: root.p.name; text-color: root.text-base.with-alpha(0.87); font-size: 10px * root.font-scale; min-width: 46px * root.font-scale; horizontal-stretch: 1; overflow: elide; vertical-alignment: center; fx: root.fx; }
        if root.show-tina: VerticalLayout { width: 48px * root.font-scale; alignment: center; HorizontalLayout { alignment: center; CircularCell { cell: root.p.tina; font-scale: root.font-scale; size-mul: root.cell-mul; fx: root.fx; } } }
        if root.show-aluna: VerticalLayout { width: 48px * root.font-scale; alignment: center; HorizontalLayout { alignment: center; CircularCell { cell: root.p.aluna; font-scale: root.font-scale; size-mul: root.cell-mul; fx: root.fx; } } }
        if root.show-tarta: VerticalLayout { width: 48px * root.font-scale; alignment: center; HorizontalLayout { alignment: center; CircularCell { cell: root.p.tarta; font-scale: root.font-scale; size-mul: root.cell-mul; fx: root.fx; } } }
        if root.show-basilisk: VerticalLayout { width: 48px * root.font-scale; alignment: center; HorizontalLayout { alignment: center; CircularCell { cell: root.p.basilisk; font-scale: root.font-scale; size-mul: root.cell-mul; fx: root.fx; } } }
        // ×ボタン用の右余白（固定。横拡大は名前列が吸収する）
        Rectangle { width: 20px * root.font-scale; }
    }
}

export component BuffOverlay inherits Window {
    in property <[BuffPlayerRow]> players;
    in property <bool> empty;
    // 文字の縁取り/影（設定の「縁取り」「影」チェックから Rust が設定。低不透明度・透明 HUD で文字を浮かせる）。
    in property <bool> overlay-outline: true;
    in property <bool> overlay-shadow: false;
    property <HudFx> fx: { outline: root.overlay-outline, shadow: root.overlay-shadow };
    in property <float> font-scale: 1.0; // メインの font_size に連動
    in property <bool> show-tina: true;
    in property <bool> show-aluna: true;
    in property <bool> show-tarta: true;
    in property <bool> show-basilisk: true;
    in property <bool> compact;          // 密表示（行高・行間を詰める）
    in property <bool> show-minimize; // タスクバー常駐モード時のみ最小化ボタンを出す
    in property <float> overlay-opacity: 0.82;        // 背景不透明度（メインとは独立）
    in property <string> overlay-font: "Yu Gothic UI"; // フォントファミリ
    in property <bool> overlay-font-bold;              // 太字（既定オフ）
    in property <color> text-base: #ffffff;            // 基準テキスト色（Rust が解決して設定。白系ラベル/値のみ再着色）
    callback start-drag();
    callback start-resize(int);
    callback close-window();
    callback minimize();

    title: @tr("イマジンデバフタイマー");
    default-font-family: root.overlay-font;
    default-font-weight: root.overlay-font-bold ? 700 : 400;
    no-frame: true;
    always-on-top: true;
    // 完全透明時は `transparent`(#00000000) を使う。femtovg 透明窓は背景色の RGB を alpha=0 でも
    // 加算で漏らすため、#0a0a12.with-alpha(0) だと窓全体に +#0a0a12 の被膜が残る（RGB=0 なら漏れ 0）。
    background: root.overlay-opacity <= 0.001 ? transparent : #0a0a12.with-alpha(root.overlay-opacity);
    preferred-width: 250px;
    preferred-height: 150px;

    drag := TouchArea {
        mouse-cursor: move;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down) {
                root.start-drag();
            }
        }
    }
    VerticalLayout {
        padding-left: 8px;
        padding-right: 8px;
        padding-bottom: 8px;
        // 上部はヘッダー帯ぶんの余白を確保（完全透明時はヘッダーごと消すので詰める）
        padding-top: root.overlay-opacity > 0.001 ? 20px : 0px;
        spacing: root.compact ? 0px : 2px;
        alignment: start; // 上詰め
        if root.empty: HudText { text: @tr("DPS一覧でピンアイコンをクリック"); text-color: root.text-base.with-alpha(0.35); font-size: 10px * root.font-scale; horizontal-alignment: center; fx: root.fx; }
        if !root.empty: HorizontalLayout {
            spacing: 4px;
            // 名前列スペーサー: 行の名前列(伸縮・min 46px*scale)と同設定で列を揃える。
            Rectangle { min-width: 46px * root.font-scale; horizontal-stretch: 1; }
            if root.show-tina: HudText { text: @tr("ティナ"); text-color: #ff4d6d; font-size: 9px * root.font-scale; width: 48px * root.font-scale; horizontal-alignment: center; vertical-alignment: center; overflow: elide; fx: root.fx; }
            if root.show-aluna: HudText { text: @tr("アルーナ"); text-color: #5fd35f; font-size: 9px * root.font-scale; width: 48px * root.font-scale; horizontal-alignment: center; vertical-alignment: center; overflow: elide; fx: root.fx; }
            if root.show-tarta: HudText { text: @tr("タータ"); text-color: #b98bff; font-size: 9px * root.font-scale; width: 48px * root.font-scale; horizontal-alignment: center; vertical-alignment: center; overflow: elide; fx: root.fx; }
            if root.show-basilisk: HudText { text: @tr("バジリスク"); text-color: #d9a05b; font-size: 9px * root.font-scale; width: 48px * root.font-scale; horizontal-alignment: center; vertical-alignment: center; overflow: elide; fx: root.fx; }
            // ×ボタン用の右余白（固定。横拡大は名前列が吸収する）
            Rectangle { width: 20px * root.font-scale; }
        }
        for p in root.players: BuffPlayerRowItem {
            p: p;
            font-scale: root.font-scale;
            text-base: root.text-base;
            fx: root.fx;
            show-tina: root.show-tina;
            show-aluna: root.show-aluna;
            show-tarta: root.show-tarta;
            show-basilisk: root.show-basilisk;
            compact: root.compact;
        }
    }
    // 縁ドラッグでリサイズ
    ResizeEdges { width: 100%; height: 100%; resize(d) => { root.start-resize(d); } }
    // ヘッダーの操作ボタン（ResizeEdges より後＝最上層で右上角クリックを優先）。
    // 上部のヘッダー帯（padding-top）に収まり、完全透明時はヘッダーごと非描画にする。
    if root.overlay-opacity > 0.001 && root.show-minimize: OverlayMinButton { x: root.width - 2 * self.width - 6px; y: 2px; minimize => { root.minimize(); } }
    if root.overlay-opacity > 0.001: OverlayCloseButton { x: root.width - self.width - 2px; y: 2px; close => { root.close-window(); } }
}

