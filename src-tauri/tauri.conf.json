{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bpsr-checker",
  "version": "0.2.1",
  "identifier": "com.bpsr-checker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DPS Checker",
        "label": "main",
        "url": "/",
        "shadow": false,
        "decorations": false,
        "transparent": true,
        "width": 520,
        "height": 350,
        "minWidth": 400,
        "minHeight": 120,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["./WinDivert.dll", "./WinDivert64.sys"]
  }
}
