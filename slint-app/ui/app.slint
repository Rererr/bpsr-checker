// メイン窓（S2: タブ + プレイヤーテーブル + スキル内訳ドリルダウン）。
// 条件付き列・被ダメドリルダウンは後続増分。

struct Row {
    rank: int,
    uid-str: string,   // f64 uid を精度落ちさせず Rust へ返すため文字列で持つ
    name: string,
    class-color: color,
    dmg-text: string,
    dps-text: string,
    pct-text: string,
    pct: float,        // 0..100（割合バー幅。topValue 基準）
    is-local: bool,
    // 条件付き列（settings 連動）
    crit-text: string,
    crit-value-text: string,
    lucky-text: string,
    lucky-value-text: string,
    hits-text: string,
    hpm-text: string,
    score-text: string,
}

struct ColumnFlags {
    crit: bool,
    crit-value: bool,
    lucky: bool,
    lucky-value: bool,
    hits: bool,
    hpm: bool,
    score: bool,
}

struct SkillRowUi {
    name: string,
    elem-text: string,
    elem-color: color,
    total-text: string,
    dps-text: string,
    pct-text: string,
    pct: float,
}

component TabButton inherits TouchArea {
    in property <string> label;
    in property <bool> active;
    Rectangle {
        background: root.active ? #2d6cdf66 : (root.has-hover ? #ffffff14 : transparent);
        border-radius: 4px;
        HorizontalLayout {
            padding-left: 9px;
            padding-right: 9px;
            Text {
                text: root.label;
                color: root.active ? white : #b8b8c8;
                font-size: 12px;
                vertical-alignment: center;
            }
        }
    }
}

component PlayerRowItem inherits Rectangle {
    in property <Row> entry;
    in property <bool> highlight-local;
    in property <ColumnFlags> cols;
    callback activate(string);
    height: 20px;
    background: ta.has-hover
        ? #ffffff12
        : ((root.entry.is-local && root.highlight-local) ? #ffd7001f : transparent);

    // 割合バー（クラス色グラデーション）
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.entry.pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, root.entry.class-color.with-alpha(0.22) 0%, transparent 100%);
    }

    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 5px;
            Rectangle {
                width: 3px;
                background: root.entry.class-color;
                border-radius: 1px;
            }
            Text {
                text: root.entry.name;
                color: white;
                font-size: 12px;
                overflow: elide;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
        }
        Text { text: root.entry.dmg-text; color: #e6e6f0; font-size: 12px; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.dps-text; color: #4fc3f7; font-size: 12px; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.pct-text; color: #cfcfe0; font-size: 11px; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.crit: Text { text: root.entry.crit-text; color: #f39c12; font-size: 11px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.crit-value: Text { text: root.entry.crit-value-text; color: #f39c12; font-size: 11px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.lucky: Text { text: root.entry.lucky-text; color: #2ecc71; font-size: 11px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.lucky-value: Text { text: root.entry.lucky-value-text; color: #2ecc71; font-size: 11px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.hits: Text { text: root.entry.hits-text; color: #cfcfe0; font-size: 11px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.hpm: Text { text: root.entry.hpm-text; color: #cfcfe0; font-size: 11px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.score: Text { text: root.entry.score-text; color: #99aa99; font-size: 11px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
    }

    ta := TouchArea {
        clicked => { root.activate(root.entry.uid-str); }
    }
}

component SkillRowItem inherits Rectangle {
    in property <SkillRowUi> entry;
    height: 20px;

    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.entry.pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, root.entry.elem-color.with-alpha(0.20) 0%, transparent 100%);
    }
    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            Text { text: root.entry.elem-text; color: root.entry.elem-color; font-size: 11px; width: 14px; horizontal-alignment: center; vertical-alignment: center; }
            Text { text: root.entry.name; color: white; font-size: 12px; overflow: elide; vertical-alignment: center; horizontal-stretch: 1; }
        }
        Text { text: root.entry.total-text; color: #e6e6f0; font-size: 12px; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.dps-text; color: #4fc3f7; font-size: 12px; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.pct-text; color: #cfcfe0; font-size: 11px; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
    }
}

// no-frame 窓の縁/角リサイズ用ハンドル。
component ResizeHandle inherits TouchArea {
    in property <int> dir;
    callback resize(int);
    pointer-event(e) => {
        if (e.kind == PointerEventKind.down) {
            root.resize(root.dir);
        }
    }
}

export component MainWindow inherits Window {
    in property <[Row]> rows;
    in property <[SkillRowUi]> skill-rows;
    in property <string> total-text: "0";
    in property <string> elapsed-text: "0:00";
    in property <string> inspected-name;
    in property <bool> highlight-local: true;
    in property <ColumnFlags> cols;
    in property <int> tab: 0;  // 0=dps 1=heal 2=taken 3=history（Rust が set）
    in property <int> view: 0; // 0=一覧 1=スキル内訳（Rust が set）
    callback quit();
    callback start-drag();
    callback start-resize(int);
    callback select-tab(int);
    callback open-skills(string);
    callback back();

    title: @tr("DPSメーター");
    no-frame: true;
    always-on-top: true;
    background: #14141ecc;
    preferred-width: 520px;
    preferred-height: 360px;

    VerticalLayout {
        // ── ヘッダ（タブ + 合計 + ドラッグ + 終了）──
        Rectangle {
            height: 26px;
            background: #1c1c2acc;
            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                spacing: 2px;
                TabButton { label: @tr("DPS"); active: root.tab == 0; clicked => { root.select-tab(0); } }
                TabButton { label: @tr("回復"); active: root.tab == 1; clicked => { root.select-tab(1); } }
                TabButton { label: @tr("被ダメ"); active: root.tab == 2; clicked => { root.select-tab(2); } }
                TabButton { label: @tr("履歴"); active: root.tab == 3; clicked => { root.select-tab(3); } }
                drag := TouchArea {
                    horizontal-stretch: 1;
                    mouse-cursor: move;
                    pointer-event(ev) => {
                        if (ev.kind == PointerEventKind.down) {
                            root.start-drag();
                        }
                    }
                    Text {
                        x: parent.width - self.width - 6px;
                        text: @tr("合計DPS") + " " + root.total-text + "   " + @tr("経過") + " " + root.elapsed-text;
                        color: #c8c8d8;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
                quit-btn := TouchArea {
                    width: 26px;
                    clicked => { root.quit(); }
                    Rectangle {
                        background: quit-btn.has-hover ? #c0392b : transparent;
                        border-radius: 4px;
                        Text { text: "✕"; color: white; font-size: 12px; }
                    }
                }
            }
        }

        // ── 一覧ビュー ──
        if root.view == 0: VerticalLayout {
            vertical-stretch: 1;
            Rectangle {
                height: 16px;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 6px;
                    Text { text: @tr("プレイヤー"); color: #888; font-size: 10px; horizontal-stretch: 1; vertical-alignment: center; }
                    Text {
                        text: root.tab == 1 ? @tr("回復") : (root.tab == 2 ? @tr("被ダメ") : @tr("ダメージ"));
                        color: #888;
                        font-size: 10px;
                        width: 64px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                    Text { text: @tr("DPS"); color: #888; font-size: 10px; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: @tr("%"); color: #888; font-size: 10px; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.crit: Text { text: @tr("会心率"); color: #888; font-size: 10px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.crit-value: Text { text: @tr("会心ダメ率"); color: #888; font-size: 9px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.lucky: Text { text: @tr("幸運率"); color: #888; font-size: 10px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.lucky-value: Text { text: @tr("幸運ダメ率"); color: #888; font-size: 9px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.hits: Text { text: @tr("ヒット数"); color: #888; font-size: 9px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.hpm: Text { text: @tr("毎分ヒット数"); color: #888; font-size: 9px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.score: Text { text: @tr("戦力"); color: #888; font-size: 10px; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                }
            }
            Flickable {
                vertical-stretch: 1;
                max-height: 100000px;
                viewport-height: rowbox.preferred-height;
                rowbox := VerticalLayout {
                    for row in root.rows: PlayerRowItem {
                        entry: row;
                        highlight-local: root.highlight-local;
                        cols: root.cols;
                        activate(u) => { root.open-skills(u); }
                    }
                    if root.rows.length == 0: Text {
                        text: @tr("データなし");
                        color: #666;
                        font-size: 12px;
                        height: 40px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── スキル内訳ビュー ──
        if root.view == 1: VerticalLayout {
            vertical-stretch: 1;
            Rectangle {
                height: 20px;
                background: #20202e;
                HorizontalLayout {
                    padding-left: 4px;
                    padding-right: 8px;
                    spacing: 6px;
                    back-btn := TouchArea {
                        width: 56px;
                        clicked => { root.back(); }
                        Rectangle {
                            background: back-btn.has-hover ? #ffffff20 : transparent;
                            border-radius: 4px;
                            Text { text: "← " + @tr("戻る"); color: #cdd; font-size: 11px; }
                        }
                    }
                    Text { text: root.inspected-name; color: #e6e6f0; font-size: 12px; horizontal-stretch: 1; overflow: elide; vertical-alignment: center; }
                }
            }
            Rectangle {
                height: 16px;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 6px;
                    Text { text: @tr("スキル"); color: #888; font-size: 10px; horizontal-stretch: 1; vertical-alignment: center; }
                    Text { text: @tr("ダメージ"); color: #888; font-size: 10px; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: @tr("DPS"); color: #888; font-size: 10px; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: @tr("%"); color: #888; font-size: 10px; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
                }
            }
            Flickable {
                vertical-stretch: 1;
                max-height: 100000px;
                viewport-height: skillbox.preferred-height;
                skillbox := VerticalLayout {
                    for s in root.skill-rows: SkillRowItem { entry: s; }
                    if root.skill-rows.length == 0: Text {
                        text: @tr("データなし");
                        color: #666;
                        font-size: 12px;
                        height: 40px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // ── リサイズハンドル（縁/角ドラッグでサイズ変更）。縁6px・角14px ──
    ResizeHandle { dir: 0; mouse-cursor: ns-resize; resize(d) => { root.start-resize(d); } x: 14px; y: 0; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 1; mouse-cursor: ns-resize; resize(d) => { root.start-resize(d); } x: 14px; y: root.height - 6px; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 2; mouse-cursor: ew-resize; resize(d) => { root.start-resize(d); } x: root.width - 6px; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 3; mouse-cursor: ew-resize; resize(d) => { root.start-resize(d); } x: 0; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 5; mouse-cursor: nwse-resize; resize(d) => { root.start-resize(d); } x: 0; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 4; mouse-cursor: nesw-resize; resize(d) => { root.start-resize(d); } x: root.width - 14px; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 7; mouse-cursor: nesw-resize; resize(d) => { root.start-resize(d); } x: 0; y: root.height - 14px; width: 14px; height: 14px; }
    ResizeHandle { dir: 6; mouse-cursor: nwse-resize; resize(d) => { root.start-resize(d); } x: root.width - 14px; y: root.height - 14px; width: 14px; height: 14px; }
}
