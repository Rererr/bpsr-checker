import { PlayerRow, MonitorInfo } from "common.slint";

// DPS 一覧ウィンドウ。PoC では枠あり(no-frame:false)にして
// ドラッグ移動・閉じる操作を可能にし、位置保存/復元の検証をしやすくする。
export component DpsList inherits Window {
    in property <[PlayerRow]> rows;
    in property <[MonitorInfo]> monitors;
    in property <string> status;
    in property <bool> buffs-visible: true;
    in property <bool> buffs-locked: true;
    callback quit();
    callback toggle-buffs();
    callback toggle-lock();
    callback start-drag();

    title: "BPSR Slint PoC — DPS";
    no-frame: true;          // Windows 標準枠なし（オーバーレイらしく）
    always-on-top: true;
    background: #14141ecc;    // 半透明（アルファ cc ≒ 0.8）。背後が透ける
    // 20 行＋診断が収まる高さにして、コンテンツによる強制拡大を防ぐ
    preferred-width: 540px;
    preferred-height: 660px;

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        // ── ヘッダ（左の余白を掴んでドラッグ移動）──
        HorizontalLayout {
            spacing: 6px;
            height: 24px;
            drag-handle := TouchArea {
                horizontal-stretch: 1;
                mouse-cursor: move;
                pointer-event(ev) => {
                    if (ev.kind == PointerEventKind.down) {
                        root.start-drag();
                    }
                }
                Text {
                    x: 0;
                    text: "DPS (mock)  ⠿ drag";
                    color: #e6e6f0;
                    font-size: 14px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
            buffs-btn := TouchArea {
                width: 96px;
                height: 22px;
                clicked => { root.toggle-buffs(); }
                Rectangle {
                    background: buffs-btn.has-hover
                        ? #2a4a7a
                        : (root.buffs-visible ? #2d6cdf88 : #444a55);
                    border-radius: 4px;
                    Text {
                        text: root.buffs-visible ? "Buffs: ON" : "Buffs: OFF";
                        color: white;
                        font-size: 12px;
                    }
                }
            }
            lock-btn := TouchArea {
                width: 96px;
                height: 22px;
                clicked => { root.toggle-lock(); }
                Rectangle {
                    background: lock-btn.has-hover
                        ? #6a5a2a
                        : (root.buffs-locked ? #444a55 : #b8862a);
                    border-radius: 4px;
                    Text {
                        text: root.buffs-locked ? "Lock: ON" : "Lock: OFF";
                        color: white;
                        font-size: 12px;
                    }
                }
            }
            quit-btn := TouchArea {
                width: 56px;
                height: 22px;
                clicked => { root.quit(); }
                Rectangle {
                    background: quit-btn.has-hover ? #c0392b : #80303a;
                    border-radius: 4px;
                    Text { text: "Quit"; color: white; font-size: 12px; }
                }
            }
        }

        // ── 行 ──
        for row in root.rows: Rectangle {
            height: 22px;
            // DPS 割合バー
            Rectangle {
                x: 0;
                y: 0;
                width: parent.width * (row.pct / 100.0);
                height: 100%;
                background: #2d6cdf40;
                border-radius: 3px;
            }
            HorizontalLayout {
                width: 100%;
                height: 100%;
                padding-left: 6px;
                padding-right: 6px;
                spacing: 6px;
                Text { text: row.name; color: white; font-size: 12px; width: 130px; vertical-alignment: center; }
                Text { text: row.class-name; color: #a0a0c0; font-size: 11px; width: 64px; vertical-alignment: center; }
                Rectangle {} // spacer
                Text { text: row.dps-text; color: #cfeaff; font-size: 12px; vertical-alignment: center; }
                Text { text: row.pct-text; color: #9ff0c0; font-size: 11px; width: 46px; horizontal-alignment: right; vertical-alignment: center; }
            }
        }

        Rectangle {} // spacer（モニタ診断を下端へ）

        // ── モニタ診断（Slint/winit が認識しているジオメトリ）──
        Text { text: "Monitors (winit):"; color: #8890a0; font-size: 11px; }
        for m in root.monitors: Text {
            text: (m.primary ? "● " : "○ ") + m.name + "  " + m.geometry + "  x" + m.scale;
            color: #9aa0b4;
            font-size: 10px;
        }
        Text { text: root.status; color: #707890; font-size: 10px; }
    }
}
