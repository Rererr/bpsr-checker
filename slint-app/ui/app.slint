// メイン窓（S2: タブ + プレイヤーテーブル + スキル内訳ドリルダウン）。
// 条件付き列・被ダメドリルダウンは後続増分。

struct Row {
    rank: int,
    uid-str: string,   // f64 uid を精度落ちさせず Rust へ返すため文字列で持つ
    name: string,
    class-color: color,
    dmg-text: string,
    dps-text: string,
    pct-text: string,
    pct: float,        // 0..100（割合バー幅。topValue 基準）
    is-local: bool,
    // 条件付き列（settings 連動）
    crit-text: string,
    crit-value-text: string,
    lucky-text: string,
    lucky-value-text: string,
    hits-text: string,
    hpm-text: string,
    score-text: string,
    watched: bool,
    spark-commands: string, // この行のDPS推移（空=非表示行）。viewbox 100x16
    food-active: bool,      // 食事バフ使用中
    food-remaining: float,  // 食事の残量割合 0..1（アイコンの色が上から縦に抜ける）
    food-time: string,      // ホバー時の残り時間（例: 45s）
    food-label: string,     // ホバー時の種類ラベル（例: 物攻 +15。空=不明）
    syrup-active: bool,     // シロップ(錬金)バフ使用中
    syrup-remaining: float, // シロップの残量割合 0..1
    syrup-time: string,     // ホバー時の残り時間
    syrup-label: string,    // ホバー時の種類ラベル
}

struct ColumnFlags {
    crit: bool,
    crit-value: bool,
    lucky: bool,
    lucky-value: bool,
    hits: bool,
    hpm: bool,
    score: bool,
}

// 設定パネルのトグル表示状態（Rust が cfg から set）
struct SettingsUi {
    show-crit: bool,
    show-crit-value: bool,
    show-lucky: bool,
    show-lucky-value: bool,
    show-hits: bool,
    show-hpm: bool,
    show-score: bool,
    highlight-local: bool,
    abbreviate-scores: bool,
    privacy-mask: bool,
    self-status: bool,
    buff-overlay: bool,
    imagine-only: bool,
    aot: bool,
    three-min-auto-open: bool,
    compact-split: bool,
    graph-for-local: bool,
    startup-tab: string,
    accent-theme: string,
    auto-add: bool,
    show-imagine-tina: bool,
    show-imagine-aluna: bool,
    show-imagine-tarta: bool,
    show-imagine-basilisk: bool,
    show-consumable: bool,
}

// 数値設定の表示用（Rust が cfg から整形して set）。ステッパーで増減する。
struct SettingsNumUi {
    combat-exit: string,
    poll-interval: string,
    history-limit: string,
    ts-samples: string,
    ts-interval: string,
    three-min-dur: string,
    graph-count: string,
    font-size: string,
}

struct SkillRowUi {
    uid-str: string,   // 被ダメ攻撃元のドリルダウンに使う（スキル行では未使用）
    name: string,
    elem-text: string,
    elem-color: color,
    total-text: string,
    dps-text: string,
    pct-text: string,
    pct: float,
}

// 履歴ビューのフラット行（is-header=エンカウンタ見出し / false=プレイヤー行）。
// 展開はネスト配列を避け、Rust 側で展開中のみプレイヤー行を差し込む。
struct HistoryRowUi {
    is-header: bool,
    snap-id: string,
    expanded: bool,
    duration-text: string,
    dps-text: string,
    dmg-text: string,
    count-text: string,
    rank-text: string,
    name: string,
    class-color: color,
    p-dps-text: string,
    p-pct-text: string,
    p-pct: float,
}

// 自キャラUID 候補（現在のプレイヤーから）
struct UidCandidate {
    uid-str: string,
    label: string,    // "名前 #1234"
    selected: bool,
}

// 3分計測 結果パネルのプレイヤー行
struct ResultRowUi {
    rank-text: string,
    name: string,
    class-color: color,
    dps-text: string,
    dmg-text: string,
    pct-text: string,
    uid-str: string,   // クリックでスキル内訳の対象に
    selected: bool,
}

// スキル内訳 円グラフの1要素（扇形 or 区切り線の SVGパス）。viewbox 100x100
// is-line=true は灰色の内向き区切り線（塗りなし・外周には届かない）。
struct PieSlice {
    commands: string,
    color: color,
    is-line: bool,
}

// スキル内訳の凡例行（円グラフのスライスと同色）。
struct SkillLegendUi {
    name: string,
    color: color,
    pct-text: string,
}

// 3分計測 結果パネル エリア2 のスキル行（クリックで折れ線の対象スキルに）。
struct ResultSkillRowUi {
    uid-str: string,
    name: string,
    elem-text: string,
    elem-color: color,
    dmg-text: string,
    pct-text: string,
    selected: bool,
}

// アクセントカラーテーマ。設定の accent-theme プリセットに応じて Rust が起動時/変更時に set する。
// accent=文字・枠・選択ハイライト系 / accent-strong=塗りつぶし系（タブ・チェック・スライダー）。
export global Theme {
    in-out property <color> accent: #4fc3f7;
    in-out property <color> accent-strong: #2d6cdf;
}

component TabButton inherits TouchArea {
    in property <string> label;
    in property <bool> active;
    Rectangle {
        background: root.active ? Theme.accent-strong.with-alpha(0.4) : (root.has-hover ? #ffffff14 : transparent);
        border-radius: 4px;
        HorizontalLayout {
            padding-left: 9px;
            padding-right: 9px;
            Text {
                text: root.label;
                color: root.active ? white : #b8b8c8;
                font-size: 12px;
                vertical-alignment: center;
            }
        }
    }
}

// 狭幅ヘッダ用アイコン（viewbox 16x16 の SVG パスコマンド）。
// 絵文字/Dingbats はフォント欠落環境があるため Path 描画で持つ。
global HeaderIcons {
    // 停止（縦2本・塗り。小サイズで潰れないよう隙間を広めに取る）
    out property <string> pause: "M 3.5 3 H 6.5 V 13 H 3.5 Z M 9.5 3 H 12.5 V 13 H 9.5 Z";
    // 再開（再生三角・塗り）
    out property <string> play: "M 5 3 L 13 8 L 5 13 Z";
    // 初期化（円弧矢印・線）
    out property <string> reset: "M 13.5 8 A 5.5 5.5 0 1 1 9.42 2.69 M 6.9 3.6 L 9.42 2.69 L 7.7 0.7";
    // 計測（ストップウォッチ・線）
    out property <string> stopwatch: "M 3.5 9.5 A 4.5 4.5 0 1 1 12.5 9.5 A 4.5 4.5 0 1 1 3.5 9.5 M 8 9.5 L 10.3 7.2 M 8 5 V 3.2 M 6.4 2.8 H 9.6";
    // コピー（重ね四角・線）
    out property <string> copy: "M 5.5 5 H 13.5 V 14 H 5.5 Z M 5.5 11 H 2.5 V 2 H 10.5 V 5";
    // コピー済（チェック・線）
    out property <string> check: "M 3 8.5 L 6.5 12 L 13 3.5";
    // 設定（スライダー2本・線。ノブは縦ティックで表現＝丸ノブは小サイズで矢印に潰れるため）
    out property <string> settings: "M 2 5 H 14 M 10 2.8 V 7.2 M 2 11 H 14 M 6 8.8 V 13.2";
    // 最前面ピン（画鋲・塗り。頭バー＋胴＋台座＋針のシルエット）
    out property <string> pin: "M 4.5 1.8 H 11.5 V 3.2 H 4.5 Z M 6 3.2 H 10 L 10.7 7 H 5.3 Z M 3.8 7 H 12.2 V 8.6 H 3.8 Z M 7.45 8.6 H 8.55 V 13.6 H 7.45 Z";
}

// ヘッダの機能ボタン。狭幅時（show-icon）はテキストの代わりに Path アイコンを表示する。
component HeaderButton inherits TouchArea {
    in property <string> label;
    in property <string> icon-commands; // HeaderIcons の viewbox 16x16 パス
    in property <bool> show-icon;
    in property <bool> active;
    in property <bool> icon-fill: false; // true=塗り、false=線
    in property <color> active-bg: #8a5d12aa;
    in property <color> active-fg: #ffd54f;
    property <color> fg: root.active ? root.active-fg : #cdd;
    Rectangle {
        background: root.active ? root.active-bg : (root.has-hover ? #ffffff20 : transparent);
        border-radius: 4px;
        if root.show-icon: Path {
            width: 13px;
            height: 13px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            viewbox-width: 16;
            viewbox-height: 16;
            commands: root.icon-commands;
            stroke: root.icon-fill ? transparent : root.fg;
            stroke-width: root.icon-fill ? 0px : 1.6px;
            fill: root.icon-fill ? root.fg : transparent;
        }
        if !root.show-icon: Text {
            text: root.label;
            color: root.fg;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// 設定パネルのセグメントボタン（起動タブ選択など）
component SegButton inherits TouchArea {
    in property <string> label;
    in property <bool> active;
    width: 50px;
    height: 22px;
    Rectangle {
        background: root.active ? Theme.accent-strong : (root.has-hover ? #ffffff20 : #ffffff10);
        border-radius: 3px;
        Text { text: root.label; color: root.active ? white : #bbb; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
    }
}

// 食事/シロップ バフのタイマーアイコン。アイコン自体の色が残量に応じて上から
// 縦に抜けていく（縦型プログレスバー・使用中=色付き / 未使用=グレー半透明）。
component ConsumableBadge inherits Rectangle {
    in property <bool> active;
    in property <float> remaining;  // 残量割合 0..1（1=満タン, 0=切れ）
    in property <string> icon;      // SVGパス commands（viewbox 24）
    in property <color> tint;       // 使用中の色
    in property <string> tip-time;  // ホバー: 残り時間（例 45s）
    in property <string> tip-label; // ホバー: 種類ラベル（例 物攻 +15。空=非表示）
    in property <float> font-scale: 1.0;
    callback clicked();
    property <float> elapsed: 1.0 - root.remaining;  // 経過割合（上から色が消える境界）
    // アイコン径＝メインのフォントサイズ（font_size = 12px*font_scale）に一致
    width: 12px * root.font-scale;
    height: self.width;
    Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 24;
        viewbox-height: 24;
        commands: root.icon;
        // 上[0..経過]=グレー半透明、下[経過..1]=色。残量が減ると色が上から下へ抜ける。
        fill: root.active
            ? @linear-gradient(180deg, #8a8f9980 0%, #8a8f9980 root.elapsed * 100%, root.tint root.elapsed * 100%, root.tint 100%)
            : #8a8f9980;
    }
    // ホバーで残り時間＋種類をアイコンの下に表示。PopupWindow=最前面・行にクリップ
    // されないため最上段でも見切れない。ポップはアイコンの下に出すので hover を奪わない。
    ta := TouchArea {
        // アイコン(約12px)はホバー判定が狭く、少しのカーソルずれで tip が消えて
        // ちらつく。行高さいっぱい＋左右に余白を取った判定に広げて安定させる。
        // 行クリックは下層の rowta が拾えなくなるため clicked を転送して維持する。
        width: root.width + 10px;
        height: 20px * root.font-scale;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        changed has-hover => {
            if (self.has-hover && root.active) {
                tip.show();
            } else {
                tip.close();
            }
        }
        clicked => { root.clicked(); }
    }
    tip := PopupWindow {
        x: 0;
        y: root.height + 3px;
        Rectangle {
            width: tipcol.preferred-width;
            height: tipcol.preferred-height;
            background: #11131af2;
            border-radius: 4px;
            border-width: 1px;
            border-color: #ffffff26;
            tipcol := VerticalLayout {
                padding-left: 7px;
                padding-right: 7px;
                padding-top: 4px;
                padding-bottom: 4px;
                spacing: 1px;
                Text {
                    text: @tr("残り {}", root.tip-time);
                    color: #e6e6f0;
                    font-size: 11px * root.font-scale;
                }
                if root.tip-label != "": Text {
                    text: root.tip-label;
                    color: root.tint;
                    font-size: 10px * root.font-scale;
                }
            }
        }
    }
}

component PlayerRowItem inherits Rectangle {
    in property <Row> entry;
    in property <bool> highlight-local;
    in property <ColumnFlags> cols;
    in property <float> font-scale: 1.0;
    in property <bool> show-graph-col;
    in property <bool> show-consumable: true;
    callback activate(string);
    callback toggle-watch(string);
    height: 20px * root.font-scale;
    background: rowta.has-hover
        ? #ffffff12
        : ((root.entry.is-local && root.highlight-local) ? #ffd7001f : transparent);

    // 行クリック（背面）。ウォッチピン等の TouchArea が前面で個別に捕捉する。
    rowta := TouchArea {
        clicked => { root.activate(root.entry.uid-str); }
    }

    // 割合バー（クラス色グラデーション）
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.entry.pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, root.entry.class-color.with-alpha(0.22) 0%, transparent 100%);
    }

    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 5px;
            Rectangle {
                width: 3px;
                background: root.entry.class-color;
                border-radius: 1px;
            }
            Text {
                text: root.entry.name;
                color: white;
                font-size: 12px * root.font-scale;
                overflow: elide;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            // 食事/シロップ バフのタイマーアイコン（残量に応じて色が上から縦に抜ける・ホバーで詳細）
            if root.show-consumable: VerticalLayout { alignment: center; ConsumableBadge {
                active: root.entry.food-active;
                remaining: root.entry.food-remaining;
                tint: #66bb6a;
                tip-time: root.entry.food-time;
                tip-label: root.entry.food-label;
                font-scale: root.font-scale;
                icon: "M8.1 13.34l2.83-2.83L3.91 3.5c-1.56 1.56-1.56 4.09 0 5.66l4.19 4.18zm6.78-1.81c1.53.71 3.68.21 5.27-1.38 1.91-1.91 2.28-4.65.81-6.12-1.46-1.46-4.2-1.1-6.12.81-1.59 1.59-2.09 3.74-1.38 5.27L3.7 19.87l1.41 1.41L12 14.41l6.88 6.88 1.41-1.41L13.41 13l1.47-1.47z";
                clicked => { root.activate(root.entry.uid-str); }
            } }
            if root.show-consumable: VerticalLayout { alignment: center; ConsumableBadge {
                active: root.entry.syrup-active;
                remaining: root.entry.syrup-remaining;
                tint: #b07cff;
                tip-time: root.entry.syrup-time;
                tip-label: root.entry.syrup-label;
                font-scale: root.font-scale;
                icon: "M19.8 18.4L14 10.67V6.5l1.35-1.69c.26-.33.03-.81-.39-.81H9.04c-.42 0-.65.48-.39.81L10 6.5v4.17L4.2 18.4c-.49.66-.02 1.6.8 1.6h14c.82 0 1.29-.94.8-1.6z";
                clicked => { root.activate(root.entry.uid-str); }
            } }
        }
        if root.show-graph-col: Rectangle {
            width: 60px;
            // 対象行のみ折れ線を描く（非対象は空セルで列を揃える）
            Path {
                x: 2px;
                width: 56px;
                height: 14px;
                viewbox-x: 0;
                viewbox-y: 0;
                viewbox-width: 100;
                viewbox-height: 16;
                commands: root.entry.spark-commands;
                stroke: root.entry.class-color;
                stroke-width: 1.2px;
                fill: transparent;
            }
        }
        Text { text: root.entry.dmg-text; color: #e6e6f0; font-size: 12px * root.font-scale; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.dps-text; color: Theme.accent; font-size: 12px * root.font-scale; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.pct-text; color: #cfcfe0; font-size: 11px * root.font-scale; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.crit: Text { text: root.entry.crit-text; color: #f39c12; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.crit-value: Text { text: root.entry.crit-value-text; color: #f39c12; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.lucky: Text { text: root.entry.lucky-text; color: #2ecc71; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.lucky-value: Text { text: root.entry.lucky-value-text; color: #2ecc71; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.hits: Text { text: root.entry.hits-text; color: #cfcfe0; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.hpm: Text { text: root.entry.hpm-text; color: #cfcfe0; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if root.cols.score: Text { text: root.entry.score-text; color: #99aa99; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        watch := TouchArea {
            width: 14px;
            clicked => { root.toggle-watch(root.entry.uid-str); }
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 9px;
                height: 9px;
                border-radius: 4.5px;
                border-width: 1px;
                border-color: root.entry.watched ? Theme.accent : (watch.has-hover ? #888888 : #ffffff00);
                background: root.entry.watched ? Theme.accent : transparent;
            }
        }
    }
}

// 軽量分割表示の行（名前＋ダメージ＋DPSのみ。グラフ/ピン無し）
component CompactRowItem inherits Rectangle {
    in property <Row> entry;
    in property <bool> highlight-local;
    in property <float> font-scale: 1.0;
    callback activate(string);
    height: 18px;
    background: cta.has-hover
        ? #ffffff12
        : ((root.entry.is-local && root.highlight-local) ? #ffd7001f : transparent);
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.entry.pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, root.entry.class-color.with-alpha(0.18) 0%, transparent 100%);
    }
    cta := TouchArea {
        clicked => { root.activate(root.entry.uid-str); }
    }
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 5px;
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            Rectangle { width: 2px; background: root.entry.class-color; border-radius: 1px; }
            Text { text: root.entry.name; color: white; font-size: 11px * root.font-scale; overflow: elide; horizontal-stretch: 1; vertical-alignment: center; }
        }
        Text { text: root.entry.dmg-text; color: #e6e6f0; font-size: 11px * root.font-scale; width: 56px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.dps-text; color: Theme.accent; font-size: 11px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
    }
}

component SkillRowItem inherits Rectangle {
    in property <SkillRowUi> entry;
    in property <bool> clickable;
    in property <float> font-scale: 1.0;
    callback activate(string);
    height: 20px;
    background: (root.clickable && ta.has-hover) ? #ffffff12 : transparent;

    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.entry.pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, root.entry.elem-color.with-alpha(0.20) 0%, transparent 100%);
    }
    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            Text { text: root.entry.elem-text; color: root.entry.elem-color; font-size: 11px * root.font-scale; width: 14px; horizontal-alignment: center; vertical-alignment: center; }
            Text { text: root.entry.name; color: white; font-size: 12px * root.font-scale; overflow: elide; vertical-alignment: center; horizontal-stretch: 1; }
        }
        Text { text: root.entry.total-text; color: #e6e6f0; font-size: 12px * root.font-scale; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.dps-text; color: Theme.accent; font-size: 12px * root.font-scale; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.entry.pct-text; color: #cfcfe0; font-size: 11px * root.font-scale; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
    }
    ta := TouchArea {
        enabled: root.clickable;
        mouse-cursor: root.clickable ? pointer : default;
        clicked => { root.activate(root.entry.uid-str); }
    }
}

// 履歴の行（見出し or プレイヤー）。見出しはクリックで展開トグル。
component HistoryRowItem inherits Rectangle {
    in property <HistoryRowUi> e;
    in property <float> font-scale: 1.0;
    callback toggle(string);
    height: root.e.is-header ? 24px : 18px;
    background: (root.e.is-header && hta.has-hover) ? #ffffff14 : (root.e.is-header ? #ffffff08 : transparent);

    // プレイヤー行の割合バー
    if !root.e.is-header: Rectangle {
        x: 0;
        y: 0;
        width: parent.width * (root.e.p-pct / 100.0);
        height: 100%;
        background: @linear-gradient(90deg, root.e.class-color.with-alpha(0.18) 0%, transparent 100%);
    }
    // 見出しのみクリック可（プレイヤー行では enabled:false で無反応）
    hta := TouchArea {
        enabled: root.e.is-header;
        mouse-cursor: root.e.is-header ? pointer : default;
        clicked => { root.toggle(root.e.snap-id); }
    }
    HorizontalLayout {
        padding-left: root.e.is-header ? 8px : 18px;
        padding-right: 8px;
        spacing: 8px;
        // ── 見出し ──
        if root.e.is-header: Text { text: root.e.duration-text; color: #888; font-size: 10px * root.font-scale; width: 40px; vertical-alignment: center; }
        if root.e.is-header: Text { text: root.e.dps-text + " DPS"; color: Theme.accent; font-size: 11px * root.font-scale; width: 90px; vertical-alignment: center; }
        if root.e.is-header: Text { text: root.e.dmg-text; color: #aaa; font-size: 10px * root.font-scale; width: 60px; vertical-alignment: center; }
        if root.e.is-header: Text { text: root.e.count-text + @tr("人"); color: #666; font-size: 10px * root.font-scale; horizontal-stretch: 1; vertical-alignment: center; }
        if root.e.is-header: Text { text: root.e.expanded ? "▲" : "▼"; color: #555; font-size: 9px * root.font-scale; vertical-alignment: center; }
        // ── プレイヤー行 ──
        if !root.e.is-header: Text { text: root.e.rank-text; color: #555; font-size: 10px * root.font-scale; width: 18px; vertical-alignment: center; }
        if !root.e.is-header: Text { text: root.e.name; color: root.e.class-color; font-size: 11px * root.font-scale; overflow: elide; horizontal-stretch: 1; vertical-alignment: center; }
        if !root.e.is-header: Text { text: root.e.p-dps-text; color: Theme.accent; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
        if !root.e.is-header: Text { text: root.e.p-pct-text; color: #aaa; font-size: 10px * root.font-scale; width: 40px; horizontal-alignment: right; vertical-alignment: center; }
    }
}

// 3分計測 結果パネルの行（クリックでスキル内訳の対象に）
component ResultRow inherits Rectangle {
    in property <ResultRowUi> e;
    callback activate(string);
    height: 18px;
    background: root.e.selected ? Theme.accent.with-alpha(0.18) : (rta.has-hover ? #ffffff18 : #ffffff0a);
    border-width: 1px;
    border-color: root.e.selected ? Theme.accent.with-alpha(0.667) : #ffffff00;
    border-radius: 2px;
    rta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.activate(root.e.uid-str); }
    }
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 8px;
        Text { text: root.e.rank-text; color: #666; width: 18px; font-size: 10px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.e.name; color: root.e.class-color; font-size: 11px; horizontal-stretch: 1; overflow: elide; vertical-alignment: center; }
        Text { text: root.e.dps-text; color: Theme.accent; font-size: 10px; width: 56px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.e.dmg-text; color: #aaa; font-size: 10px; width: 60px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.e.pct-text; color: #777; font-size: 10px; width: 40px; horizontal-alignment: right; vertical-alignment: center; }
    }
}

// 3分計測 結果パネル エリア2 のスキル行（クリックで折れ線の対象スキルに）
component ResultSkillRow inherits Rectangle {
    in property <ResultSkillRowUi> e;
    callback activate(string);
    height: 18px;
    background: root.e.selected ? Theme.accent.with-alpha(0.18) : (rsta.has-hover ? #ffffff18 : #ffffff0a);
    border-width: 1px;
    border-color: root.e.selected ? Theme.accent.with-alpha(0.667) : #ffffff00;
    border-radius: 2px;
    rsta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.activate(root.e.uid-str); }
    }
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 6px;
        Text { text: root.e.elem-text; color: root.e.elem-color; font-size: 10px; width: 14px; horizontal-alignment: center; vertical-alignment: center; }
        Text { text: root.e.name; color: white; font-size: 11px; horizontal-stretch: 1; overflow: elide; vertical-alignment: center; }
        Text { text: root.e.dmg-text; color: #e6e6f0; font-size: 10px; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
        Text { text: root.e.pct-text; color: #777; font-size: 10px; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
    }
}

// 折れ線グラフ＋左Y軸目安(上=最大/中=半分/下=0)＋時間X軸(区切り本数は横幅で可変)＋グリッド線。
component SparkGraph inherits VerticalLayout {
    in property <bool> visible-graph;
    in property <string> commands;
    in property <color> line-color;
    in property <string> axis-top;
    in property <string> axis-mid;
    in property <string> empty-text;
    in property <float> duration-ms;                 // X軸の総時間（ms）
    // X軸の区切り本数（横幅で可変。約80pxごとに1区切り、2〜7本）。
    property <int> x-ticks: Math.max(2, Math.min(7, Math.floor(plot.width / 80px)));
    spacing: 2px;

    // 主行: 左Y軸 ＋ グラフ
    HorizontalLayout {
        vertical-stretch: 1;
        spacing: 4px;
        VerticalLayout {
            width: 42px;
            Text { text: root.axis-top; color: #777; font-size: 8px; horizontal-alignment: right; }
            Rectangle { vertical-stretch: 1; }
            Text { text: root.axis-mid; color: #777; font-size: 8px; horizontal-alignment: right; }
            Rectangle { vertical-stretch: 1; }
            Text { text: "0"; color: #777; font-size: 8px; horizontal-alignment: right; }
        }
        plot := Rectangle {
            horizontal-stretch: 1;
            clip: true;
            // 横グリッド（上/中/下）
            Rectangle { y: 0; width: 100%; height: 1px; background: #ffffff14; }
            Rectangle { y: parent.height / 2; width: 100%; height: 1px; background: #ffffff10; }
            Rectangle { y: parent.height - 1px; width: 100%; height: 1px; background: #ffffff14; }
            // 縦グリッド（時間区切り・本数は横幅で可変）
            for i in root.x-ticks: Rectangle {
                property <float> f: root.x-ticks > 1 ? (i * 1.0) / (root.x-ticks - 1) : 0;
                x: plot.width * self.f;
                y: 0;
                width: 1px;
                height: 100%;
                background: #ffffff0c;
            }
            if root.visible-graph: Path {
                width: 100%;
                height: 100%;
                viewbox-x: 0;
                viewbox-y: 0;
                viewbox-width: 100;
                viewbox-height: 16;
                commands: root.commands;
                stroke: root.line-color;
                stroke-width: 1px;
                fill: transparent;
            }
            if !root.visible-graph: Text { text: root.empty-text; color: #555; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
        }
    }
    // X軸: 時間ラベル（M:SS）。区切り位置に合わせて配置。
    HorizontalLayout {
        height: 11px;
        spacing: 4px;
        Rectangle { width: 42px; }   // Y軸列ぶんのスペーサ
        xaxis := Rectangle {
            horizontal-stretch: 1;
            for i in root.x-ticks: Text {
                property <float> f: root.x-ticks > 1 ? (i * 1.0) / (root.x-ticks - 1) : 0;
                property <int> sec: Math.round(root.duration-ms / 1000 * self.f);
                property <int> mins: Math.floor(self.sec / 60);
                property <int> rem: self.sec - self.mins * 60;
                property <string> rem-str: self.rem < 10 ? "0\{self.rem}" : "\{self.rem}";
                x: Math.max(0px, Math.min(xaxis.width - self.width, xaxis.width * self.f - self.width / 2));
                color: #777;
                font-size: 8px;
                text: "\{self.mins}:\{self.rem-str}";
            }
        }
    }
}

// 自キャラUID 候補チップ
component CandidateChip inherits TouchArea {
    in property <UidCandidate> c;
    callback pick(string);
    height: 20px;
    clicked => { root.pick(root.c.uid-str); }
    Rectangle {
        background: root.c.selected ? Theme.accent.with-alpha(0.2) : (root.has-hover ? #ffffff20 : #ffffff10);
        border-width: 1px;
        border-color: root.c.selected ? Theme.accent : #ffffff26;
        border-radius: 3px;
        HorizontalLayout {
            padding-left: 6px;
            padding-right: 6px;
            Text { text: root.c.label; color: root.c.selected ? Theme.accent : #bbb; font-size: 10px; vertical-alignment: center; }
        }
    }
}

// アクセントカラーのプリセットスウォッチ（設定パネル・クリックで即適用）
component ThemeSwatch inherits TouchArea {
    in property <color> c;
    in property <bool> selected;
    width: 20px;
    height: 20px;
    Rectangle {
        x: 1px;
        y: 1px;
        width: 18px;
        height: 18px;
        border-radius: 9px;
        background: root.c;
        border-width: root.selected ? 2px : 1px;
        border-color: root.selected ? white : (root.has-hover ? #ffffffaa : #ffffff40);
    }
}

// 設定パネルのトグル行（カスタムチェックボックス）
component ToggleRow inherits TouchArea {
    in property <string> label;
    in property <bool> checked;
    callback toggled();
    height: 26px;
    clicked => { root.toggled(); }
    Rectangle {
        background: root.has-hover ? #ffffff10 : transparent;
        HorizontalLayout {
            padding-left: 10px;
            padding-right: 10px;
            spacing: 8px;
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 16px;
                    height: 16px;
                    border-width: 1px;
                    border-color: #777;
                    border-radius: 3px;
                    background: root.checked ? Theme.accent-strong : transparent;
                    // チェックマークはフォント依存(✓はDingbatsで欠落環境あり)を避け Path 描画
                    if root.checked: Path {
                        width: 16px;
                        height: 16px;
                        viewbox-x: 0;
                        viewbox-y: 0;
                        viewbox-width: 16;
                        viewbox-height: 16;
                        commands: "M 3.5 8.5 L 6.5 11.5 L 12.5 4.5";
                        stroke: white;
                        stroke-width: 1.6px;
                        fill: transparent;
                    }
                }
            }
            Text { text: root.label; color: #ddd; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
        }
    }
}

// 不透明度スライダー行
component OpacityRow inherits Rectangle {
    in property <float> value;
    callback changed(float);
    height: 30px;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;
        Text { text: @tr("不透明度"); color: #ddd; font-size: 12px; vertical-alignment: center; width: 80px; }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            track := Rectangle {
                height: 6px;
                background: #3a3a48;
                border-radius: 3px;
                Rectangle {
                    x: 0;
                    width: parent.width * root.value;
                    height: 100%;
                    background: Theme.accent-strong;
                    border-radius: 3px;
                }
                ta := TouchArea {
                    moved => { root.changed(self.mouse-x / self.width); }
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) {
                            root.changed(self.mouse-x / self.width);
                        }
                    }
                }
            }
        }
    }
}

// 数値設定の増減行（−/＋ ステッパー。表示はリアクティブ Text で双方向バインド競合を回避）
component StepperRow inherits Rectangle {
    in property <string> label;
    in property <string> value-text;
    callback dec();
    callback inc();
    height: 26px;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        Text { text: root.label; color: #ddd; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
        dec-btn := TouchArea {
            width: 22px;
            clicked => { root.dec(); }
            Rectangle {
                background: dec-btn.has-hover ? #ffffff28 : #ffffff12;
                border-radius: 3px;
                Text { text: "-"; color: white; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
        Text { text: root.value-text; color: #cdd; font-size: 12px; width: 44px; horizontal-alignment: center; vertical-alignment: center; }
        inc-btn := TouchArea {
            width: 22px;
            clicked => { root.inc(); }
            Rectangle {
                background: inc-btn.has-hover ? #ffffff28 : #ffffff12;
                border-radius: 3px;
                Text { text: "+"; color: white; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
}

// テンプレート編集（ラベル＋複数行テキスト入力＋リセット＋プレビュー）。
// value は Rust 側が「パネル開時／リセット時のみ」push する。編集中(edited)は
// cfg と preview のみ更新し value を再設定しない＝入力中のクロバーを防ぐ。
component TemplateField inherits VerticalLayout {
    in property <string> label;
    in property <string> value;
    in property <string> preview;
    in property <string> hint;
    callback changed(string);
    callback reset();
    spacing: 2px;
    padding-left: 10px;
    padding-right: 10px;
    Text { text: root.label; color: #bbb; font-size: 10px; }
    HorizontalLayout {
        spacing: 4px;
        Rectangle {
            horizontal-stretch: 1;
            height: 34px;
            background: #ffffff14;
            border-width: 1px;
            border-color: ti.has-focus ? Theme.accent : #ffffff26;
            border-radius: 3px;
            ti := TextInput {
                x: 5px;
                width: parent.width - 10px;
                height: 100%;
                vertical-alignment: center;
                wrap: word-wrap;
                single-line: false;
                color: #ddd;
                font-size: 11px;
                text: root.value;
                edited => { root.changed(self.text); }
            }
        }
        reset-btn := TouchArea {
            width: 44px;
            clicked => { root.reset(); }
            Rectangle {
                background: reset-btn.has-hover ? #ffffff28 : #ffffff12;
                border-radius: 3px;
                Text { text: @tr("リセット"); color: #cdd; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
    if root.hint != "": Text { text: root.hint; color: #666; font-size: 9px; wrap: word-wrap; }
    Text { text: root.preview; color: #cfcfe0; font-size: 10px; wrap: word-wrap; }
}

// ── 設定パネルのセクション群（レスポンシブ多列レイアウトの単位）──
// 各セクションは VerticalLayout を継承し、必要な構造体/コールバックのみを公開する。
// MainWindow 側で最大3カラムへ振り分け、同じ定義を列ごとに条件配置する。

// キャラクター（自キャラUID入力・解決名・候補チップ・ヒント）
component CharacterSection inherits VerticalLayout {
    in property <string> uid-value;
    in property <string> uid-name;
    in property <[UidCandidate]> candidates;
    callback set-uid(string); // 空文字=クリア
    spacing: 1px;
    Text { text: @tr("キャラクター"); color: #888; font-size: 10px; }
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        height: 28px;
        Text { text: @tr("自キャラUID"); color: #ddd; font-size: 12px; vertical-alignment: center; width: 76px; }
        Rectangle {
            horizontal-stretch: 1;
            background: #ffffff14;
            border-width: 1px;
            border-color: uidti.has-focus ? Theme.accent : #ffffff26;
            border-radius: 3px;
            uidti := TextInput {
                x: 5px;
                width: parent.width - 10px;
                height: 100%;
                vertical-alignment: center;
                color: #ddd;
                font-size: 12px;
                input-type: number;
                text: root.uid-value;
                // Enter で確定（毎キーで set すると集計リセットされるため）
                accepted => { root.set-uid(self.text); }
            }
        }
        uidclear := TouchArea {
            width: 44px;
            clicked => { root.set-uid(""); }
            Rectangle {
                background: uidclear.has-hover ? #ffffff28 : #ffffff12;
                border-radius: 3px;
                Text { text: @tr("クリア"); color: #cdd; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        Rectangle { width: 76px; }
        Text { text: root.uid-name; color: #aaa; font-size: 11px; vertical-alignment: center; overflow: elide; horizontal-stretch: 1; }
    }
    if root.candidates.length > 0: HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        height: 24px;
        Text { text: @tr("候補"); color: #777; font-size: 10px; vertical-alignment: center; width: 76px; }
        Flickable {
            horizontal-stretch: 1;
            viewport-width: candbox.preferred-width;
            candbox := HorizontalLayout {
                spacing: 4px;
                for cand in root.candidates: CandidateChip { c: cand; pick(u) => { root.set-uid(u); } }
            }
        }
    }
    Text { text: @tr("自動判定が外れた時に手動で自分を指定（Enterで確定）"); color: #555; font-size: 9px; wrap: word-wrap; }
}

// 表示列（一覧に出す列のトグル）
component DisplayColsSection inherits VerticalLayout {
    in property <SettingsUi> cfg;
    callback set-bool(string, bool);
    spacing: 1px;
    Text { text: @tr("表示列"); color: #888; font-size: 10px; }
    ToggleRow { label: @tr("会心率"); checked: root.cfg.show-crit; toggled => { root.set-bool("show-crit", !root.cfg.show-crit); } }
    ToggleRow { label: @tr("会心ダメ率"); checked: root.cfg.show-crit-value; toggled => { root.set-bool("show-crit-value", !root.cfg.show-crit-value); } }
    ToggleRow { label: @tr("幸運率"); checked: root.cfg.show-lucky; toggled => { root.set-bool("show-lucky", !root.cfg.show-lucky); } }
    ToggleRow { label: @tr("幸運ダメ率"); checked: root.cfg.show-lucky-value; toggled => { root.set-bool("show-lucky-value", !root.cfg.show-lucky-value); } }
    ToggleRow { label: @tr("ヒット数"); checked: root.cfg.show-hits; toggled => { root.set-bool("show-hits", !root.cfg.show-hits); } }
    ToggleRow { label: @tr("毎分ヒット数"); checked: root.cfg.show-hpm; toggled => { root.set-bool("show-hpm", !root.cfg.show-hpm); } }
    ToggleRow { label: @tr("戦力"); checked: root.cfg.show-score; toggled => { root.set-bool("show-score", !root.cfg.show-score); } }
    ToggleRow { label: @tr("食事/シロップ"); checked: root.cfg.show-consumable; toggled => { root.set-bool("show-consumable", !root.cfg.show-consumable); } }
}

// 表示（強調・省略・マスク・フォントサイズ・起動タブ）
component DisplaySection inherits VerticalLayout {
    in property <SettingsUi> cfg;
    in property <SettingsNumUi> nums;
    callback set-bool(string, bool);
    callback bump-num(string, int);
    callback set-str(string, string);
    spacing: 1px;
    Text { text: @tr("表示"); color: #888; font-size: 10px; }
    ToggleRow { label: @tr("自分を強調"); checked: root.cfg.highlight-local; toggled => { root.set-bool("highlight-local", !root.cfg.highlight-local); } }
    ToggleRow { label: @tr("スコア省略(K/M)"); checked: root.cfg.abbreviate-scores; toggled => { root.set-bool("abbreviate-scores", !root.cfg.abbreviate-scores); } }
    ToggleRow { label: @tr("名前マスク"); checked: root.cfg.privacy-mask; toggled => { root.set-bool("privacy-mask", !root.cfg.privacy-mask); } }
    ToggleRow { label: @tr("軽量分割表示"); checked: root.cfg.compact-split; toggled => { root.set-bool("compact-split", !root.cfg.compact-split); } }
    StepperRow { label: @tr("フォントサイズ"); value-text: root.nums.font-size; dec => { root.bump-num("font-size", -1); } inc => { root.bump-num("font-size", 1); } }
    // 起動時のタブ: ラベルを上・セグボタンを下に縦積み（狭幅列でもラベルが潰れない）
    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 3px;
        Text { text: @tr("起動時のタブ"); color: #ddd; font-size: 12px; }
        HorizontalLayout {
            spacing: 6px;
            SegButton { label: @tr("DPS"); active: root.cfg.startup-tab == "dps"; clicked => { root.set-str("startup-tab", "dps"); } }
            SegButton { label: @tr("回復"); active: root.cfg.startup-tab == "heal"; clicked => { root.set-str("startup-tab", "heal"); } }
            SegButton { label: @tr("履歴"); active: root.cfg.startup-tab == "history"; clicked => { root.set-str("startup-tab", "history"); } }
            // 余白を吸収し、固定幅セグボタンによる行の max-width(150px) 制限を解除する。
            // これがないと DisplaySection→中央列が ~150px で頭打ちになり伸縮しない。
            Rectangle { horizontal-stretch: 1; }
        }
    }
    // アクセントカラー: プリセットスウォッチ（クリックで即適用・全ウィンドウ再起動不要）
    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 3px;
        Text { text: @tr("アクセントカラー"); color: #ddd; font-size: 12px; }
        HorizontalLayout {
            spacing: 6px;
            ThemeSwatch { c: #4fc3f7; selected: root.cfg.accent-theme == "sky"; clicked => { root.set-str("accent-theme", "sky"); } }
            ThemeSwatch { c: #34d399; selected: root.cfg.accent-theme == "emerald"; clicked => { root.set-str("accent-theme", "emerald"); } }
            ThemeSwatch { c: #fbc02d; selected: root.cfg.accent-theme == "amber"; clicked => { root.set-str("accent-theme", "amber"); } }
            ThemeSwatch { c: #fb7185; selected: root.cfg.accent-theme == "rose"; clicked => { root.set-str("accent-theme", "rose"); } }
            ThemeSwatch { c: #a78bfa; selected: root.cfg.accent-theme == "violet"; clicked => { root.set-str("accent-theme", "violet"); } }
            ThemeSwatch { c: #cfd2dc; selected: root.cfg.accent-theme == "mono"; clicked => { root.set-str("accent-theme", "mono"); } }
            // 固定幅スウォッチ列による行の max-width 制限を解除（起動時のタブと同じ対策）
            Rectangle { horizontal-stretch: 1; }
        }
    }
}

// オーバーレイ（バフ/デバフ窓・最前面）。不透明度は全幅化のため setbox 側へ分離。
component OverlaySection inherits VerticalLayout {
    in property <SettingsUi> cfg;
    callback set-bool(string, bool);
    spacing: 1px;
    Text { text: @tr("オーバーレイ"); color: #888; font-size: 10px; }
    ToggleRow { label: @tr("自キャラ バフ/デバフ"); checked: root.cfg.self-status; toggled => { root.set-bool("self-status-overlay", !root.cfg.self-status); } }
    ToggleRow { label: @tr("イマジンデバフタイマー"); checked: root.cfg.buff-overlay; toggled => { root.set-bool("buff-overlay", !root.cfg.buff-overlay); } }
    ToggleRow { label: @tr("イマジン専用モード"); checked: root.cfg.imagine-only; toggled => { root.set-bool("imagine-only", !root.cfg.imagine-only); } }
    ToggleRow { label: @tr("全プレイヤー自動追加"); checked: root.cfg.auto-add; toggled => { root.set-bool("auto-add-players", !root.cfg.auto-add); } }
    // タイマーに表示するイマジン列（パーティ構成に合わせて不要列を消す）
    Text { text: @tr("タイマー表示イマジン"); color: #888; font-size: 9px; }
    ToggleRow { label: @tr("ティナ"); checked: root.cfg.show-imagine-tina; toggled => { root.set-bool("imagine-col-tina", !root.cfg.show-imagine-tina); } }
    ToggleRow { label: @tr("アルーナ"); checked: root.cfg.show-imagine-aluna; toggled => { root.set-bool("imagine-col-aluna", !root.cfg.show-imagine-aluna); } }
    ToggleRow { label: @tr("タータ"); checked: root.cfg.show-imagine-tarta; toggled => { root.set-bool("imagine-col-tarta", !root.cfg.show-imagine-tarta); } }
    ToggleRow { label: @tr("バジリスク"); checked: root.cfg.show-imagine-basilisk; toggled => { root.set-bool("imagine-col-basilisk", !root.cfg.show-imagine-basilisk); } }
    ToggleRow { label: @tr("常に最前面"); checked: root.cfg.aot; toggled => { root.set-bool("aot", !root.cfg.aot); } }
}

// 戦闘（終了判定・更新間隔・3分計測）
component CombatSection inherits VerticalLayout {
    in property <SettingsUi> cfg;
    in property <SettingsNumUi> nums;
    callback set-bool(string, bool);
    callback bump-num(string, int);
    spacing: 1px;
    Text { text: @tr("戦闘"); color: #888; font-size: 10px; }
    StepperRow { label: @tr("戦闘終了(秒)"); value-text: root.nums.combat-exit; dec => { root.bump-num("combat-exit", -1); } inc => { root.bump-num("combat-exit", 1); } }
    StepperRow { label: @tr("更新間隔(ms)"); value-text: root.nums.poll-interval; dec => { root.bump-num("poll-interval", -1); } inc => { root.bump-num("poll-interval", 1); } }
    StepperRow { label: @tr("3分計測(秒)"); value-text: root.nums.three-min-dur; dec => { root.bump-num("three-min-dur", -1); } inc => { root.bump-num("three-min-dur", 1); } }
    ToggleRow { label: @tr("3分計測を自動で開く"); checked: root.cfg.three-min-auto-open; toggled => { root.set-bool("three-min-auto-open", !root.cfg.three-min-auto-open); } }
}

// 履歴・グラフ
component HistorySection inherits VerticalLayout {
    in property <SettingsUi> cfg;
    in property <SettingsNumUi> nums;
    callback set-bool(string, bool);
    callback bump-num(string, int);
    spacing: 1px;
    Text { text: @tr("履歴・グラフ"); color: #888; font-size: 10px; }
    StepperRow { label: @tr("履歴保持数"); value-text: root.nums.history-limit; dec => { root.bump-num("history-limit", -1); } inc => { root.bump-num("history-limit", 1); } }
    StepperRow { label: @tr("グラフ標本数"); value-text: root.nums.ts-samples; dec => { root.bump-num("ts-samples", -1); } inc => { root.bump-num("ts-samples", 1); } }
    StepperRow { label: @tr("グラフ間隔(ms)"); value-text: root.nums.ts-interval; dec => { root.bump-num("ts-interval", -1); } inc => { root.bump-num("ts-interval", 1); } }
    StepperRow { label: @tr("グラフ表示人数"); value-text: root.nums.graph-count; dec => { root.bump-num("graph-count", -1); } inc => { root.bump-num("graph-count", 1); } }
    ToggleRow { label: @tr("自分のグラフを表示"); checked: root.cfg.graph-for-local; toggled => { root.set-bool("graph-for-local", !root.cfg.graph-for-local); } }
}

// no-frame 窓の縁/角リサイズ用ハンドル。
component ResizeHandle inherits TouchArea {
    in property <int> dir;
    callback resize(int);
    pointer-event(e) => {
        if (e.kind == PointerEventKind.down) {
            root.resize(root.dir);
        }
    }
}

// no-frame 窓の縁/角リサイズ枠（8ハンドル）。中央は透過し下層へイベントを通す。
// 透明 Rectangle 自体はイベントを捕捉しないため、縁/角のみ反応する。
component ResizeEdges inherits Rectangle {
    callback resize(int);
    ResizeHandle { dir: 0; mouse-cursor: ns-resize; resize(d) => { root.resize(d); } x: 14px; y: 0; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 1; mouse-cursor: ns-resize; resize(d) => { root.resize(d); } x: 14px; y: root.height - 6px; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 2; mouse-cursor: ew-resize; resize(d) => { root.resize(d); } x: root.width - 6px; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 3; mouse-cursor: ew-resize; resize(d) => { root.resize(d); } x: 0; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 5; mouse-cursor: nwse-resize; resize(d) => { root.resize(d); } x: 0; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 4; mouse-cursor: nesw-resize; resize(d) => { root.resize(d); } x: root.width - 14px; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 7; mouse-cursor: nesw-resize; resize(d) => { root.resize(d); } x: 0; y: root.height - 14px; width: 14px; height: 14px; }
    ResizeHandle { dir: 6; mouse-cursor: nwse-resize; resize(d) => { root.resize(d); } x: root.width - 14px; y: root.height - 14px; width: 14px; height: 14px; }
}

export component MainWindow inherits Window {
    in property <[Row]> rows;
    in property <[Row]> compact-left;   // 軽量分割 左カラム（前半）
    in property <[Row]> compact-right;  // 軽量分割 右カラム（後半）
    in property <[SkillRowUi]> skill-rows;
    in property <[HistoryRowUi]> history-rows;
    in property <string> total-text: "0";
    in property <string> elapsed-text: "0:00";
    in property <string> inspected-name;
    in property <bool> highlight-local: true;
    in property <bool> aot: true; // 常に最前面（設定連動）
    in property <ColumnFlags> cols;
    in property <int> tab: 0;  // 0=dps 1=heal 2=taken 3=history（Rust が set）
    in property <int> view: 0; // 0=一覧 1=スキル内訳/攻撃元（Rust が set）
    in property <bool> skills-clickable; // 被ダメ攻撃元一覧のとき true（行クリックで技別へ）
    in property <bool> settings-open;
    in property <SettingsUi> cfg-ui;
    in property <SettingsNumUi> nums;
    in property <string> name-template-value;
    in property <string> copy-template-value;
    in property <string> name-preview;
    in property <string> copy-preview;
    in property <string> selected-uid-value;  // 自キャラUID入力欄（開時/確定時に push）
    in property <string> selected-uid-name;    // 解決名/状態表示
    in property <[UidCandidate]> uid-candidates;
    in property <float> win-opacity: 0.85;
    in property <float> font-scale: 1.0; // 本体テーブル＋ヘッダの文字倍率（font_size/12）
    in property <bool> copied; // コピー直後の一時フィードバック
    in property <bool> show-graph-col;    // 一覧にDPS推移列を出すか（graph設定＋被ダメ以外）
    in property <bool> show-consumable: true; // 名前列に食事/シロップバッジを出すか
    in property <bool> paused;            // 集計の一時停止状態
    in property <int> measure-kind;       // 3分計測 0=通常 1=待機(pending) 2=計測中(active)
    in property <string> measure-text;    // 計測中のカウントダウン "M:SS"
    in property <bool> result-open;       // 3分計測 結果パネル表示
    in property <string> result-dps;
    in property <string> result-dmg;
    in property <string> result-duration;
    in property <string> result-char-spark;        // エリア1: 選択キャラの累積合計ダメージ折れ線
    in property <bool> result-char-spark-visible;
    in property <[ResultRowUi]> result-rows;        // エリア1: キャラ一覧（最大5）
    in property <[ResultSkillRowUi]> result-skill-rows; // エリア2: スキル内訳
    in property <string> result-skill-spark;        // エリア2: 選択スキルの累積ダメージ折れ線
    in property <bool> result-skill-spark-visible;
    in property <[PieSlice]> result-pie;            // エリア3: TOP10+その他 円グラフ
    in property <[SkillLegendUi]> result-legend;
    in property <string> result-pie-title;
    in property <string> result-char-name;          // エリア1 折れ線ラベル: 選択キャラ名
    in property <string> result-skill-name;         // エリア4 折れ線ラベル: 選択スキル名
    in property <string> result-char-axis-top;      // エリア1 Y軸: 最大DPS
    in property <string> result-char-axis-mid;      // エリア1 Y軸: 最大DPSの半分
    in property <string> result-skill-axis-top;     // エリア4 Y軸: 最大DPS
    in property <string> result-skill-axis-mid;     // エリア4 Y軸: 最大DPSの半分
    in property <float> result-duration-ms;         // 折れ線 X軸 時間ラベル用（計測全体の長さ）
    in property <int> capture-state;  // 0=起動中 1=待機(ゲーム通信なし) 2=受信中 3=開始失敗
    in property <string> app-version;        // 結果モーダルの透かし（画像コピーに写り込む）
    in property <bool> result-img-copied;    // 画像コピー直後の一時フィードバック
    callback quit();
    callback minimize();
    callback start-drag();
    callback start-resize(int);
    callback select-tab(int);
    callback open-drill(string);
    callback drill-row(string);
    callback toggle-watch(string);
    callback back();
    callback toggle-settings();
    callback set-bool(string, bool);
    callback set-opacity(float);
    callback bump-num(string, int);
    callback set-str(string, string);
    callback reset-str(string);
    callback set-selected-uid(string); // 空文字=クリア
    callback copy-list();
    callback toggle-history(string);
    callback clear-history();
    callback toggle-measure();
    callback toggle-pause();
    callback reset-encounter();
    callback close-result();
    callback copy-result();
    callback copy-result-image();
    callback restart-measure();
    callback select-result-player(string);
    callback select-result-skill(string);

    // ヘッダの固定幅合計（タブ＋ボタン）が収まらない幅ではアイコン/短縮ラベル表示に切り替える。
    // root.width への直接バインディングはヘッダ文字列経由で layoutinfo と循環するため、
    // changed コールバックで値として代入してループを断つ。
    property <bool> narrow-header: false;
    changed width => { root.narrow-header = root.width < 600px; }
    // 設定パネルの列数（窓幅でレスポンシブに 1/2/3）。短ラベルが多いので幅があれば3列まで。
    property <int> set-cols: root.width >= 660px ? 3 : (root.width >= 440px ? 2 : 1);
    // セクション index(0=キャラ,1=表示列,2=表示,3=オーバーレイ,4=戦闘,5=履歴) の所属カラムを返す。
    pure function scol(i: int) -> int {
        if (root.set-cols <= 1) {
            return 0;
        }
        if (root.set-cols == 2) {
            return i <= 2 ? 0 : 1;
        }
        return i <= 1 ? 0 : (i <= 3 ? 1 : 2);
    }

    title: @tr("DPSメーター");
    default-font-family: "Yu Gothic UI"; // femtovg は ClearType 非対応のため可読性重視の和文フォントを既定に
    no-frame: true;
    always-on-top: root.aot;
    // 不透明度: 背景の透け具合を調整（文字・バーは可読性のため不透明のまま）
    background: #14141e.with-alpha(root.win-opacity);
    preferred-width: 520px;
    preferred-height: 360px;

    VerticalLayout {
        // ── ヘッダ（タブ + 合計 + ドラッグ + 終了）──
        Rectangle {
            height: 26px;
            background: #1c1c2acc;
            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                spacing: 2px;
                TabButton { label: @tr("DPS"); active: root.tab == 0; clicked => { root.select-tab(0); } }
                TabButton { label: root.narrow-header ? @tr("Heal") : @tr("回復"); active: root.tab == 1; clicked => { root.select-tab(1); } }
                TabButton { label: root.narrow-header ? @tr("Taken") : @tr("被ダメ"); active: root.tab == 2; clicked => { root.select-tab(2); } }
                TabButton { label: root.narrow-header ? @tr("Log") : @tr("履歴"); active: root.tab == 3; clicked => { root.select-tab(3); } }
                drag := TouchArea {
                    horizontal-stretch: 1;
                    mouse-cursor: move;
                    pointer-event(ev) => {
                        if (ev.kind == PointerEventKind.down) {
                            root.start-drag();
                        }
                    }
                    Text {
                        x: parent.width - self.width - 6px;
                        // 狭幅時はラベルを省き値のみ。それでも収まらない幅では隠して
                        // タブへのはみ出し重なりを防ぐ（ドラッグ領域は stretch で潰れ得る）
                        text: root.narrow-header
                            ? root.total-text + "  " + root.elapsed-text
                            : @tr("合計DPS") + " " + root.total-text + "   " + @tr("経過") + " " + root.elapsed-text;
                        visible: self.width + 12px <= parent.width;
                        color: #c8c8d8;
                        font-size: 11px * root.font-scale;
                        vertical-alignment: center;
                    }
                }
                // 観測ステータスドット（緑=ゲーム通信受信中 / 青=待機 / 赤=開始失敗 / 灰=起動中）
                Rectangle {
                    width: 12px;
                    Rectangle {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 7px;
                        height: 7px;
                        border-radius: 3.5px;
                        background: root.capture-state == 2 ? #4caf50
                                  : (root.capture-state == 3 ? #e05252
                                  : (root.capture-state == 1 ? #5a8fd8 : #777777));
                    }
                }
                pause-btn := HeaderButton {
                    width: root.narrow-header ? 26px : 40px;
                    label: root.paused ? @tr("再開") : @tr("停止");
                    icon-commands: root.paused ? HeaderIcons.play : HeaderIcons.pause;
                    icon-fill: true;
                    show-icon: root.narrow-header;
                    active: root.paused;
                    clicked => { root.toggle-pause(); }
                }
                reset-btn := HeaderButton {
                    width: root.narrow-header ? 26px : 44px;
                    label: @tr("初期化");
                    icon-commands: HeaderIcons.reset;
                    show-icon: root.narrow-header;
                    clicked => { root.reset-encounter(); }
                }
                // 計測中（kind=2）はカウントダウン M:SS を狭幅でもテキスト表示する
                measure-btn := HeaderButton {
                    width: root.narrow-header
                        ? (root.measure-kind == 2 ? 36px : 26px)
                        : (root.measure-kind == 0 ? 44px : 58px);
                    label: root.measure-kind == 0
                        ? @tr("計測")
                        : (root.measure-kind == 1 ? @tr("待機") : root.measure-text);
                    icon-commands: HeaderIcons.stopwatch;
                    show-icon: root.narrow-header && root.measure-kind != 2;
                    active: root.measure-kind != 0;
                    clicked => { root.toggle-measure(); }
                }
                copy-btn := HeaderButton {
                    width: root.narrow-header ? 26px : 44px;
                    label: root.copied ? @tr("済") : @tr("コピー");
                    icon-commands: root.copied ? HeaderIcons.check : HeaderIcons.copy;
                    show-icon: root.narrow-header;
                    active: root.copied;
                    active-bg: #2e7d32;
                    active-fg: #cdd;
                    clicked => { root.copy-list(); }
                }
                settings-btn := HeaderButton {
                    width: root.narrow-header ? 26px : 36px;
                    label: @tr("設定");
                    icon-commands: HeaderIcons.settings;
                    show-icon: root.narrow-header;
                    active: root.settings-open;
                    active-bg: #ffffff20;
                    active-fg: #cdd;
                    clicked => { root.toggle-settings(); }
                }
                pin-btn := HeaderButton {
                    width: root.narrow-header ? 26px : 36px;
                    label: @tr("前面");
                    icon-commands: HeaderIcons.pin;
                    icon-fill: true;
                    show-icon: root.narrow-header;
                    active: root.aot;
                    // 最前面はデフォルトON＝常時表示状態。警告色の黄ではなく
                    // アクセント色で控えめに示す（設定ボタンと同様の抑えたトーン）。
                    active-bg: #ffffff20;
                    active-fg: Theme.accent;
                    clicked => { root.set-bool("aot", !root.aot); }
                }
                min-btn := TouchArea {
                    width: 26px;
                    clicked => { root.minimize(); }
                    Rectangle {
                        background: min-btn.has-hover ? #ffffff20 : transparent;
                        border-radius: 4px;
                        Text { text: "−"; color: white; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
                quit-btn := TouchArea {
                    width: 26px;
                    clicked => { root.quit(); }
                    Rectangle {
                        background: quit-btn.has-hover ? #c0392b : transparent;
                        border-radius: 4px;
                        Text { text: "×"; color: white; font-size: 12px; }
                    }
                }
            }
        }

        // ── 一覧ビュー（履歴タブ以外・通常列）──
        if !root.settings-open && root.view == 0 && root.tab != 3 && !root.cfg-ui.compact-split: VerticalLayout {
            vertical-stretch: 1;
            Rectangle {
                height: 16px;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 6px;
                    Text { text: @tr("プレイヤー"); color: #888; font-size: 10px * root.font-scale; horizontal-stretch: 1; vertical-alignment: center; }
                    if root.show-graph-col: Text { text: @tr("推移"); color: #888; font-size: 9px * root.font-scale; width: 60px; horizontal-alignment: center; vertical-alignment: center; }
                    Text {
                        text: root.tab == 1 ? @tr("回復") : (root.tab == 2 ? @tr("被ダメ") : @tr("ダメージ"));
                        color: #888;
                        font-size: 10px * root.font-scale;
                        width: 64px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                    Text { text: @tr("DPS"); color: #888; font-size: 10px * root.font-scale; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: @tr("%"); color: #888; font-size: 10px * root.font-scale; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.crit: Text { text: @tr("会心率"); color: #888; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.crit-value: Text { text: @tr("会心ダメ率"); color: #888; font-size: 9px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.lucky: Text { text: @tr("幸運率"); color: #888; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.lucky-value: Text { text: @tr("幸運ダメ率"); color: #888; font-size: 9px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.hits: Text { text: @tr("ヒット数"); color: #888; font-size: 9px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.hpm: Text { text: @tr("毎分ヒット数"); color: #888; font-size: 9px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    if root.cols.score: Text { text: @tr("戦力"); color: #888; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                    // データ行末尾のウォッチピン(14px)に合わせた見出し用スペーサー（列ズレ防止）
                    Rectangle { width: 14px; }
                }
            }
            Flickable {
                vertical-stretch: 1;
                max-height: 100000px;
                viewport-height: rowbox.preferred-height;
                rowbox := VerticalLayout {
                    for row in root.rows: PlayerRowItem {
                        entry: row;
                        highlight-local: root.highlight-local;
                        cols: root.cols;
                        font-scale: root.font-scale;
                        show-graph-col: root.show-graph-col;
                        show-consumable: root.show-consumable;
                        activate(u) => { root.open-drill(u); }
                        toggle-watch(u) => { root.toggle-watch(u); }
                    }
                    // 空状態: 観測ステータスに応じた案内（初回ユーザーの「動いているのか」を解消）
                    if root.rows.length == 0: VerticalLayout {
                        padding-top: 18px;
                        spacing: 5px;
                        Text {
                            text: root.capture-state == 3 ? @tr("パケット観測の開始に失敗しました")
                                : (root.capture-state == 2 ? @tr("ゲーム通信を検出中") : @tr("ゲーム通信を待機中"));
                            color: root.capture-state == 3 ? #e05252 : #999;
                            font-size: 12px;
                            horizontal-alignment: center;
                        }
                        if root.capture-state != 3: Text {
                            text: @tr("戦闘を開始すると自動的に表示されます");
                            color: #777;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                        if root.capture-state != 3 && root.capture-state != 2: Text {
                            text: @tr("検出されない場合はゾーン移動か再ログインで検出が始まります");
                            color: #666;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                        if root.capture-state != 3 && root.capture-state != 2: Text {
                            text: @tr("VPN / ExitLag / NoPing 等の使用中は検出できないことがあります");
                            color: #666;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                        if root.capture-state == 3: Text {
                            text: @tr("管理者権限で起動しているか確認してください");
                            color: #888;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                        if root.capture-state == 3: Text {
                            text: @tr("WinDivert.dll / WinDivert64.sys が exe と同じフォルダにあるか確認してください");
                            color: #888;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }

        // ── 軽量分割表示（2カラム・履歴タブ以外）──
        if !root.settings-open && root.view == 0 && root.tab != 3 && root.cfg-ui.compact-split: Flickable {
            vertical-stretch: 1;
            max-height: 100000px;
            viewport-height: csbox.preferred-height;
            csbox := HorizontalLayout {
                spacing: 4px;
                // 左カラム（前半）
                VerticalLayout {
                    horizontal-stretch: 1;
                    Rectangle {
                        height: 16px;
                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 6px;
                            spacing: 5px;
                            Text { text: @tr("プレイヤー"); color: #888; font-size: 10px * root.font-scale; horizontal-stretch: 1; vertical-alignment: center; }
                            Text { text: root.tab == 1 ? @tr("回復") : (root.tab == 2 ? @tr("被ダメ") : @tr("ダメージ")); color: #888; font-size: 10px * root.font-scale; width: 56px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: @tr("DPS"); color: #888; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                        }
                    }
                    for row in root.compact-left: CompactRowItem {
                        entry: row;
                        highlight-local: root.highlight-local;
                        font-scale: root.font-scale;
                        activate(u) => { root.open-drill(u); }
                    }
                }
                // 右カラム（後半）
                VerticalLayout {
                    horizontal-stretch: 1;
                    Rectangle {
                        height: 16px;
                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 6px;
                            spacing: 5px;
                            Text { text: @tr("プレイヤー"); color: #888; font-size: 10px * root.font-scale; horizontal-stretch: 1; vertical-alignment: center; }
                            Text { text: root.tab == 1 ? @tr("回復") : (root.tab == 2 ? @tr("被ダメ") : @tr("ダメージ")); color: #888; font-size: 10px * root.font-scale; width: 56px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: @tr("DPS"); color: #888; font-size: 10px * root.font-scale; width: 50px; horizontal-alignment: right; vertical-alignment: center; }
                        }
                    }
                    for row in root.compact-right: CompactRowItem {
                        entry: row;
                        highlight-local: root.highlight-local;
                        font-scale: root.font-scale;
                        activate(u) => { root.open-drill(u); }
                    }
                    if root.rows.length == 0: Text { text: @tr("データなし"); color: #666; font-size: 12px; height: 40px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }

        // ── 履歴ビュー ──
        if !root.settings-open && root.view == 0 && root.tab == 3: VerticalLayout {
            vertical-stretch: 1;
            Rectangle {
                height: 20px;
                background: #20202e;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 6px;
                    spacing: 6px;
                    Text { text: @tr("履歴"); color: #888; font-size: 10px * root.font-scale; horizontal-stretch: 1; vertical-alignment: center; }
                    clear-btn := TouchArea {
                        width: 70px;
                        clicked => { root.clear-history(); }
                        Rectangle {
                            background: clear-btn.has-hover ? #ffffff20 : #ffffff10;
                            border-radius: 3px;
                            Text { text: @tr("履歴クリア"); color: #cdd; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
            }
            Flickable {
                vertical-stretch: 1;
                max-height: 100000px;
                viewport-height: histbox.preferred-height;
                histbox := VerticalLayout {
                    for h in root.history-rows: HistoryRowItem {
                        e: h;
                        font-scale: root.font-scale;
                        toggle(id) => { root.toggle-history(id); }
                    }
                    if root.history-rows.length == 0: Text {
                        text: @tr("履歴なし");
                        color: #666;
                        font-size: 12px;
                        height: 40px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── スキル内訳ビュー ──
        if !root.settings-open && root.view == 1: VerticalLayout {
            vertical-stretch: 1;
            Rectangle {
                height: 20px;
                background: #20202e;
                HorizontalLayout {
                    padding-left: 4px;
                    padding-right: 8px;
                    spacing: 6px;
                    back-btn := TouchArea {
                        width: 56px;
                        clicked => { root.back(); }
                        Rectangle {
                            background: back-btn.has-hover ? #ffffff20 : transparent;
                            border-radius: 4px;
                            Text { text: "← " + @tr("戻る"); color: #cdd; font-size: 11px; }
                        }
                    }
                    Text { text: root.inspected-name; color: #e6e6f0; font-size: 12px * root.font-scale; horizontal-stretch: 1; overflow: elide; vertical-alignment: center; }
                }
            }
            Rectangle {
                height: 16px;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 6px;
                    Text { text: @tr("スキル"); color: #888; font-size: 10px * root.font-scale; horizontal-stretch: 1; vertical-alignment: center; }
                    Text { text: @tr("ダメージ"); color: #888; font-size: 10px * root.font-scale; width: 64px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: @tr("DPS"); color: #888; font-size: 10px * root.font-scale; width: 58px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: @tr("%"); color: #888; font-size: 10px * root.font-scale; width: 44px; horizontal-alignment: right; vertical-alignment: center; }
                }
            }
            Flickable {
                vertical-stretch: 1;
                max-height: 100000px;
                viewport-height: skillbox.preferred-height;
                skillbox := VerticalLayout {
                    for s in root.skill-rows: SkillRowItem {
                        entry: s;
                        clickable: root.skills-clickable;
                        font-scale: root.font-scale;
                        activate(u) => { root.drill-row(u); }
                    }
                    if root.skill-rows.length == 0: Text {
                        text: @tr("データなし");
                        color: #666;
                        font-size: 12px;
                        height: 40px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── 設定パネル ──
        if root.settings-open: VerticalLayout {
            vertical-stretch: 1;
            Rectangle {
                height: 20px;
                background: #20202e;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 6px;
                    Text { text: @tr("設定"); color: #e6e6f0; font-size: 12px; horizontal-stretch: 1; vertical-alignment: center; }
                    close-btn := TouchArea {
                        width: 24px;
                        clicked => { root.toggle-settings(); }
                        Rectangle {
                            background: close-btn.has-hover ? #c0392b : transparent;
                            border-radius: 4px;
                            Text { text: "×"; color: white; font-size: 11px; }
                        }
                    }
                }
            }
            Flickable {
                vertical-stretch: 1;
                max-height: 100000px;
                viewport-height: setbox.preferred-height;
                // 横は Flickable 幅に固定（横スクロール無効＝内側の列レイアウトが窓幅へ
                // 逆流しないようにし、set-cols(root.width依存) との binding loop を断つ）
                viewport-width: self.width;
                setbox := VerticalLayout {
                    padding: 4px;
                    spacing: 6px;
                    // 横の layoutinfo を定数化し、列数(set-cols)→窓幅→set-cols の binding loop を断つ。
                    // 実幅は親 Flickable の viewport-width(=自幅)で決まるので各値は表示に影響しない。
                    min-width: 0px;
                    preferred-width: 0px;
                    max-width: 100000px;
                    // ── 設定セクションのレスポンシブ多列グリッド（窓幅で 1/2/3 列）──
                    // 6セクションを scol(i) で各カラムへ振り分け。同じ定義を列ごとに条件配置する。
                    HorizontalLayout {
                        spacing: 8px;
                        // ── 列0 ──
                        VerticalLayout {
                            horizontal-stretch: 1;
                            // preferred 幅を内容非依存(0)にして全カラムを完全な等幅にする。
                            // （内容の preferred 差で stretch 配分が偏り、表示列が狭くなるのを防ぐ）
                            min-width: 0px;
                            preferred-width: 0px;
                            alignment: start; // 上詰め（カラム間の高さ差で見出し直下に隙間が出るのを防ぐ）
                            spacing: 1px;
                            if root.scol(0) == 0: CharacterSection { uid-value: root.selected-uid-value; uid-name: root.selected-uid-name; candidates: root.uid-candidates; set-uid(u) => { root.set-selected-uid(u); } }
                            if root.scol(1) == 0: DisplayColsSection { cfg: root.cfg-ui; set-bool(k, v) => { root.set-bool(k, v); } }
                            if root.scol(2) == 0: DisplaySection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } }
                            if root.scol(3) == 0: OverlaySection { cfg: root.cfg-ui; set-bool(k, v) => { root.set-bool(k, v); } }
                            if root.scol(4) == 0: CombatSection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                            if root.scol(5) == 0: HistorySection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                        }
                        // ── 列1（2列以上のとき）──
                        if root.set-cols >= 2: VerticalLayout {
                            horizontal-stretch: 1;
                            min-width: 0px;
                            preferred-width: 0px;
                            alignment: start;
                            spacing: 1px;
                            if root.scol(0) == 1: CharacterSection { uid-value: root.selected-uid-value; uid-name: root.selected-uid-name; candidates: root.uid-candidates; set-uid(u) => { root.set-selected-uid(u); } }
                            if root.scol(1) == 1: DisplayColsSection { cfg: root.cfg-ui; set-bool(k, v) => { root.set-bool(k, v); } }
                            if root.scol(2) == 1: DisplaySection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } }
                            if root.scol(3) == 1: OverlaySection { cfg: root.cfg-ui; set-bool(k, v) => { root.set-bool(k, v); } }
                            if root.scol(4) == 1: CombatSection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                            if root.scol(5) == 1: HistorySection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                        }
                        // ── 列2（3列のとき）──
                        if root.set-cols >= 3: VerticalLayout {
                            horizontal-stretch: 1;
                            min-width: 0px;
                            preferred-width: 0px;
                            alignment: start;
                            spacing: 1px;
                            if root.scol(0) == 2: CharacterSection { uid-value: root.selected-uid-value; uid-name: root.selected-uid-name; candidates: root.uid-candidates; set-uid(u) => { root.set-selected-uid(u); } }
                            if root.scol(1) == 2: DisplayColsSection { cfg: root.cfg-ui; set-bool(k, v) => { root.set-bool(k, v); } }
                            if root.scol(2) == 2: DisplaySection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } set-str(k, v) => { root.set-str(k, v); } }
                            if root.scol(3) == 2: OverlaySection { cfg: root.cfg-ui; set-bool(k, v) => { root.set-bool(k, v); } }
                            if root.scol(4) == 2: CombatSection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                            if root.scol(5) == 2: HistorySection { cfg: root.cfg-ui; nums: root.nums; set-bool(k, v) => { root.set-bool(k, v); } bump-num(k, d) => { root.bump-num(k, d); } }
                        }
                    }
                    // ── 不透明度（常に全幅。2列以上のときは複数列ぶんの横幅で操作しやすく）──
                    // ラベル「不透明度」は OpacityRow 内に持つため見出しは付けない。
                    OpacityRow { value: root.win-opacity; changed(v) => { root.set-opacity(v); } }
                    // ── テンプレート（常に全幅）──
                    Text { text: @tr("テンプレート"); color: #888; font-size: 10px; }
                    TemplateField {
                        label: @tr("名前列テンプレ");
                        value: root.name-template-value;
                        preview: root.name-preview;
                        hint: "{name} {class} {spec} {score} {seasonLv} {seasonStr}";
                        changed(t) => { root.set-str("name-template", t); }
                        reset => { root.reset-str("name-template"); }
                    }
                    TemplateField {
                        label: @tr("コピーテンプレ");
                        value: root.copy-template-value;
                        preview: root.copy-preview;
                        hint: "{rank} {name} {class} {spec} {dmg} {dps} {pct} {crit} {critV} {lucky} {luckyV} {hits} {hpm} {score} {seasonLv} {seasonStr}";
                        changed(t) => { root.set-str("copy-template", t); }
                        reset => { root.reset-str("copy-template"); }
                    }
                }
            }
        }
    }

    // ── リサイズハンドル（縁/角ドラッグでサイズ変更）。縁6px・角14px ──
    ResizeHandle { dir: 0; mouse-cursor: ns-resize; resize(d) => { root.start-resize(d); } x: 14px; y: 0; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 1; mouse-cursor: ns-resize; resize(d) => { root.start-resize(d); } x: 14px; y: root.height - 6px; width: root.width - 28px; height: 6px; }
    ResizeHandle { dir: 2; mouse-cursor: ew-resize; resize(d) => { root.start-resize(d); } x: root.width - 6px; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 3; mouse-cursor: ew-resize; resize(d) => { root.start-resize(d); } x: 0; y: 14px; width: 6px; height: root.height - 28px; }
    ResizeHandle { dir: 5; mouse-cursor: nwse-resize; resize(d) => { root.start-resize(d); } x: 0; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 4; mouse-cursor: nesw-resize; resize(d) => { root.start-resize(d); } x: root.width - 14px; y: 0; width: 14px; height: 14px; }
    ResizeHandle { dir: 7; mouse-cursor: nesw-resize; resize(d) => { root.start-resize(d); } x: 0; y: root.height - 14px; width: 14px; height: 14px; }
    ResizeHandle { dir: 6; mouse-cursor: nwse-resize; resize(d) => { root.start-resize(d); } x: root.width - 14px; y: root.height - 14px; width: 14px; height: 14px; }

    // ── 3分計測 結果モーダル（最上層・背景クリックで閉じる）──
    if root.result-open: Rectangle {
        width: 100%;
        height: 100%;
        background: #000000cc;
        backdrop := TouchArea { clicked => { root.close-result(); } }
        Rectangle {
            x: 12px;
            y: 12px;
            width: parent.width - 24px;
            height: parent.height - 24px;
            background: #14141ef7;
            border-width: 1px;
            border-color: #ffffff26;
            border-radius: 8px;
            // カード内クリックを吸収し背景の close へ落とさない
            TouchArea {}
            VerticalLayout {
                padding: 12px;
                spacing: 8px;
                HorizontalLayout {
                    Text { text: @tr("3分計測 結果"); color: Theme.accent; font-size: 13px; horizontal-stretch: 1; vertical-alignment: center; }
                    rclose := TouchArea {
                        width: 24px;
                        clicked => { root.close-result(); }
                        Rectangle {
                            background: rclose.has-hover ? #c0392b : transparent;
                            border-radius: 4px;
                            Text { text: "×"; color: white; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
                // サマリ（総合DPS/総ダメ/計測時間）はヘッダー直下にコンパクトに残す
                HorizontalLayout {
                    spacing: 22px;
                    VerticalLayout { spacing: 1px; Text { text: "DPS"; color: #888; font-size: 10px; } Text { text: root.result-dps; color: Theme.accent; font-size: 14px; } }
                    VerticalLayout { spacing: 1px; Text { text: @tr("総ダメ"); color: #888; font-size: 10px; } Text { text: root.result-dmg; color: #e6e6f0; font-size: 14px; } }
                    VerticalLayout { spacing: 1px; Text { text: @tr("計測時間"); color: #888; font-size: 10px; } Text { text: root.result-duration; color: #e6e6f0; font-size: 14px; } }
                }
                // ── エリア1（フル幅）: 選択キャラ折れ線ラベル ＋ キャラ一覧（最大5・3行超は縦スクロール）＋ 累積合計ダメージ折れ線 ──
                VerticalLayout {
                    vertical-stretch: 30;
                    spacing: 4px;
                    // キャラ一覧（高さ≒3行ぶん。超過は縦スクロール）
                    Rectangle {
                        height: 58px;
                        Flickable {
                            width: 100%;
                            height: 100%;
                            viewport-height: charbox.preferred-height;
                            charbox := VerticalLayout {
                                spacing: 2px;
                                for r in root.result-rows: ResultRow { e: r; activate(u) => { root.select-result-player(u); } }
                                if root.result-rows.length == 0: Text { text: @tr("ダメージなし"); color: #555; font-size: 11px; height: 30px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                    }
                    // 選択キャラの区間DPS折れ線ラベル
                    Text {
                        text: root.result-char-name == "" ? @tr("DPS推移") : @tr("DPS推移") + " — " + root.result-char-name;
                        color: #888;
                        font-size: 10px;
                        overflow: elide;
                    }
                    // 選択キャラの区間DPS折れ線（残り高さいっぱい・左にY軸目安）
                    SparkGraph {
                        vertical-stretch: 1;
                        visible-graph: root.result-char-spark-visible;
                        commands: root.result-char-spark;
                        line-color: Theme.accent;
                        axis-top: root.result-char-axis-top;
                        axis-mid: root.result-char-axis-mid;
                        duration-ms: root.result-duration-ms;
                        empty-text: "";
                    }
                }
                // ── 中段: エリア2(65%)＝スキル内訳 ｜ エリア3(35%)＝円グラフ ──
                HorizontalLayout {
                    vertical-stretch: 50;
                    spacing: 8px;
                    // エリア2（65%）: スキル内訳（残り高さいっぱい・超過は縦スクロール）
                    VerticalLayout {
                        horizontal-stretch: 0.65;
                        spacing: 4px;
                        Text { text: root.result-pie-title; color: #cdd; font-size: 10px; overflow: elide; }
                        Rectangle {
                            vertical-stretch: 1;
                            Flickable {
                                width: 100%;
                                height: 100%;
                                viewport-height: resskillbox.preferred-height;
                                resskillbox := VerticalLayout {
                                    spacing: 2px;
                                    for s in root.result-skill-rows: ResultSkillRow { e: s; activate(u) => { root.select-result-skill(u); } }
                                    if root.result-skill-rows.length == 0: Text { text: @tr("スキルなし"); color: #555; font-size: 11px; height: 30px; horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                        }
                    }
                    // エリア3（35%）: TOP10＋その他 の円グラフ＋凡例
                    VerticalLayout {
                        horizontal-stretch: 0.35;
                        spacing: 4px;
                        // 円グラフ（領域内に収まる正方形。区切り線は灰色で外周に届かない）。
                        // 凡例より高さ配分を多めにして円を大きく見せる（円:凡例 = 2:1）。
                        pie-col := Rectangle {
                            vertical-stretch: 2;
                            property <length> sz: self.width < self.height ? self.width : self.height;
                            Rectangle {
                                width: pie-col.sz;
                                height: pie-col.sz;
                                x: (pie-col.width - pie-col.sz) / 2;
                                y: (pie-col.height - pie-col.sz) / 2;
                                for slice in root.result-pie: Path {
                                    width: 100%;
                                    height: 100%;
                                    viewbox-x: 0;
                                    viewbox-y: 0;
                                    viewbox-width: 100;
                                    viewbox-height: 100;
                                    commands: slice.commands;
                                    fill: slice.is-line ? transparent : slice.color;
                                    stroke: slice.is-line ? #8a8a8acc : transparent;
                                    stroke-width: slice.is-line ? 1px : 0px;
                                }
                            }
                        }
                        // 凡例（スキル名＋同色＋割合）
                        Flickable {
                            vertical-stretch: 1;
                            max-height: 100000px;
                            viewport-height: legbox.preferred-height;
                            legbox := VerticalLayout {
                                spacing: 1px;
                                for lg in root.result-legend: HorizontalLayout {
                                    spacing: 4px;
                                    height: 14px;
                                    VerticalLayout { alignment: center; Rectangle { width: 8px; height: 8px; background: lg.color; border-radius: 2px; } }
                                    Text { text: lg.name; color: #bbb; font-size: 9px; overflow: elide; horizontal-stretch: 1; vertical-alignment: center; }
                                    Text { text: lg.pct-text; color: #888; font-size: 9px; vertical-alignment: center; }
                                }
                            }
                        }
                    }
                }
                // ── エリア4（フル幅）: 選択スキル折れ線ラベル ＋ 区間DPS折れ線 ──
                VerticalLayout {
                    vertical-stretch: 20;
                    spacing: 4px;
                    Text {
                        text: root.result-skill-name == "" ? @tr("スキルDPS推移") : @tr("スキルDPS推移") + " — " + root.result-skill-name;
                        color: #888;
                        font-size: 10px;
                        overflow: elide;
                    }
                    SparkGraph {
                        vertical-stretch: 1;
                        visible-graph: root.result-skill-spark-visible;
                        commands: root.result-skill-spark;
                        line-color: #66bb6a;
                        axis-top: root.result-skill-axis-top;
                        axis-mid: root.result-skill-axis-mid;
                        duration-ms: root.result-duration-ms;
                        empty-text: @tr("スキルを選択");
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    // 透かし（画像コピーに写り込む小さなクレジット）。stretch で余白を吸収しボタンを右寄せ
                    Text {
                        text: root.app-version;
                        color: #555;
                        font-size: 9px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    copy-img-r := TouchArea {
                        width: 76px;
                        height: 24px;
                        clicked => { root.copy-result-image(); }
                        Rectangle { background: root.result-img-copied ? #2e7d32 : (copy-img-r.has-hover ? #ffffff20 : #ffffff10); border-radius: 4px; Text { text: root.result-img-copied ? @tr("済") : @tr("画像コピー"); color: #ccc; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; } }
                    }
                    copy-r := TouchArea {
                        width: 64px;
                        height: 24px;
                        clicked => { root.copy-result(); }
                        Rectangle { background: copy-r.has-hover ? #ffffff20 : #ffffff10; border-radius: 4px; Text { text: @tr("コピー"); color: #ccc; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; } }
                    }
                    restart-r := TouchArea {
                        width: 64px;
                        height: 24px;
                        clicked => { root.restart-measure(); }
                        Rectangle { background: restart-r.has-hover ? #ffffff20 : #ffffff10; border-radius: 4px; Text { text: @tr("再計測"); color: #ccc; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; } }
                    }
                    closebtn-r := TouchArea {
                        width: 64px;
                        height: 24px;
                        clicked => { root.close-result(); }
                        Rectangle { background: closebtn-r.has-hover ? Theme.accent.with-alpha(0.2) : Theme.accent.with-alpha(0.133); border-width: 1px; border-color: Theme.accent.with-alpha(0.45); border-radius: 4px; Text { text: @tr("閉じる"); color: Theme.accent; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; } }
                    }
                }
            }
        }
    }
}

// ─── 自キャラ バフ/デバフ オーバーレイ ───────────────────────────────
struct StatusEntryUi {
    name: string,
    remaining-text: string,
    bar-ratio: float,
    bar-color: color,
    layer-text: string,
    is-low: bool,
    border-color: color,
}

// no-frame オーバーレイ右上の閉じるボタン。クリックで設定トグルOFFと連動して窓を隠す。
// Dingbats を避け Latin-1「×」を使用（CLAUDE.md）。最後の子＝最上層に置き縁リサイズより優先。
component OverlayCloseButton inherits TouchArea {
    callback close();
    width: 16px;
    height: 14px;
    mouse-cursor: pointer;
    clicked => { root.close(); }
    Rectangle {
        background: root.has-hover ? #c0392b : #ffffff14;
        border-radius: 3px;
        Text { text: "×"; color: white; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
    }
}

component StatusRow inherits Rectangle {
    in property <StatusEntryUi> e;
    in property <float> font-scale: 1.0;
    height: 16px;
    border-width: 1px;
    border-color: root.e.border-color;
    border-radius: 3px;
    background: #00000059;
    HorizontalLayout {
        padding-left: 5px;
        padding-right: 5px;
        spacing: 5px;
        Text { text: root.e.name; color: #ffffffd9; font-size: 9px * root.font-scale; overflow: elide; horizontal-stretch: 1; vertical-alignment: center; }
        VerticalLayout {
            alignment: center;
            width: 64px;
            Rectangle {
                height: 4px;
                background: #ffffff1f;
                border-radius: 2px;
                Rectangle { x: 0; width: parent.width * root.e.bar-ratio; height: 100%; background: root.e.bar-color; border-radius: 2px; }
            }
        }
        Text { text: root.e.layer-text; color: #ffffff73; font-size: 8px * root.font-scale; width: 22px; vertical-alignment: center; }
        Text { text: root.e.remaining-text; color: root.e.is-low ? #ff7043 : #ffffffe6; font-size: 9px * root.font-scale; width: 36px; horizontal-alignment: right; vertical-alignment: center; }
    }
}

export component SelfStatusOverlay inherits Window {
    in property <[StatusEntryUi]> buffs;
    in property <[StatusEntryUi]> debuffs;
    in property <bool> waiting;
    in property <float> font-scale: 1.0; // メインの font_size に連動
    callback start-drag();
    callback start-resize(int);
    callback close-window();

    title: @tr("自キャラ バフ/デバフ表示");
    default-font-family: "Yu Gothic UI";
    no-frame: true;
    always-on-top: true;
    background: #0a0a12d1;
    preferred-width: 220px;
    preferred-height: 180px;

    // 全面ドラッグ（外周フレーム相当）
    drag := TouchArea {
        mouse-cursor: move;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down) {
                root.start-drag();
            }
        }
    }
    VerticalLayout {
        padding: 8px;
        spacing: 3px;
        alignment: start; // 上詰め（既定stretchだと余白分配で下寄り/間延びする）
        if root.waiting: Text { text: @tr("自キャラ判定中..."); color: #ffffff4d; font-size: 10px * root.font-scale; horizontal-alignment: center; }
        if !root.waiting && root.buffs.length == 0 && root.debuffs.length == 0: Text { text: @tr("バフ/デバフなし"); color: #ffffff4d; font-size: 10px * root.font-scale; horizontal-alignment: center; }
        if !root.waiting && root.buffs.length > 0: Text { text: @tr("バフ"); color: #ffffff66; font-size: 9px * root.font-scale; }
        for b in root.buffs: StatusRow { e: b; font-scale: root.font-scale; }
        if !root.waiting && root.debuffs.length > 0: Text { text: @tr("デバフ"); color: #ffffff66; font-size: 9px * root.font-scale; }
        for d in root.debuffs: StatusRow { e: d; font-scale: root.font-scale; }
    }
    // 縁ドラッグでリサイズ（最前面・最後の子＝最上層で縁イベントを捕捉）
    ResizeEdges { width: 100%; height: 100%; resize(d) => { root.start-resize(d); } }
    // 閉じる（右上・ResizeEdges より後＝最上層で右上角クリックを優先）
    OverlayCloseButton { x: root.width - self.width - 2px; y: 2px; close => { root.close-window(); } }
}

// ─── バフタイマー オーバーレイ（イマジンデバフの円形タイマー）────────────
struct BuffCell {
    active: bool,
    arc-commands: string,
    color: color,
    text: string,
    text-color: color,
}

struct BuffPlayerRow {
    name: string,
    tina: BuffCell,
    aluna: BuffCell,
    tarta: BuffCell,
    basilisk: BuffCell,
}

component CircularCell inherits Rectangle {
    in property <BuffCell> cell;
    in property <float> font-scale: 1.0;
    width: 28px;
    height: 28px;
    opacity: root.cell.active ? 1.0 : 0.25;
    Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 28;
        viewbox-height: 28;
        commands: "M 14 1.5 A 12.5 12.5 0 1 1 13.99 1.5";
        stroke: #ffffff1f;
        stroke-width: 3px;
        fill: transparent;
    }
    Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 28;
        viewbox-height: 28;
        commands: root.cell.arc-commands;
        stroke: root.cell.color;
        stroke-width: 3px;
        fill: transparent;
    }
    Text {
        text: root.cell.text;
        color: root.cell.text-color;
        font-size: 9px * root.font-scale;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }
}

component BuffPlayerRowItem inherits Rectangle {
    in property <BuffPlayerRow> p;
    in property <float> font-scale: 1.0;
    in property <bool> show-tina: true;
    in property <bool> show-aluna: true;
    in property <bool> show-tarta: true;
    in property <bool> show-basilisk: true;
    height: 30px;
    HorizontalLayout {
        spacing: 4px;
        Text { text: root.p.name; color: #cdd; font-size: 10px * root.font-scale; width: 46px; overflow: elide; vertical-alignment: center; }
        if root.show-tina: VerticalLayout { width: 48px; alignment: center; HorizontalLayout { alignment: center; CircularCell { cell: root.p.tina; font-scale: root.font-scale; } } }
        if root.show-aluna: VerticalLayout { width: 48px; alignment: center; HorizontalLayout { alignment: center; CircularCell { cell: root.p.aluna; font-scale: root.font-scale; } } }
        if root.show-tarta: VerticalLayout { width: 48px; alignment: center; HorizontalLayout { alignment: center; CircularCell { cell: root.p.tarta; font-scale: root.font-scale; } } }
        if root.show-basilisk: VerticalLayout { width: 48px; alignment: center; HorizontalLayout { alignment: center; CircularCell { cell: root.p.basilisk; font-scale: root.font-scale; } } }
        // ヘッダと同じ末尾スペーサー（列の右寄せズレ防止＋×ボタン余白）
        Rectangle { min-width: 14px; horizontal-stretch: 1; }
    }
}

export component BuffOverlay inherits Window {
    in property <[BuffPlayerRow]> players;
    in property <bool> empty;
    in property <float> font-scale: 1.0; // メインの font_size に連動
    in property <bool> show-tina: true;
    in property <bool> show-aluna: true;
    in property <bool> show-tarta: true;
    in property <bool> show-basilisk: true;
    callback start-drag();
    callback start-resize(int);
    callback close-window();

    title: @tr("イマジンデバフタイマー");
    default-font-family: "Yu Gothic UI";
    no-frame: true;
    always-on-top: true;
    background: #0a0a12d1;
    preferred-width: 250px;
    preferred-height: 150px;

    drag := TouchArea {
        mouse-cursor: move;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down) {
                root.start-drag();
            }
        }
    }
    VerticalLayout {
        padding: 8px;
        spacing: 2px;
        alignment: start; // 上詰め
        if root.empty: Text { text: @tr("DPS一覧でピンアイコンをクリック"); color: #ffffff59; font-size: 10px * root.font-scale; horizontal-alignment: center; }
        if !root.empty: HorizontalLayout {
            spacing: 4px;
            Rectangle { width: 46px; }
            if root.show-tina: Text { text: @tr("ティナ"); color: #ff4d6d; font-size: 9px * root.font-scale; width: 48px; horizontal-alignment: center; vertical-alignment: center; }
            if root.show-aluna: Text { text: @tr("アルーナ"); color: #5fd35f; font-size: 9px * root.font-scale; width: 48px; horizontal-alignment: center; vertical-alignment: center; }
            if root.show-tarta: Text { text: @tr("タータ"); color: #b98bff; font-size: 9px * root.font-scale; width: 48px; horizontal-alignment: center; vertical-alignment: center; }
            if root.show-basilisk: Text { text: @tr("バジリスク"); color: #d9a05b; font-size: 9px * root.font-scale; width: 48px; horizontal-alignment: center; vertical-alignment: center; }
            // 末尾スペーサー: 横拡大を可能にし(最大幅を無限化)、右上の×ボタン用の余白を確保
            Rectangle { min-width: 14px; horizontal-stretch: 1; }
        }
        for p in root.players: BuffPlayerRowItem {
            p: p;
            font-scale: root.font-scale;
            show-tina: root.show-tina;
            show-aluna: root.show-aluna;
            show-tarta: root.show-tarta;
            show-basilisk: root.show-basilisk;
        }
    }
    // 縁ドラッグでリサイズ
    ResizeEdges { width: 100%; height: 100%; resize(d) => { root.start-resize(d); } }
    // 閉じる（右上・ResizeEdges より後＝最上層で右上角クリックを優先）
    OverlayCloseButton { x: root.width - self.width - 2px; y: 2px; close => { root.close-window(); } }
}

